{
  "name": "rip-lang",
  "version": "1.5.4",
  "description": "A lightweight scripting language that compiles to modern JavaScript",
  "type": "module",
  "main": "src/compiler.js",
  "browser": "www/dist/rip.browser.js",
  "exports": {
    ".": {
      "bun": "./src/compiler.js",
      "node": "./src/compiler.js",
      "browser": "./www/dist/rip.browser.js",
      "default": "./src/compiler.js"
    },
    "./loader": "./rip-loader.js"
  },
  "bin": {
    "rip": "bin/rip"
  },
  "files": [
    "bin/",
    "src/",
    "docs/",
    "scripts/serve.js",
    "rip-loader.js",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "benchmark": "bun scripts/benchmark-parser.js",
    "benchmark:parser": "bun scripts/benchmark-parser-only.js",
    "benchmark:actions": "bun scripts/benchmark-parser-actions.js",
    "browser": "bun scripts/build-browser.js",
    "parser": "bun src/grammar/solar.rip -o src/parser.js src/grammar/grammar.rip",
    "parser:old": "cd && rip $c/solar-parser/src/solar.rip -o $c/rip-lang/src/parser.js $c/rip-lang/src/grammar/grammar.rip",
    "serve": "bun scripts/serve.js",
    "test": "bun test/runner.js",
    "version": "./bin/rip -v",
    "pack": "npm pack --dry-run"
  },
  "keywords": [
    "compiler",
    "language",
    "s-expression",
    "lisp",
    "bun",
    "browser",
    "transpiler",
    "coffeescript",
    "parser",
    "rip"
  ],
  "engines": {
    "bun": ">=1.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/shreeve/rip-lang.git"
  },
  "bugs": {
    "url": "https://github.com/shreeve/rip-lang/issues"
  },
  "homepage": "https://github.com/shreeve/rip-lang#readme",
  "author": "Steve Shreeve <steve.shreeve@gmail.com>",
  "license": "MIT"
}
