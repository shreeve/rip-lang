import { Product, CartData, CartItem } from '../types.rip'

export Products = component
  products:: Product[] := []
  search := ''
  sort := ''
  error := null
  loaded := false

  filtered ~=
    result = products.slice()
    if search
      term:: string = search.toLowerCase()
      result = result.filter (p) -> p.name.toLowerCase().includes(term)
    if sort is 'price-asc'
      result.sort (a, b) -> a.price - b.price
    else if sort is 'price-desc'
      result.sort (a, b) -> b.price - a.price
    result

  mounted: ->
    document.title = 'Products - Rip'
    try
      res = await fetch '/api/products'
      products = await res.json()
    catch err
      error = String(err)
    finally
      loaded = true

  cart:: CartData ~= @app.data.cart

  inCart: (product:: Product) ->
    (cart?.items or []).some (i) -> i.id is product.id

  toggleCart: (product:: Product) ->
    if @inCart(product)
      cart.items = cart.items.filter (i) -> i.id isnt product.id
    else
      cart.items = [...cart.items, { ...product, quantity: 1 }]

  clearFilters: ->
    search = ''
    sort = ''

  render
    if error
      p.error "Failed to load products"
    else if loaded
      h1 "Products"
      div.product-filters
        input
          type: "search"
          placeholder: "Search products..."
          value <=> search
        select value <=> sort
          option value: "", disabled: true, "Sort"
          option value: "price-asc", "Price: Low to High"
          option value: "price-desc", "Price: High to Low"
      if filtered.length
        div.product-list
          for product in filtered
            article
              div.image product.image
              h5 product.name
              p "$#{product.price.toFixed(2)}"
              if @inCart(product)
                button.outline @click: (-> @toggleCart(product)), "Added to Cart"
              else
                button.outline @click: (-> @toggleCart(product)), "Add to Cart"
      else
        p "No products found. "
          button.outline.link @click: @clearFilters, "Clear Filters"
