# Tests for @rip-lang/decimal. Pure (no I/O), so they run anywhere.
#
#   bun run --cwd packages/decimal test
#   rip packages/decimal/test.rip

import {
  Decimal, D,
  DecimalError, DecimalParseError, DecimalDivisionByZeroError,
  DecimalNonTerminatingError, DecimalInvalidOperationError, DecimalRangeError,
  DecimalResourceLimitError, DecimalInexactError, DecimalUnsafeConversionError,
} from '../decimal.rip'

pass = 0
fail = 0

ok = (name, cond) ->
  if cond then pass += 1 else (fail += 1; console.error "  ✗ #{name}")

eq = (name, a, b) ->
  if a is b
    pass += 1
  else
    fail += 1
    console.error "  ✗ #{name}: got #{JSON.stringify(a)} want #{JSON.stringify(b)}"

throws = (name, errType, fn) ->
  threw = false
  try
    fn()
  catch e
    threw = e instanceof errType
  ok name, threw

dec = (s) -> Decimal.parse(s)
show = (s) -> Decimal.parse(s).toString()

# ── Parsing: valid forms ──────────────────────────────────────────────────────
eq 'parse plain',          show('123'),        '123'
eq 'parse fractional',     show('1.23'),       '1.23'
eq 'parse leading +',      show('+1.5'),       '1.5'
eq 'parse leading-dot',    show('.5'),         '0.5'
eq 'parse trailing-dot',   show('5.'),         '5'
eq 'parse leading zeros',  show('001.2300'),   '1.2300'
eq 'parse preserves scale',show('1.230'),      '1.230'
eq 'parse neg zero -> 0',  show('-0.00'),      '0.00'
eq 'parse sci positive',   show('1.5e3'),      '1500'
eq 'parse sci negative',   show('1.23e-2'),    '0.0123'
eq 'parse zero',           show('0'),          '0'
eq 'parse zero scaled',    show('0.00'),       '0.00'

# ── Parsing: rejected forms ───────────────────────────────────────────────────
throws 'reject empty',          DecimalParseError, -> dec('')
throws 'reject whitespace',     DecimalParseError, -> dec(' 1.2')
throws 'reject trailing ws',    DecimalParseError, -> dec('1.2 ')
throws 'reject underscores',    DecimalParseError, -> dec('1_000')
throws 'reject commas',         DecimalParseError, -> dec('1,000')
throws 'reject currency',       DecimalParseError, -> dec('$1.00')
throws 'reject NaN',            DecimalParseError, -> dec('NaN')
throws 'reject Infinity',       DecimalParseError, -> dec('Infinity')
throws 'reject double sign',    DecimalParseError, -> dec('--1')
throws 'reject lone dot',       DecimalParseError, -> dec('.')
throws 'reject bare exponent',  DecimalParseError, -> dec('e10')

# ── Canonical string + key ────────────────────────────────────────────────────
eq 'canonical strips zeros',   dec('1.00').toCanonicalString(),  '1'
eq 'canonical 1.50 -> 1.5',    dec('1.50').toCanonicalString(),  '1.5'
eq 'canonicalKey 1.0 == 1.00', dec('1.0').canonicalKey(),        dec('1.00').canonicalKey()
eq 'toJSON is string',         dec('1.20').toJSON(),             '1.20'

# ── Exact arithmetic + scale rules ────────────────────────────────────────────
eq 'add keeps min exp',  dec('1.20').add('3.4').toString(),   '4.60'
eq 'sub keeps min exp',  dec('1.00').sub('1.0').toString(),   '0.00'
eq 'mul adds exp',       dec('1.20').mul('3.0').toString(),   '3.600'
eq 'add coerces string', dec('0.1').add('0.2').toString(),    '0.3'
eq 'mul by bigint',      dec('2.5').mul(4n).toString(),       '10.0'
eq 'neg',                dec('1.5').neg().toString(),         '-1.5'
eq 'abs',                dec('-1.5').abs().toString(),        '1.5'
eq 'sub to negative',    dec('1').sub('3').toString(),        '-2'

# ── Division: divExact (terminating) ──────────────────────────────────────────
eq 'divExact 1/2', dec('1').divExact('2').toString(), '0.5'
eq 'divExact 1/4', dec('1').divExact('4').toString(), '0.25'
eq 'divExact 1/5', dec('1').divExact('5').toString(), '0.2'
eq 'divExact 1/8', dec('1').divExact('8').toString(), '0.125'
eq 'divExact 1/20',dec('1').divExact('20').toString(),'0.05'
eq 'divExact 10/40',dec('10').divExact('40').toString(),'0.25'
throws 'divExact 1/3 non-terminating', DecimalNonTerminatingError, -> dec('1').divExact('3')
throws 'divExact 2/6 non-terminating', DecimalNonTerminatingError, -> dec('2').divExact('6')
throws 'div by zero', DecimalDivisionByZeroError, -> dec('1').divExact('0')

# ── Division: divToScale (rounded) ────────────────────────────────────────────
eq 'divToScale 1/3 @2 half-up', dec('1').divToScale('3', 2, 'HALF_UP').toString(),   '0.33'
eq 'divToScale 2/3 @4 half-even',dec('2').divToScale('3', 4, 'HALF_EVEN').toString(),'0.6667'
eq 'divToScale 10/3 @0 floor',   dec('10').divToScale('3', 0, 'FLOOR').toString(),   '3'
eq 'divToScale neg 1/3 @2',      dec('-1').divToScale('3', 2, 'HALF_UP').toString(), '-0.33'
throws 'divToScale by zero', DecimalDivisionByZeroError, -> dec('1').divToScale('0', 2, 'HALF_UP')

# ── Rounding matrix (quantize to scale 2) ─────────────────────────────────────
q = (s, mode) -> dec(s).quantizeToScale(2, mode).toString()
eq 'UP +1.234',        q('1.234', 'UP'),        '1.24'
eq 'DOWN +1.239',      q('1.239', 'DOWN'),      '1.23'
eq 'CEILING +1.231',   q('1.231', 'CEILING'),   '1.24'
eq 'CEILING -1.239',   q('-1.239', 'CEILING'),  '-1.23'
eq 'FLOOR +1.239',     q('1.239', 'FLOOR'),     '1.23'
eq 'FLOOR -1.231',     q('-1.231', 'FLOOR'),    '-1.24'
eq 'HALF_UP 1.235',    q('1.235', 'HALF_UP'),   '1.24'
eq 'HALF_DOWN 1.235',  q('1.235', 'HALF_DOWN'), '1.23'
eq 'HALF_EVEN 1.225',  q('1.225', 'HALF_EVEN'), '1.22'
eq 'HALF_EVEN 1.235',  q('1.235', 'HALF_EVEN'), '1.24'

# ── Critical negative-tie goldens (the implementation footgun) ────────────────
eq 'neg tie HALF_EVEN -> 0.00', dec('-0.005').quantizeToScale(2, 'HALF_EVEN').toString(), '0.00'
eq 'neg tie HALF_UP -> -0.01',  dec('-0.005').quantizeToScale(2, 'HALF_UP').toString(),   '-0.01'
eq 'pos tie HALF_EVEN 0.005',   dec('0.005').quantizeToScale(2, 'HALF_EVEN').toString(),  '0.00'
eq 'cents -0.005 HALF_EVEN',    dec('-0.005').toCentsNumber('HALF_EVEN'),  0
eq 'cents -0.005 HALF_UP',      dec('-0.005').toCentsNumber('HALF_UP'),    -1
eq 'cents 0.005 HALF_UP',       dec('0.005').toCentsNumber('HALF_UP'),     1
eq 'cents 0.005 HALF_EVEN',     dec('0.005').toCentsNumber('HALF_EVEN'),   0

# ── UNNECESSARY mode ──────────────────────────────────────────────────────────
eq 'UNNECESSARY exact ok', dec('1.5').quantizeToScale(2, 'UNNECESSARY').toString(), '1.50'
throws 'UNNECESSARY inexact throws', DecimalInexactError, -> dec('1.555').quantizeToScale(2, 'UNNECESSARY')

# ── Money / cents compatibility with @rip-lang/validate ───────────────────────
# validate `money` is HALF_UP, `money_even` is HALF_EVEN; both return integer
# cents. A bare integer is dollars: "129222" -> 12922200 cents.
eq 'cents $1,234.50 -> 123450', dec('1234.50').toCentsNumber('HALF_UP'),   123450
eq 'cents dollars 129222',      dec('129222').toCentsNumber('HALF_UP'),    12922200
eq 'cents 1.235 half-up 124',   dec('1.235').toCentsNumber('HALF_UP'),     124
eq 'cents 1.225 half-up 123',   dec('1.225').toCentsNumber('HALF_UP'),     123
eq 'cents 1.225 banker 122',    dec('1.225').toCentsNumber('HALF_EVEN'),   122
eq 'cents 1.235 banker 124',    dec('1.235').toCentsNumber('HALF_EVEN'),   124
eq 'toScaledInteger bigint',    dec('1.23').toScaledInteger(2, 'HALF_UP'), 123n

# ── Comparison ────────────────────────────────────────────────────────────────
ok 'eq 1.0 == 1.00',        dec('1.0').eq('1.00')
ok 'lt 1.1 < 1.2',          dec('1.1').lt('1.2')
ok 'gt -1 > -2',            dec('-1').gt('-2')
eq 'cmp equal',             dec('2.50').cmp('2.5'), 0
eq 'cmp less',              dec('1').cmp('2'), -1
eq 'cmp greater',           dec('3').cmp('2'), 1
# Huge exponent gap must compare without allocating a giant BigInt.
eq 'cmp huge gap no-throw',  Decimal.fromParts(1n, 90000).cmp(Decimal.fromParts(1n, 0)), 1
eq 'cmp huge gap negative',  Decimal.fromParts(1n, 0).cmp(Decimal.fromParts(1n, 90000)), -1

# ── from / fromScaledInteger ──────────────────────────────────────────────────
eq 'from bigint',          Decimal.from(42n).toString(),               '42'
eq 'from safe int',        Decimal.from(42).toString(),                '42'
eq 'fromScaledInteger',    Decimal.fromScaledInteger(12345n, 2).toString(), '123.45'
eq 'fromScaledInteger num',Decimal.fromScaledInteger(12345, 2).toString(),  '123.45'
throws 'from float rejected',     DecimalUnsafeConversionError, -> Decimal.from(0.1)
throws 'from unsafe int rejected',DecimalUnsafeConversionError, -> Decimal.from(9007199254740993)

# ── DuckDB DECIMAL(p, s) fit ──────────────────────────────────────────────────
ok  'fits DECIMAL(5,2)',      dec('123.45').fitsDecimal(5, 2)
ok  'not fits DECIMAL(4,2)',  not dec('123.45').fitsDecimal(4, 2)
ok  'not fits scale too small', not dec('123.45').fitsDecimal(5, 1)
eq  'toFixed pads scale',     dec('1.2').toFixed(3, 'HALF_EVEN'), '1.200'

# ── Resource limits / OOM preflight ───────────────────────────────────────────
throws 'parse huge exponent rejected', DecimalRangeError, -> dec('1e1000000000')
throws 'add huge gap rejected',        DecimalResourceLimitError, ->
  Decimal.fromParts(1n, 50000).add(Decimal.fromParts(1n, 0))
throws 'toString huge rejected',       DecimalResourceLimitError, ->
  Decimal.fromParts(1n, 100000).toString()

# ── D"..." tagged constructor ─────────────────────────────────────────────────
eq 'D literal',            D"19.99".toString(),  '19.99'
eq 'D negative',           D"-0.00".toString(),  '0.00'
throws 'D rejects interpolation', DecimalParseError, -> D"x#{1}y"

# ── Invariant enforcement (review hardening) ──────────────────────────────────
throws 'from huge bigint rejected',  DecimalResourceLimitError, -> Decimal.from(10n ** 1000n)
throws 'fromParts huge rejected',    DecimalResourceLimitError, -> Decimal.fromParts(10n ** 1000n, 0)
throws 'config unknown key rejected',DecimalInvalidOperationError, -> Decimal.config({ maxDigit: 2000 })

# Invalid rounding mode must throw even when no rounding is needed.
throws 'bad mode on exact quantize',  DecimalInvalidOperationError, -> dec('1.50').quantizeToScale(2, 'BOGUS')
throws 'bad mode on expansion',       DecimalInvalidOperationError, -> dec('1.5').quantizeToScale(2, 'BOGUS')
throws 'bad mode on exact division',  DecimalInvalidOperationError, -> dec('1').divToScale('2', 1, 'BOGUS')

# Zero must not trip false resource limits at huge exponents.
eq 'add high-exp zero',        Decimal.fromParts(0n, 100000).add('1').toString(),               '1'
eq 'zero times max coef',      Decimal.fromParts(0n, 0).mul(Decimal.parse('9'.repeat(1000))).toString(), '0'
eq 'quantize zero huge scale', Decimal.fromParts(0n, 100000).quantizeToScale(100000, 'HALF_EVEN').exp, -100000
eq 'toString zero pos-exp',    Decimal.fromParts(0n, 100000).toString(),                        '0'
throws 'divExact zero exp out of range', DecimalRangeError, ->
  Decimal.fromParts(0n, 100000).divExact(Decimal.fromParts(1n, -100000))

# divToScale negative-shift short-circuit (no huge denominator allocation).
eq 'divToScale tiny result rounds to 0', Decimal.fromParts(1n, -100000).divToScale('1', 2, 'HALF_UP').toString(), '0.00'

# fitsDecimal validates its DECIMAL(p, s) metadata.
throws 'fitsDecimal bad precision', DecimalInvalidOperationError, -> dec('1.5').fitsDecimal(0, 0)
throws 'fitsDecimal scale > prec',  DecimalInvalidOperationError, -> dec('1.5').fitsDecimal(2, 3)

# ── valueOf guard ─────────────────────────────────────────────────────────────
throws 'valueOf throws on coercion', DecimalError, -> dec('1').valueOf()

# ── Summary ───────────────────────────────────────────────────────────────────
console.log "\n@rip-lang/decimal: #{pass} passed, #{fail} failed"
process.exit(1) if fail > 0
