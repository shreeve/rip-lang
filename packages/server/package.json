{
  "name": "@rip-lang/server",
  "version": "1.3.110",
  "description": "Pure Rip web framework and application server",
  "type": "module",
  "main": "api.rip",
  "exports": {
    ".": "./api.rip",
    "./middleware": "./middleware.rip",
    "./server": "./server.rip"
  },
  "bin": {
    "rip-server": "./bin/rip-server"
  },
  "scripts": {
    "build": "rip -c server.rip",
    "test": "rip tests/read.test.rip"
  },
  "keywords": [
    "server",
    "api",
    "web-framework",
    "routing",
    "middleware",
    "validation",
    "app-server",
    "hot-reload",
    "multi-worker",
    "https",
    "tls",
    "mdns",
    "bun",
    "rip",
    "rip-lang"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/shreeve/rip-lang.git",
    "directory": "packages/server"
  },
  "homepage": "https://github.com/shreeve/rip-lang/tree/main/packages/server#readme",
  "bugs": {
    "url": "https://github.com/shreeve/rip-lang/issues"
  },
  "author": "Steve Shreeve <steve.shreeve@gmail.com>",
  "license": "MIT",
  "dependencies": {
    "rip-lang": ">=3.13.119"
  },
  "files": [
    "api.rip",
    "default.rip",
    "middleware.rip",
    "server.rip",
    "server.html",
    "certs/",
    "bin/",
    "tests/",
    "docs/",
    "README.md"
  ]
}
