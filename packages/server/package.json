{
  "name": "@rip-lang/server",
  "version": "1.4.16",
  "description": "Bun-native content server: static sites, apps, HTTP proxy, and TCP/TLS passthrough",
  "type": "module",
  "main": "api.rip",
  "exports": {
    ".": "./api.rip",
    "./middleware": "./middleware.rip",
    "./server": "./server.rip"
  },
  "bin": {
    "rip-server": "./bin/rip-server"
  },
  "scripts": {
    "build": "rip -c server.rip",
    "test": "rip tests/runner.rip"
  },
  "keywords": [
    "server",
    "content-server",
    "static-serving",
    "app-server",
    "reverse-proxy",
    "tls-passthrough",
    "routing",
    "middleware",
    "validation",
    "hot-reload",
    "multi-worker",
    "https",
    "tls",
    "acme",
    "bun",
    "rip",
    "rip-lang"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/shreeve/rip-lang.git",
    "directory": "packages/server"
  },
  "homepage": "https://github.com/shreeve/rip-lang/tree/main/packages/server#readme",
  "bugs": {
    "url": "https://github.com/shreeve/rip-lang/issues"
  },
  "author": "Steve Shreeve <steve.shreeve@gmail.com>",
  "license": "MIT",
  "dependencies": {
    "rip-lang": ">=3.13.135"
  },
  "files": [
    "api.rip",
    "browse.rip",
    "middleware.rip",
    "server.rip",
    "server.html",
    "acme/",
    "bin/",
    "certs/",
    "control/",
    "serving/",
    "streams/",
    "tests/",
    "API.md",
    "CONFIG.md",
    "README.md"
  ]
}
