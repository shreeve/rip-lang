# ==============================================================================
# fuzz.rip — robustness fuzzing of the hand-rolled untrusted-byte parsers
# ==============================================================================
#
# These two functions parse attacker-controlled input directly:
#
#   parseSNI        — raw TLS ClientHello bytes off the wire (streams/)
#   validateRequest — the front-door request guard (serving/security.rip)
#
# On a memory-safe runtime the worst a parser bug can do is throw or hang —
# both turn into a worker crash / DoS. This harness asserts the invariants
# that prevent that:
#
#   1. Never throws on ANY input (always returns a verdict object).
#   2. Always terminates (no non-advancing loop → no hang).
#   3. Valid inputs still parse correctly (no over-eager rejection).
#
# Fuzzing is seeded (mulberry32) so any failure is reproducible: the case
# that breaks an invariant is printed as hex for a direct repro.
# ==============================================================================

import { test, ok, eq } from './runner.rip'
import { parseSNI } from '../streams/clienthello.rip'
import { validateRequest } from '../serving/security.rip'

# --- Seeded PRNG (mulberry32) — deterministic, reproducible runs ---

makeRng = (seed) ->
  state = seed >>> 0
  ->
    state = (state + 0x6D2B79F5) | 0
    t = Math.imul(state ^ (state >>> 15), 1 | state)
    t = (t + Math.imul(t ^ (t >>> 7), 61 | t)) ^ t
    ((t ^ (t >>> 14)) >>> 0) / 4294967296

randBytes = (rng, n) ->
  out = new Uint8Array(n)
  out[i] = Math.floor(rng() * 256) for i in [0...n]
  out

toHex = (buf) ->
  Array.from(buf).map((b) -> b.toString(16).padStart(2, '0')).join('')

# --- Valid ClientHello builder (so we can assert positive parsing too) ---

buildClientHello = (host) ->
  name          = Array.from(new TextEncoder().encode(host))
  nameLen       = name.length
  entry         = [0x00, (nameLen >> 8) & 0xff, nameLen & 0xff, ...name]   # host_name entry
  listLen       = entry.length
  extData       = [(listLen >> 8) & 0xff, listLen & 0xff, ...entry]        # server_name_list
  extLen        = extData.length
  ext           = [0x00, 0x00, (extLen >> 8) & 0xff, extLen & 0xff, ...extData]  # ext type 0 + len
  extsLen       = ext.length
  extsBlock     = [(extsLen >> 8) & 0xff, extsLen & 0xff, ...ext]
  clientVersion = [0x03, 0x03]
  random        = (0 for _ in [0...32])
  sessionId     = [0x00]
  ciphers       = [0x00, 0x02, 0x00, 0x2f]
  compression   = [0x01, 0x00]
  helloBody     = [...clientVersion, ...random, ...sessionId, ...ciphers, ...compression, ...extsBlock]
  helloLen      = helloBody.length
  handshake     = [0x01, (helloLen >> 16) & 0xff, (helloLen >> 8) & 0xff, helloLen & 0xff, ...helloBody]
  recordLen     = handshake.length
  record        = [0x16, 0x03, 0x01, (recordLen >> 8) & 0xff, recordLen & 0xff, ...handshake]
  Uint8Array.from(record)

# Many zero-length extensions — stresses the extension loop for non-advance.
buildClientHelloManyExts = (count) ->
  exts = []
  exts.push(0x00, 0x33, 0x00, 0x00) for _ in [0...count]   # type 0x0033, len 0
  extsLen       = exts.length
  extsBlock     = [(extsLen >> 8) & 0xff, extsLen & 0xff, ...exts]
  clientVersion = [0x03, 0x03]
  random        = (0 for _ in [0...32])
  sessionId     = [0x00]
  ciphers       = [0x00, 0x02, 0x00, 0x2f]
  compression   = [0x01, 0x00]
  helloBody     = [...clientVersion, ...random, ...sessionId, ...ciphers, ...compression, ...extsBlock]
  helloLen      = helloBody.length
  handshake     = [0x01, (helloLen >> 16) & 0xff, (helloLen >> 8) & 0xff, helloLen & 0xff, ...helloBody]
  recordLen     = handshake.length
  record        = [0x16, 0x03, 0x01, (recordLen >> 8) & 0xff, recordLen & 0xff, ...handshake]
  Uint8Array.from(record)

isVerdict = (r) ->
  r? and typeof r is 'object' and typeof r.ok is 'boolean'

# ==============================================================================
# parseSNI
# ==============================================================================

test "parseSNI extracts SNI from a well-formed ClientHello", ->
  r = parseSNI(buildClientHello('Example.COM'))
  eq r.ok, true
  eq r.sni, 'example.com'     # parser lowercases

test "parseSNI: every truncation of a valid hello returns a verdict (never throws)", ->
  full = buildClientHello('host.example.com')
  for n in [0...full.length]
    prefix = full.subarray(0, n)
    r = try parseSNI(prefix) catch e then { __threw: e.message }
    ok isVerdict(r), "threw or non-verdict at prefix len #{n}: #{JSON.stringify(r)}"
    ok r.ok is false, "short prefix len #{n} should not claim success"

test "parseSNI: 25k random byte arrays never throw and always return a verdict", ->
  rng = makeRng(0xC0FFEE)
  for i in [0...25000]
    n   = Math.floor(rng() * 64)
    buf = randBytes(rng, n)
    r   = try parseSNI(buf) catch e then { __threw: e.message, hex: toHex(buf) }
    ok isVerdict(r), "parseSNI misbehaved on input: #{JSON.stringify(r)}"

test "parseSNI: byte-flip mutations of a valid hello never throw", ->
  rng  = makeRng(0x1234)
  base = buildClientHello('mutate.example.com')
  for i in [0...4000]
    buf = Uint8Array.from(base)
    flips = 1 + Math.floor(rng() * 5)
    for _ in [0...flips]
      buf[Math.floor(rng() * buf.length)] = Math.floor(rng() * 256)
    r = try parseSNI(buf) catch e then { __threw: e.message, hex: toHex(buf) }
    ok isVerdict(r), "mutation threw: #{JSON.stringify(r)}"

test "parseSNI: terminates fast on a hello packed with empty extensions (no hang)", ->
  # Each loop iteration must advance the cursor by >= 4 bytes; a regression
  # that fails to advance would hang here. Budget is generous to avoid CI flake.
  buf = buildClientHelloManyExts(3000)
  t0  = performance.now()
  r   = parseSNI(buf)
  dt  = performance.now() - t0
  ok isVerdict(r), 'verdict expected'
  ok dt < 250, "parseSNI took #{dt.toFixed(1)}ms on 3000 empty extensions (possible non-advance)"

# ==============================================================================
# validateRequest
# ==============================================================================

isReqVerdict = (r) ->
  r? and typeof r is 'object' and typeof r.valid is 'boolean'

PATH_CHARS = ['a', 'b', '/', '.', '%', '0', '2', 'e', '-', '_', ':', '@', '?', '&', '=', '\\', '+']

randPath = (rng, n) ->
  out = ''
  out += PATH_CHARS[Math.floor(rng() * PATH_CHARS.length)] for _ in [0...n]
  out

test "validateRequest: 8k random URLs never throw and always return a verdict", ->
  rng = makeRng(0xBEEF)
  built = 0
  for i in [0...8000]
    seg = randPath(rng, Math.floor(rng() * 48))
    url = "http://host.test/#{seg}?#{randPath(rng, Math.floor(rng() * 16))}"
    req = try new Request(url) catch then null   # invalid URL = Request/URL layer, not ours
    continue unless req
    built++
    r = try validateRequest(req) catch e then { __threw: e.message, url }
    ok isReqVerdict(r), "validateRequest misbehaved: #{JSON.stringify(r)}"
  ok built > 0, 'expected at least some constructible URLs'

test "validateRequest: random header combos never throw", ->
  rng = makeRng(0x5151)
  for i in [0...3000]
    headers = {}
    headers['content-length']   = String(Math.floor(rng() * 99999)) if rng() < 0.5
    headers['transfer-encoding'] = 'chunked'                          if rng() < 0.5
    headers['host'] = if rng() < 0.5 then 'a.com,b.com' else 'a.com'
    req = try new Request('http://host.test/x', { headers }) catch then null
    continue unless req
    r = try validateRequest(req) catch e then { __threw: e.message }
    ok isReqVerdict(r), "validateRequest threw on headers: #{JSON.stringify(r)}"
