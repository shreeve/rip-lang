import { test, eq, ok } from './runner.rip'
import { normalizeConfig } from '../serving/config.rip'

getErrors = (fn) ->
  try
    fn()
    []
  catch e
    e.validationErrors or []

test "local app creates site routes with correct host", ->
  config = normalizeConfig({
    sites:
      dev: 'dev.example.com'
    apps:
      web: 'dev'
  }, '/home/shreeve')
  eq config.kind, 'serve'
  ok config.sites['dev.example.com']
  eq config.sites['dev.example.com'].host, 'dev.example.com'
  eq config.sites['dev.example.com'].routes.length, 1
  eq config.sites['dev.example.com'].routes[0].app, 'web'

test "multiple sites on one app", ->
  config = normalizeConfig({
    sites:
      dev: 'local.example.com'
      prod: 'example.com'
      www: 'www.example.com'
    apps:
      web: 'dev prod www'
  }, '/home/shreeve')
  eq Object.keys(config.sites).length, 3
  eq config.sites['local.example.com'].routes[0].app, 'web'
  eq config.sites['example.com'].routes[0].app, 'web'
  eq config.sites['www.example.com'].routes[0].app, 'web'

test "http proxy creates proxy entry and websocket route", ->
  config = normalizeConfig({
    sites:
      incus: 'incus.example.com'
    apps:
      incus: 'https://10.0.0.50:8443 incus'
  }, '/home/shreeve')
  route = config.sites['incus.example.com'].routes[0]
  eq route.proxy, 'proxy-incus'
  eq route.websocket, true
  eq route.app, null
  proxy = config.proxies['proxy-incus']
  ok proxy
  eq proxy.kind, 'http'

test "tcp proxy creates stream entries", ->
  config = normalizeConfig({
    sites:
      db: 'db.example.com'
    apps:
      mysql: 'tcp://10.0.0.50:3306 db'
  }, '/home/shreeve')
  eq config.sites['db.example.com'], undefined
  ok config.streamUpstreams['tcp-mysql']
  eq config.streams.length, 1
  eq config.streams[0].proxy, 'tcp-mysql'
  eq config.streams[0].sni[0], 'db.example.com'

test "server settings and version are optional", ->
  config = normalizeConfig({
    sites:
      dev: 'example.com'
    apps:
      web: 'dev'
  }, '/home/shreeve')
  eq config.version, 2
  ok config.server

test "hostnames are lowercased", ->
  config = normalizeConfig({
    sites:
      dev: 'Dev.EXAMPLE.com'
    apps:
      web: 'dev'
  }, '/home/shreeve')
  ok config.sites['dev.example.com']

test "mixed app kinds in one config", ->
  config = normalizeConfig({
    sites:
      dev: 'local.example.com'
      prod: 'example.com'
      incus: 'incus.example.com'
      db: 'db.example.com'
    apps:
      web: 'dev prod'
      incus: 'https://10.0.0.50:8443 incus'
      mysql: 'tcp://10.0.0.50:3306 db'
  }, '/home/shreeve')
  eq Object.keys(config.sites).length, 3
  eq config.sites['local.example.com'].routes[0].app, 'web'
  eq config.sites['example.com'].routes[0].app, 'web'
  eq config.sites['incus.example.com'].routes[0].proxy, 'proxy-incus'
  eq config.streams.length, 1
  eq config.streams[0].sni[0], 'db.example.com'

test "rejects multiple apps on same site", ->
  errors = getErrors ->
    normalizeConfig({
      sites:
        dev: 'example.com'
      apps:
        a: 'dev'
        b: 'dev'
    }, '/home/shreeve')
  ok errors.some((err) -> err.code is 'E_SITE_MULTI_BIND')

test "rejects app with multiple targets", ->
  errors = getErrors ->
    normalizeConfig({
      sites:
        dev: 'example.com'
      apps:
        web: './a ./b dev'
    }, '/home/shreeve')
  ok errors.some((err) -> err.code is 'E_APP_MULTI_TARGET')
