import { test, eq, ok } from './runner.rip'
import { compileRouteTable, matchRoute, describeRoute } from '../serving/router.rip'

test "compileRouteTable keeps global route order", ->
  table = compileRouteTable([
    { id: 'one', path: '/a', proxy: 'app' }
    { id: 'two', path: '/b', proxy: 'app' }
  ])
  eq table.routes.length, 2
  eq table.routes[0].order, 0
  eq table.routes[1].order, 1

test "compileRouteTable merges site routes with inherited host", ->
  table = compileRouteTable([],
    admin.example.com:
      routes: [{ path: '/*', app: 'admin' }]
  )
  eq table.routes.length, 1
  eq table.routes[0].host, 'admin.example.com'

test "matchRoute prefers exact host over catchall", ->
  table = compileRouteTable([
    { path: '/*', proxy: 'fallback' }
    { host: 'api.example.com', path: '/*', proxy: 'api' }
  ])
  eq matchRoute(table, 'api.example.com', '/users').proxy, 'api'

test "matchRoute prefers wildcard host over catchall", ->
  table = compileRouteTable([
    { path: '/*', proxy: 'fallback' }
    { host: '*.example.com', path: '/*', proxy: 'wild' }
  ])
  eq matchRoute(table, 'api.example.com', '/users').proxy, 'wild'

test "matchRoute does not let wildcard span multiple labels", ->
  table = compileRouteTable([
    { host: '*.example.com', path: '/*', proxy: 'wild' }
    { path: '/*', proxy: 'fallback' }
  ])
  eq matchRoute(table, 'a.b.example.com', '/users').proxy, 'fallback'

test "matchRoute prefers exact path over prefix", ->
  table = compileRouteTable([
    { path: '/api/*', proxy: 'api' }
    { path: '/api/users', proxy: 'users' }
  ])
  eq matchRoute(table, 'example.com', '/api/users').proxy, 'users'

test "matchRoute prefers longer prefix", ->
  table = compileRouteTable([
    { path: '/api/*', proxy: 'api' }
    { path: '/api/admin/*', proxy: 'admin' }
  ])
  eq matchRoute(table, 'example.com', '/api/admin/users').proxy, 'admin'

test "matchRoute uses lower priority number before order", ->
  table = compileRouteTable([
    { path: '/api/*', proxy: 'one', priority: 10 }
    { path: '/api/*', proxy: 'two', priority: 5 }
  ])
  eq matchRoute(table, 'example.com', '/api/x').proxy, 'two'

test "matchRoute filters by method", ->
  table = compileRouteTable([
    { path: '/submit', proxy: 'read', methods: ['GET'] }
    { path: '/submit', proxy: 'write', methods: ['POST'] }
  ])
  eq matchRoute(table, 'example.com', '/submit', 'POST').proxy, 'write'

test "matchRoute returns null when nothing matches", ->
  table = compileRouteTable([
    { host: 'api.example.com', path: '/api/*', proxy: 'api' }
  ])
  eq matchRoute(table, 'example.com', '/api/x'), null

test "describeRoute summarizes action", ->
  table = compileRouteTable([
    { host: 'api.example.com', path: '/api/*', proxy: 'api' }
  ])
  summary = describeRoute(matchRoute(table, 'api.example.com', '/api/x'))
  ok summary.includes('proxy:api')

test "compiled route preserves root field", ->
  table = compileRouteTable([], {
    '*.example.com':
      routes: [
        { path: '/*', static: '.', root: '/mnt/site', spa: true }
      ]
  })
  matched = matchRoute(table, 'app.example.com', '/index.html')
  eq matched.root, '/mnt/site'

test "matchRoute resolves path-mounted apps on same host", ->
  table = compileRouteTable([], {
    'relay.example.com':
      routes: [
        { id: 'mqtt-proxy', path: '/mqtt/*', proxy: 'proxy-mqtt' }
        { id: 'repl-static', path: '/repl/*', static: '.', root: '/var/www/relay-repl', browse: true }
      ]
  })
  eq matchRoute(table, 'relay.example.com', '/mqtt').proxy, 'proxy-mqtt'
  eq matchRoute(table, 'relay.example.com', '/mqtt/foo/bar').proxy, 'proxy-mqtt'
  eq matchRoute(table, 'relay.example.com', '/repl/').root, '/var/www/relay-repl'
  eq matchRoute(table, 'relay.example.com', '/repl/index.html').root, '/var/www/relay-repl'

test "matchRoute accepts bare mount path, trailing slash, and nested paths", ->
  table = compileRouteTable([], {
    'relay.example.com':
      routes: [
        { id: 'mqtt', path: '/mqtt/*', proxy: 'proxy-mqtt' }
      ]
  })
  eq matchRoute(table, 'relay.example.com', '/mqtt').proxy, 'proxy-mqtt'
  eq matchRoute(table, 'relay.example.com', '/mqtt/').proxy, 'proxy-mqtt'
  eq matchRoute(table, 'relay.example.com', '/mqtt/foo/bar').proxy, 'proxy-mqtt'

test "matchRoute respects segment boundary on mount path", ->
  table = compileRouteTable([], {
    'relay.example.com':
      routes: [
        { id: 'mqtt', path: '/mqtt/*', proxy: 'proxy-mqtt' }
      ]
  })
  # '/mqttfake' must NOT match '/mqtt/*' — segment boundary protection
  eq matchRoute(table, 'relay.example.com', '/mqttfake'), null
  eq matchRoute(table, 'relay.example.com', '/mqtt-abc'), null

test "matchRoute prefers subpath mount over root on same host", ->
  table = compileRouteTable([], {
    'relay.example.com':
      routes: [
        { id: 'root', path: '/*', static: '.', root: '/var/www/site' }
        { id: 'mqtt', path: '/mqtt/*', proxy: 'proxy-mqtt' }
      ]
  })
  eq matchRoute(table, 'relay.example.com', '/mqtt/foo').proxy, 'proxy-mqtt'
  eq matchRoute(table, 'relay.example.com', '/index.html').static, '.'

test "compiled route preserves spa field", ->
  table = compileRouteTable([], {
    '*.example.com':
      routes: [
        { path: '/*', static: '.', root: '/mnt/site', spa: true }
      ]
  })
  matched = matchRoute(table, 'app.example.com', '/index.html')
  eq matched.spa, true
