# test-registry.rip — serving/registry, scheduler, and queue tests

import { test, eq, ok } from './runner.rip'
import { createAppRegistry, registerApp, resolveHost, getAppState, removeApp } from '../serving/registry.rip'
import { isCurrentVersion, getNextAvailableSocket, releaseWorker, isRetryableBusy, maybeCloneForRetry, drainQueueOnce } from '../serving/queue.rip'

# --- Registry ---

test "createAppRegistry returns empty maps", ->
  r = createAppRegistry()
  eq r.apps.size, 0
  eq r.hostIndex.size, 0

test "registerApp adds app and indexes hosts", ->
  r = createAppRegistry()
  registerApp(r, 'myapp', { hosts: ['example.com', 'www.example.com'] })
  eq r.apps.size, 1
  eq r.hostIndex.size, 2
  eq resolveHost(r, 'example.com'), 'myapp'
  eq resolveHost(r, 'www.example.com'), 'myapp'

test "resolveHost is case-insensitive", ->
  r = createAppRegistry()
  registerApp(r, 'app1', { hosts: ['Example.COM'] })
  eq resolveHost(r, 'example.com'), 'app1'
  eq resolveHost(r, 'EXAMPLE.COM'), 'app1'

test "resolveHost returns null for unknown host", ->
  r = createAppRegistry()
  eq resolveHost(r, 'unknown.com'), null

test "resolveHost matches wildcard host", ->
  r = createAppRegistry()
  registerApp(r, 'wild', { hosts: ['*.example.com'] })
  eq resolveHost(r, 'api.example.com'), 'wild'

test "resolveHost wildcard does not span multiple labels", ->
  r = createAppRegistry()
  registerApp(r, 'wild', { hosts: ['*.example.com'] })
  eq resolveHost(r, 'a.b.example.com'), null

test "resolveHost falls back to catchall host", ->
  r = createAppRegistry()
  registerApp(r, 'catchall', { hosts: ['*'] })
  eq resolveHost(r, 'unknown.com'), 'catchall'

test "resolveHost prefers exact host over wildcard", ->
  r = createAppRegistry()
  registerApp(r, 'wild', { hosts: ['*.example.com'] })
  registerApp(r, 'exact', { hosts: ['api.example.com'] })
  eq resolveHost(r, 'api.example.com'), 'exact'

test "getAppState returns app or null", ->
  r = createAppRegistry()
  registerApp(r, 'app1', { hosts: [] })
  ok getAppState(r, 'app1')
  eq getAppState(r, 'nope'), null

test "removeApp cleans up hosts and app", ->
  r = createAppRegistry()
  registerApp(r, 'app1', { hosts: ['a.com', 'b.com'] })
  removeApp(r, 'app1')
  eq r.apps.size, 0
  eq r.hostIndex.size, 0
  eq resolveHost(r, 'a.com'), null

test "removeApp cleans wildcard entries", ->
  r = createAppRegistry()
  registerApp(r, 'wild', { hosts: ['*.example.com'] })
  removeApp(r, 'wild')
  eq resolveHost(r, 'api.example.com'), null

test "AppState has correct defaults", ->
  r = createAppRegistry()
  state = registerApp(r, 'app1', { hosts: ['h.com'] })
  eq state.sockets.length, 0
  eq state.inflightTotal, 0
  eq state.maxQueue, 512
  eq state.queueTimeoutMs, 30000

# --- Scheduler ---

test "getNextAvailableSocket returns worker with 0 inflight", ->
  workers = [{ socket: '/a', inflight: 0, version: 1, workerId: 0 }]
  sock = getNextAvailableSocket(workers, null)
  eq sock.socket, '/a'

test "getNextAvailableSocket skips inflight workers", ->
  workers = [
    { socket: '/a', inflight: 1, version: 1, workerId: 0 }
    { socket: '/b', inflight: 0, version: 1, workerId: 1 }
  ]
  sock = getNextAvailableSocket(workers, null)
  eq sock.socket, '/b'

test "getNextAvailableSocket returns null when all busy", ->
  workers = [{ socket: '/a', inflight: 1, version: 1, workerId: 0 }]
  sock = getNextAvailableSocket(workers, null)
  eq sock, null

test "getNextAvailableSocket increments inflight on checkout (K=1)", ->
  w = { socket: '/a', inflight: 0, version: 1, workerId: 0 }
  workers = [w]
  sock = getNextAvailableSocket(workers, null)
  eq sock, w
  eq w.inflight, 1
  # Worker is full at K=1, so pool drops to empty
  eq workers.length, 0

test "getNextAvailableSocket allows multiple checkouts up to concurrency (K=3)", ->
  w = { socket: '/a', inflight: 0, version: 1, workerId: 0 }
  workers = [w]
  s1 = getNextAvailableSocket(workers, null, 3)
  eq s1, w
  eq w.inflight, 1
  ok workers.length is 1     # still has capacity, re-added
  s2 = getNextAvailableSocket(workers, null, 3)
  eq s2, w
  eq w.inflight, 2
  ok workers.length is 1
  s3 = getNextAvailableSocket(workers, null, 3)
  eq s3, w
  eq w.inflight, 3
  eq workers.length, 0       # full, removed from pool
  s4 = getNextAvailableSocket(workers, null, 3)
  eq s4, null

test "getNextAvailableSocket prefers a worker with capacity over a full one (K=2)", ->
  full = { socket: '/full', inflight: 2, version: 1, workerId: 0 }
  open = { socket: '/open', inflight: 0, version: 1, workerId: 1 }
  workers = [full, open]
  sock = getNextAvailableSocket(workers, null, 2)
  eq sock, open
  eq open.inflight, 1

test "checkout/release accounting is balanced under retry-same-worker (K=4)", ->
  # Simulates the dispatcher's retry path: if forward returns 503-busy
  # while the worker still has capacity, the scheduler can hand back the
  # same worker. The dispatcher must release the spurious bump so the
  # accounting balances.
  w = { socket: '/a', inflight: 0, version: 1, workerId: 0 }
  available = [w]
  sockets = [w]
  s1 = getNextAvailableSocket(available, null, 4)   # initial: 0->1
  eq w.inflight, 1
  retry = getNextAvailableSocket(available, null, 4) # retry: 1->2 (same worker)
  eq retry, w
  eq w.inflight, 2
  releaseWorker(sockets, available, null, retry, 4) # undo the spurious bump
  eq w.inflight, 1
  releaseWorker(sockets, available, null, s1, 4)    # final release of original
  eq w.inflight, 0

test "checkout/release accounting is balanced under retry-different-worker (K=2)", ->
  # Force "different worker" case by saturating the first one before retry.
  a = { socket: '/a', inflight: 0, version: 1, workerId: 0 }
  b = { socket: '/b', inflight: 0, version: 1, workerId: 1 }
  available = [a, b]
  sockets = [a, b]
  # Saturate a so the scheduler has to pick b. LIFO: pops b first; for
  # this test we want the original to be a, so checkout twice on a until
  # full, then verify retry routes to b.
  s1 = getNextAvailableSocket(available, null, 2)        # b (LIFO), b.inflight=1
  s2 = getNextAvailableSocket(available, null, 2)        # b again, b.inflight=2
  eq s1, s2
  eq b.inflight, 2
  # b is now full, removed from pool. Next checkout returns a.
  retry = getNextAvailableSocket(available, null, 2)
  eq retry, a
  ok retry isnt s1
  releaseWorker(sockets, available, null, s1, 2)         # b.inflight=1
  releaseWorker(sockets, available, null, s2, 2)         # b.inflight=0
  releaseWorker(sockets, available, null, retry, 2)      # a.inflight=0
  eq a.inflight, 0
  eq b.inflight, 0

test "isCurrentVersion with no version tracking", ->
  ok isCurrentVersion(null, { version: 1 })
  ok isCurrentVersion(null, { version: null })

test "releaseWorker resets inflight and re-adds to pool", ->
  w = { socket: '/a', inflight: 1, version: 1, workerId: 0 }
  sockets = [w]
  available = []
  releaseWorker(sockets, available, null, w)
  eq w.inflight, 0
  eq available.length, 1

test "releaseWorker decrements without re-adding when still has capacity (K=4)", ->
  w = { socket: '/a', inflight: 2, version: 1, workerId: 0 }
  sockets = [w]
  available = [w]   # already in pool — has capacity (2 < 4)
  releaseWorker(sockets, available, null, w, 4)
  eq w.inflight, 1
  eq available.length, 1   # not double-added

test "releaseWorker re-adds when transitioning from full to has-capacity (K=4)", ->
  w = { socket: '/a', inflight: 4, version: 1, workerId: 0 }
  sockets = [w]
  available = []   # was full → not in pool
  releaseWorker(sockets, available, null, w, 4)
  eq w.inflight, 3
  eq available.length, 1   # re-added because we transitioned full → open

test "releaseWorker is idempotent against duplicate adds", ->
  w = { socket: '/a', inflight: 4, version: 1, workerId: 0 }
  sockets = [w]
  available = [w]   # weird edge: somehow already present despite being "full"
  releaseWorker(sockets, available, null, w, 4)
  eq w.inflight, 3
  eq available.length, 1   # still only one entry

test "isRetryableBusy matches 503 + Rip-Worker-Busy", ->
  headers = new Headers({ 'Rip-Worker-Busy': '1' })
  res = { status: 503, headers }
  ok isRetryableBusy(res)

test "isRetryableBusy matches 503 + Rip-Worker-Draining", ->
  headers = new Headers({ 'Rip-Worker-Draining': '1' })
  res = { status: 503, headers }
  ok isRetryableBusy(res)

test "isRetryableBusy false for 503 without busy/draining header", ->
  headers = new Headers()
  res = { status: 503, headers }
  eq isRetryableBusy(res), false

test "isRetryableBusy false for non-503", ->
  headers = new Headers({ 'Rip-Worker-Busy': '1' })
  res = { status: 200, headers }
  eq isRetryableBusy(res), false

test "maybeCloneForRetry returns null for GET (bodyless, no clone needed)", ->
  req = { method: 'GET', headers: new Headers() }
  eq maybeCloneForRetry(req), null

test "maybeCloneForRetry returns null when content-length is missing", ->
  req = { method: 'POST', headers: new Headers(), clone: -> 'CLONE' }
  eq maybeCloneForRetry(req), null

test "maybeCloneForRetry clones POST with small content-length", ->
  req =
    method: 'POST'
    headers: new Headers({ 'content-length': '256' })
    clone: -> 'CLONE'
  eq maybeCloneForRetry(req), 'CLONE'

test "maybeCloneForRetry returns null for oversized body", ->
  req =
    method: 'POST'
    headers: new Headers({ 'content-length': String(20 * 1024 * 1024) })
    clone: -> 'CLONE'
  eq maybeCloneForRetry(req), null

# --- Queue ---

test "drainQueueOnce processes one job from queue", ->
  processed = []
  queue = [{ req: 'r1', resolve: (->), enqueuedAt: Date.now() }]
  inflightOut = drainQueueOnce(
    0, 2, (-> 1),
    (-> queue.shift()),
    (-> false),
    (->),
    (-> { socket: '/a', inflight: 0 }),
    ((job, worker) -> processed.push(job.req))
  )
  eq processed.length, 1
  eq inflightOut, 1

test "drainQueueOnce resolves timed-out job", ->
  resolved = []
  queue = [{ req: 'r1', resolve: ((r) -> resolved.push('timeout')), enqueuedAt: 0 }]
  drainQueueOnce(
    0, 2, (-> 1),
    (-> queue.shift()),
    (-> true),
    (-> 'timeout-response'),
    (-> null),
    (->)
  )
  eq resolved[0], 'timeout'
