import { test, eq, ok } from './runner.rip'
import { dirname, join } from 'node:path'
import { coerceInt, computeSocketPrefix, parseFlags } from '../control/cli.rip'
import { createServingRuntime, createReloadHistoryEntry } from '../serving/runtime.rip'

serverDir = dirname(import.meta.dir)
defaultRip = join(serverDir, 'browse.rip')

test "control cli helpers load and parse basic flags", ->
  flags = parseFlags(['bun', 'server', '--https-port=9445', '--file=./serve.rip', defaultRip])
  eq coerceInt('42', 0), 42
  eq flags.httpsPort, 9445
  ok flags.configPath.endsWith('serve.rip')

test "control cli uses bare app token as true app name override", ->
  flags = parseFlags(['bun', 'server', 'ola'])
  eq flags.appName, 'ola'
  eq flags.appAliases[0], 'ola'
  eq flags.socketPrefix, 'rip_ola'

  socketPrefix = computeSocketPrefix(
    ['bun', 'server', 'ola'],
    (appTok) -> { appName: appTok }
    -> false
    -> false
    (_, tok) -> tok
    -> '/tmp'
  )
  eq socketPrefix, 'rip_ola'

test "control cli supports explicit path with custom app name", ->
  flags = parseFlags(['bun', 'server', "#{defaultRip}@ola"])
  eq flags.appName, 'ola'
  eq flags.appAliases[0], 'ola'
  eq flags.socketPrefix, 'rip_ola'

test "workerConcurrency defaults to 1 (preserves historical behavior)", ->
  flags = parseFlags(['bun', 'server', defaultRip])
  eq flags.workerConcurrency, 1

test "workerConcurrency parses c:N positional", ->
  flags = parseFlags(['bun', 'server', defaultRip, 'c:8'])
  eq flags.workerConcurrency, 8

test "workerConcurrency parses --worker-concurrency=N long form", ->
  flags = parseFlags(['bun', 'server', defaultRip, '--worker-concurrency=4'])
  eq flags.workerConcurrency, 4

test "workerConcurrency floors below 1 to 1", ->
  flags = parseFlags(['bun', 'server', defaultRip, 'c:0'])
  eq flags.workerConcurrency, 1

test "rateLimit defaults to 300 (public-internet-safe)", ->
  flags = parseFlags(['bun', 'server', defaultRip])
  eq flags.rateLimit, 300
  eq flags.rateLimitWindow, 60000

test "rateLimit explicit 0 still disables limiting", ->
  flags = parseFlags(['bun', 'server', defaultRip, '--rate-limit=0'])
  eq flags.rateLimit, 0

test "rateLimit explicit positive value passes through", ->
  flags = parseFlags(['bun', 'server', defaultRip, '--rate-limit=60'])
  eq flags.rateLimit, 60

test "idleTimeoutSec defaults to 30s", ->
  flags = parseFlags(['bun', 'server', defaultRip])
  eq flags.idleTimeoutSec, 30

test "idleTimeoutSec accepts override", ->
  flags = parseFlags(['bun', 'server', defaultRip, '--idle-timeout-sec=15'])
  eq flags.idleTimeoutSec, 15

test "idleTimeoutSec floors negative input to 0", ->
  flags = parseFlags(['bun', 'server', defaultRip, '--idle-timeout-sec=-5'])
  eq flags.idleTimeoutSec, 0

test "maxBodyMb defaults to 10MB", ->
  flags = parseFlags(['bun', 'server', defaultRip])
  eq flags.maxBodyMb, 10

test "maxBodyMb accepts override", ->
  flags = parseFlags(['bun', 'server', defaultRip, '--max-body-mb=50'])
  eq flags.maxBodyMb, 50

test "maxBodyMb floors below 1 to 1 (cap can't be zero)", ->
  flags = parseFlags(['bun', 'server', defaultRip, '--max-body-mb=0'])
  eq flags.maxBodyMb, 1

test "serving runtime helpers load and create summary entries", ->
  runtime = createServingRuntime()
  entry = createReloadHistoryEntry('reload-1', 'test', null, 1, 'applied')
  eq runtime.configInfo.kind, 'none'
  eq entry.id, 'reload-1'
  eq entry.result, 'applied'
