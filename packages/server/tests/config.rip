import { test, eq, ok } from './runner.rip'
import { normalizeConfig, summarizeConfig, formatConfigErrors, checkConfigFile } from '../serving/config.rip'
import { dirname, join } from 'node:path'
import { writeFileSync, mkdirSync, rmSync, mkdtempSync } from 'node:fs'
import { tmpdir } from 'node:os'

FIXTURE_DIR = dirname(import.meta.path) + '/fixtures'

getErrors = (fn) ->
  try
    fn()
    []
  catch e
    e.validationErrors or []

test "normalizeConfig accepts local app with sites", ->
  normalized = normalizeConfig(
    sites:
      dev: 'local.example.com'
      prod: 'example.com'
    apps:
      web: 'dev prod'
  , FIXTURE_DIR)
  eq normalized.kind, 'serve'
  eq Object.keys(normalized.sites).length, 2
  eq normalized.sites['local.example.com'].routes[0].app, 'web'
  eq normalized.sites['example.com'].routes[0].app, 'web'

test "normalizeConfig generates catch-all route paths", ->
  normalized = normalizeConfig(
    sites:
      dev: 'example.com'
    apps:
      web: 'dev'
  , FIXTURE_DIR)
  eq normalized.sites['example.com'].routes[0].path, '/*'

test "normalizeConfig accepts local app at relative path", ->
  normalized = normalizeConfig(
    sites:
      dev: 'example.com'
    apps:
      patient: "#{FIXTURE_DIR} dev"
  , '/srv')
  eq normalized.sites['example.com'].routes[0].app, 'patient'
  eq normalized.apps.patient.id, 'patient'

test "normalizeConfig accepts http proxy app", ->
  normalized = normalizeConfig(
    sites:
      incus: 'incus.example.com'
    apps:
      incus: 'https://10.0.0.50:8443 incus'
  , '/srv')
  eq Object.keys(normalized.sites).length, 1
  route = normalized.sites['incus.example.com'].routes[0]
  eq route.proxy, 'proxy-incus'
  eq route.websocket, false
  eq route.path, '/*'
  ok normalized.upstreams['proxy-incus']
  eq normalized.upstreams['proxy-incus'].targets[0], 'https://10.0.0.50:8443'

test "normalizeConfig accepts tcp proxy app", ->
  normalized = normalizeConfig(
    sites:
      db: 'db.example.com'
    apps:
      mysql: 'tcp://10.0.0.50:3306 db'
  , '/srv')
  ok normalized.streamUpstreams['tcp-mysql']
  eq normalized.streams.length, 1
  eq normalized.streams[0].sni[0], 'db.example.com'
  eq normalized.streams[0].proxy, 'tcp-mysql'

test "normalizeConfig rejects empty app spec", ->
  errors = getErrors ->
    normalizeConfig(
      sites:
        dev: 'example.com'
      apps:
        web: ''
    , '/srv')
  ok errors.some((err) -> err.code is 'E_APP_EMPTY')

test "normalizeConfig rejects app with no sites", ->
  errors = getErrors ->
    normalizeConfig(
      sites:
        dev: 'example.com'
      apps:
        proxy: 'https://10.0.0.50:8443'
    , '/srv')
  ok errors.some((err) -> err.code is 'E_APP_NO_SITES')

test "normalizeConfig rejects unknown site names", ->
  errors = getErrors ->
    normalizeConfig(
      sites:
        dev: 'example.com'
      apps:
        web: 'dev missing'
    , '/srv')
  ok errors.some((err) -> err.code is 'E_APP_UNKNOWN_SITE')

test "normalizeConfig rejects duplicate site bindings", ->
  errors = getErrors ->
    normalizeConfig(
      sites:
        dev: 'example.com'
      apps:
        web: 'dev'
        api: 'dev'
    , '/srv')
  ok errors.some((err) -> err.code is 'E_SITE_MULTI_BIND')

test "normalizeConfig rejects object app specs", ->
  errors = getErrors ->
    normalizeConfig(
      sites:
        dev: 'example.com'
      apps:
        web:
          entry: './index.rip'
    , '/srv')
  ok errors.some((err) -> err.code is 'E_APP_OBJECT')

test "normalizeConfig rejects unknown top-level keys", ->
  errors = getErrors ->
    normalizeConfig(
      hosts:
        'example.com':
          root: '/mnt/site'
      apps: {}
    , '/srv')
  ok errors.some((err) -> err.code is 'E_UNKNOWN_KEY')

test "normalizeConfig rejects duplicate hostnames in sites", ->
  errors = getErrors ->
    normalizeConfig(
      sites:
        dev: 'example.com'
        prod: 'example.com'
    , '/srv')
  ok errors.some((err) -> err.code is 'E_SITE_DUPLICATE_HOST')

test "normalizeConfig rejects non-string site hostnames", ->
  errors = getErrors ->
    normalizeConfig(
      sites:
        dev: 42
    , '/srv')
  ok errors.some((err) -> err.code is 'E_SITE_HOST_TYPE')

test "normalizeConfig rejects tcp proxy without port", ->
  errors = getErrors ->
    normalizeConfig(
      sites:
        db: 'db.example.com'
      apps:
        mysql: 'tcp://10.0.0.50 db'
    , '/srv')
  ok errors.some((err) -> err.code is 'E_APP_TCP_PORT')

test "normalizeConfig accepts top-level hsts and acme", ->
  normalized = normalizeConfig(
    hsts: true
    acme: ['example.com']
    sites:
      dev: 'example.com'
    apps:
      web: 'dev'
  , FIXTURE_DIR)
  eq normalized.server.hsts, true
  eq normalized.server.acme, true
  eq normalized.server.acmeDomains[0], 'example.com'

test "normalizeConfig server block overrides top-level hsts", ->
  normalized = normalizeConfig(
    hsts: true
    server:
      hsts: false
    sites:
      dev: 'example.com'
    apps:
      web: 'dev'
  , FIXTURE_DIR)
  eq normalized.server.hsts, false

test "normalizeConfig preserves server settings", ->
  normalized = normalizeConfig(
    server:
      hsts: true
      verify:
        requireHealthyProxies: false
        minHealthyTargetsPerProxy: 2
    sites:
      dev: 'example.com'
    apps:
      web: 'dev'
  , '/srv')
  eq normalized.server.hsts, true
  eq normalized.server.verify.requireHealthyProxies, false
  eq normalized.server.verify.minHealthyTargetsPerProxy, 2

test "normalizeConfig works with minimal config", ->
  normalized = normalizeConfig({}, '/srv')
  eq normalized.kind, 'serve'
  eq Object.keys(normalized.sites).length, 0
  eq Object.keys(normalized.apps).length, 0

test "formatConfigErrors includes code path and hint", ->
  output = formatConfigErrors('serve.rip', [
    code: 'E_APP_EMPTY'
    path: 'apps.web'
    message: 'app web: empty spec'
    hint: 'Add site names.'
  ])
  ok output.includes('[E_APP_EMPTY]')
  ok output.includes('apps.web')
  ok output.includes('Hint:')

test "normalizeConfig generates static route when no index.rip", ->
  normalized = normalizeConfig(
    sites:
      dev: 'example.com'
    apps:
      zion: '/tmp/nonexistent-dir-for-test dev'
  , '/srv')
  route = normalized.sites['example.com'].routes[0]
  eq route.static, '.'
  eq route.app, null
  ok route.root.includes('nonexistent-dir-for-test')

test "normalizeConfig passes browse flag to static route", ->
  normalized = normalizeConfig(
    sites:
      dev: 'example.com'
    apps:
      zion: '/tmp/nonexistent-dir-for-test dev browse'
  , '/srv')
  route = normalized.sites['example.com'].routes[0]
  eq route.static, '.'
  eq route.browse, true
  eq route.spa, false

test "normalizeConfig passes spa flag to static route", ->
  normalized = normalizeConfig(
    sites:
      dev: 'example.com'
    apps:
      zion: '/tmp/nonexistent-dir-for-test dev spa'
  , '/srv')
  route = normalized.sites['example.com'].routes[0]
  eq route.static, '.'
  eq route.spa, true
  eq route.browse, false

test "normalizeConfig flags are not treated as site names", ->
  normalized = normalizeConfig(
    sites:
      dev: 'example.com'
    apps:
      zion: '/tmp/nonexistent-dir-for-test dev browse spa'
  , '/srv')
  eq Object.keys(normalized.sites).length, 1
  route = normalized.sites['example.com'].routes[0]
  eq route.browse, true
  eq route.spa, true

test "normalizeConfig rejects unknown non-flag non-site tokens", ->
  errors = getErrors ->
    normalizeConfig(
      sites:
        dev: 'example.com'
      apps:
        web: 'dev bogus'
    , '/srv')
  ok errors.some((err) -> err.code is 'E_APP_UNKNOWN_SITE')

test "normalizeConfig accepts site@/path mount", ->
  normalized = normalizeConfig(
    sites:
      relay: 'relay.example.com'
    apps:
      mqtt: 'http://127.0.0.1:9001 relay@/mqtt'
  , '/srv')
  routes = normalized.sites['relay.example.com'].routes
  eq routes.length, 1
  eq routes[0].path, '/mqtt/*'
  eq routes[0].mountPath, '/mqtt'
  eq routes[0].proxy, 'proxy-mqtt'

test "normalizeConfig allows multiple apps mounted at distinct paths on one site", ->
  normalized = normalizeConfig(
    sites:
      relay: 'relay.example.com'
    apps:
      mqtt: 'http://127.0.0.1:9001 relay@/mqtt'
      repl: '/tmp/nonexistent-relay-repl relay@/repl browse'
  , '/srv')
  routes = normalized.sites['relay.example.com'].routes
  eq routes.length, 2
  mqttRoute = routes.find((r) -> r.mountPath is '/mqtt')
  replRoute = routes.find((r) -> r.mountPath is '/repl')
  ok mqttRoute
  ok replRoute
  eq mqttRoute.path, '/mqtt/*'
  eq mqttRoute.proxy, 'proxy-mqtt'
  eq replRoute.path, '/repl/*'
  eq replRoute.static, '.'
  eq replRoute.browse, true

test "normalizeConfig allows root mount to coexist with subpath mount", ->
  normalized = normalizeConfig(
    sites:
      relay: 'relay.example.com'
    apps:
      root: '/tmp/nonexistent-relay-root relay'
      mqtt: 'http://127.0.0.1:9001 relay@/mqtt'
  , '/srv')
  routes = normalized.sites['relay.example.com'].routes
  eq routes.length, 2
  paths = routes.map((r) -> r.mountPath).sort()
  eq paths, ['/', '/mqtt']

test "normalizeConfig canonicalizes mount paths", ->
  for raw in ['/mqtt', '/mqtt/', '/mqtt/*']
    normalized = normalizeConfig(
      sites:
        relay: 'relay.example.com'
      apps:
        mqtt: "http://127.0.0.1:9001 relay@#{raw}"
    , '/srv')
    eq normalized.sites['relay.example.com'].routes[0].mountPath, '/mqtt'
    eq normalized.sites['relay.example.com'].routes[0].path, '/mqtt/*'

test "normalizeConfig rejects duplicate (site, path) bindings", ->
  errors = getErrors ->
    normalizeConfig(
      sites:
        relay: 'relay.example.com'
      apps:
        a: 'http://127.0.0.1:9001 relay@/mqtt'
        b: 'http://127.0.0.1:9002 relay@/mqtt'
    , '/srv')
  ok errors.some((err) -> err.code is 'E_SITE_MULTI_BIND')

test "normalizeConfig rejects tcp proxy with path mount", ->
  errors = getErrors ->
    normalizeConfig(
      sites:
        db: 'db.example.com'
      apps:
        mysql: 'tcp://10.0.0.50:3306 db@/db'
    , '/srv')
  ok errors.some((err) -> err.code is 'E_APP_TCP_PATH')

test "normalizeConfig rejects malformed mount path", ->
  for bad in ['relay@mqtt', 'relay@//mqtt', 'relay@/mqtt?x', 'relay@/mqtt#f', 'relay@']
    errors = getErrors ->
      normalizeConfig(
        sites:
          relay: 'relay.example.com'
        apps:
          bad: "http://127.0.0.1:9001 #{bad}"
      , '/srv')
    ok errors.some((err) -> err.code is 'E_APP_PATH_FORMAT'),
      "expected E_APP_PATH_FORMAT for #{JSON.stringify(bad)}, got #{JSON.stringify(errors.map((e) -> e.code))}"

test "normalizeConfig rejects missing site before @", ->
  errors = getErrors ->
    normalizeConfig(
      sites:
        relay: 'relay.example.com'
      apps:
        bad: 'http://127.0.0.1:9001 @/mqtt'
    , '/srv')
  ok errors.some((err) -> err.code is 'E_APP_SITE_MISSING')

test "normalizeConfig gives every route a site-qualified id", ->
  normalized = normalizeConfig(
    sites:
      relay: 'relay.example.com'
    apps:
      mqtt: 'http://127.0.0.1:9001 relay@/mqtt'
      repl: '/tmp/nonexistent-relay-repl relay@/repl browse'
  , '/srv')
  ids = normalized.sites['relay.example.com'].routes.map((r) -> r.id).sort()
  eq ids, ['mqtt-relay-proxy-mqtt', 'repl-relay-static-repl']

test "normalizeConfig supports wildcard host with multi-path mounts", ->
  normalized = normalizeConfig(
    sites:
      wild: '*.example.com'
    apps:
      api: 'http://127.0.0.1:9000 wild@/api'
      static: '/tmp/nonexistent-wild-static wild browse'
  , '/srv')
  routes = normalized.sites['*.example.com'].routes
  eq routes.length, 2
  mounts = routes.map((r) -> r.mountPath).sort()
  eq mounts, ['/', '/api']

test "checkConfigFile validates a multi-path serve.rip from disk", ->
  dir = mkdtempSync(join(tmpdir(), 'rip-mp-'))
  try
    writeFileSync join(dir, 'serve.rip'), """
      export default
        sites:
          relay: 'relay.example.com'

        apps:
          mqtt: 'http://127.0.0.1:9001 relay@/mqtt'
          repl: '/var/www/relay-repl relay@/repl browse'
      """
    result = checkConfigFile!(join(dir, 'serve.rip'))
    eq result.kind, 'serve'
    eq result.summary.counts.hosts, 1
    eq result.summary.counts.routes, 2
    eq result.summary.counts.apps, 0   # no local rip apps, just http proxy + static
    ok result.summary.counts.proxies >= 1
  finally
    rmSync dir, { recursive: true, force: true }

test "summarizeConfig reports canonical counts", ->
  summary = summarizeConfig('/srv/serve.rip',
    kind: 'serve'
    version: 2
    server: {}
    proxies: { 'proxy-incus': { id: 'proxy-incus', kind: 'http' } }
    apps: { web: { entry: '/srv/web/index.rip' } }
    sites:
      'example.com':
        routes: [{ path: '/*', app: 'web' }]
      'www.example.com':
        routes: [{ path: '/*', app: 'web' }]
    streams: []
  )
  eq summary.counts.proxies, 1
  eq summary.counts.apps, 1
  eq summary.counts.hosts, 2
  eq summary.counts.routes, 2
