# extracted.rip — tests for modules extracted during the server rebuild

import { test, eq, ok } from './runner.rip'
import { nowMs, isDebug, applyFlagSideEffects, stripInternalHeaders } from '../serving/logging.rip'
import { proxyRouteToUpstream, upgradeProxyWebSocket } from '../serving/proxy.rip'
import { createMetrics, buildDiagnosticsBody } from '../serving/metrics.rip'
import { proxyRealtimeToWorker, buildWebSocketHandlers, createHub } from '../serving/realtime.rip'
import { Manager } from '../control/manager.rip'
import { createUpstreamPool } from '../serving/upstream.rip'
import { createServingRuntime } from '../serving/runtime.rip'

# --- serving/logging.rip ---

test "nowMs returns a number", ->
  ok typeof nowMs() is 'number'
  ok nowMs() > 0

test "isDebug returns false by default", ->
  eq isDebug(), false

test "applyFlagSideEffects sets debug mode", ->
  applyFlagSideEffects({ debug: true })
  ok isDebug()
  applyFlagSideEffects({ debug: false })

test "stripInternalHeaders removes rip headers and preserves others", ->
  h = new Headers()
  h.set('content-type', 'text/plain')
  h.set('rip-worker-busy', '1')
  h.set('rip-worker-id', 'w-0')
  h.set('rip-no-log', '1')
  h.set('x-custom', 'keep')
  stripped = stripInternalHeaders(h)
  ok stripped.has('content-type')
  ok stripped.has('x-custom')
  eq stripped.has('rip-worker-busy'), false
  eq stripped.has('rip-worker-id'), false
  eq stripped.has('rip-no-log'), false

# --- serving/proxy.rip ---

test "proxyRouteToUpstream returns 503 when no matching proxy", ->
  pool = createUpstreamPool()
  runtime = createServingRuntime(null, pool)
  metrics = createMetrics()
  route = { proxy: 'nonexistent', timeouts: {} }
  req = new Request('http://localhost/test')
  res = await proxyRouteToUpstream(req, route, 'req-1', '127.0.0.1', runtime, metrics, {}, (->), (->))
  eq res.status, 503

test "upgradeProxyWebSocket returns 503 when no matching proxy", ->
  pool = createUpstreamPool()
  runtime = createServingRuntime(null, pool)
  route = { proxy: 'nonexistent' }
  res = upgradeProxyWebSocket(null, null, route, 'req-1', runtime)
  eq res.status, 503

# --- serving/metrics.rip ---

test "buildDiagnosticsBody returns valid JSON with expected keys", ->
  metrics = createMetrics()
  runtime = createServingRuntime()
  body = buildDiagnosticsBody
    metrics: metrics
    startedAt: Date.now()
    appRegistry: { apps: new Map(), hostIndex: new Map() }
    servingRuntime: runtime
    serverVersion: '1.0.0'
    ripVersion: '3.0.0'
    configInfo: { kind: 'none' }
    realtimeStats: { clients: 0, groups: 0 }
    hosts: []
    streamDiagnostics: {}
    multiplexer: { enabled: false }
    activeRuntime: { id: 'test', inflight: 0, wsConnections: 0 }
    retiredRuntimes: []
    activeStreamRuntime: { id: 'test', inflight: 0, listeners: [] }
    retiredStreamRuntimes: []
  parsed = JSON.parse(body)
  ok parsed.status
  ok parsed.version
  ok parsed.metrics
  ok parsed.gauges
  eq parsed.version.server, '1.0.0'

# --- serving/realtime.rip ---

test "proxyRealtimeToWorker returns null when no socket available", ->
  result = await proxyRealtimeToWorker(new Headers(), 'open', '', (-> null), (->))
  eq result, null

test "buildWebSocketHandlers returns object with websocket handlers", ->
  hub = createHub()
  serverStub =
    metrics: createMetrics()
    retainRuntimeWs: (->)
    releaseRuntimeWs: (->)
    createWsPassthrough: (->)
    releaseProxyTarget: (->)
    logEvent: (->)
    proxyRealtimeToWorker: (->)
  handlers = buildWebSocketHandlers(hub, serverStub)
  ok handlers.websocket
  ok typeof handlers.websocket.open is 'function'
  ok typeof handlers.websocket.message is 'function'
  ok typeof handlers.websocket.close is 'function'

# --- control/manager.rip ---

test "Manager constructor initializes expected state", ->
  flags = { appName: 'test', workers: 2 }
  mgr = new Manager(flags, '/tmp/server.rip')
  eq mgr.appWorkers.size, 0
  eq mgr.currentVersion, 1
  eq mgr.shuttingDown, false
  eq mgr.defaultAppId, 'test'
  ok mgr.restartBudgets instanceof Map
  ok mgr.observedGen instanceof Map
  ok mgr.appliedGen instanceof Map
  ok mgr.swapInFlight instanceof Map
  ok mgr.lastBootError instanceof Map
  ok mgr.recyclingIds instanceof Set
  eq mgr.recyclingIds.size, 0

test "Manager.markWorkerExpectedExit adds workerId to recyclingIds", ->
  mgr = new Manager({ appName: 'test' }, '/tmp/server.rip')
  mgr.markWorkerExpectedExit(7)
  ok mgr.recyclingIds.has(7)
  eq mgr.recyclingIds.size, 1

test "Manager.markWorkerExpectedExit ignores non-number ids (defensive)", ->
  mgr = new Manager({ appName: 'test' }, '/tmp/server.rip')
  mgr.markWorkerExpectedExit('not-a-number')
  mgr.markWorkerExpectedExit(null)
  mgr.markWorkerExpectedExit(undefined)
  eq mgr.recyclingIds.size, 0

test "Manager.markWorkerExpectedExit is idempotent", ->
  mgr = new Manager({ appName: 'test' }, '/tmp/server.rip')
  mgr.markWorkerExpectedExit(3)
  mgr.markWorkerExpectedExit(3)
  mgr.markWorkerExpectedExit(3)
  eq mgr.recyclingIds.size, 1
  ok mgr.recyclingIds.has(3)

test "Manager.teardown clears recyclingIds", ->
  mgr = new Manager({ appName: 'test' }, '/tmp/server.rip')
  mgr.markWorkerExpectedExit(1)
  mgr.markWorkerExpectedExit(2)
  eq mgr.recyclingIds.size, 2
  await mgr.teardown()
  eq mgr.recyclingIds.size, 0

# Full-flow test for the worker-recycle path. Uses a fake worker process
# whose `exited` promise we resolve manually, mocks spawnWorker so we
# can observe the replacement, and intercepts logEvent to verify the
# event name. This is the regression that pins "self-recycle exits get
# logged as worker_recycle, replacements spawn immediately, and the
# crash budget is NOT incremented."
test "Manager.monitor: graceful exit (recyclingIds) takes the recycle path", ->
  mgr = new Manager({ appName: 'test', socketPrefix: '/tmp/test-recycle' }, '/tmp/server.rip')
  # Stand-in for spawnWorker so we don't hit Bun.spawn or the filesystem.
  spawnedReplacements = 0
  mgr.spawnWorker = (appId, version) ->
    spawnedReplacements++
    {
      id: 99
      appId: appId
      socketPath: '/tmp/replacement.sock'
      startedAt: Date.now()
      process: { exited: new Promise(->) }
    }

  # Build a controllable fake worker. process.exited is a Promise we
  # resolve below to drive monitor's `.then` callback.
  resolveExit = null
  fakeProcess =
    exited: new Promise (r) -> resolveExit = r
    kill: ->
  worker =
    id: 42
    appId: 'test'
    socketPath: '/tmp/fake.sock'
    startedAt: Date.now()
    process: fakeProcess
  mgr.appWorkers.set('test', [worker])

  # Mark this worker as expected-to-exit (graceful self-recycle), then
  # wire up the monitor and resolve the exit promise to drive the
  # callback chain. We yield twice so both the await on `exited` and
  # the synchronous body of the `.then` handler can run.
  mgr.markWorkerExpectedExit(42)
  mgr.monitor(worker)
  resolveExit(0)
  await new Promise (r) -> setImmediate r
  await new Promise (r) -> setImmediate r

  # After the recycle: id is consumed from the set, replacement
  # spawned in the same slot immediately (no setTimeout backoff),
  # and no crash-budget entry was created for the slot.
  ok not mgr.recyclingIds.has(42), "recyclingIds should be cleared after monitor handled the exit"
  eq spawnedReplacements, 1
  eq mgr.appWorkers.get('test').length, 1
  eq mgr.appWorkers.get('test')[0].id, 99
  eq mgr.restartBudgets.size, 0
