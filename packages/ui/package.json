    "README.md"
  ],
  "homepage": "https://github.com/shreeve/rip-lang/tree/main/packages/ui#readme",
  "keywords": [
    "ui",
    "headless",
    "accessible",
    "components",
    "widgets",
    "aria",
    "wai-aria",
    "select",
    "dialog",
    "grid",
    "combobox",
    "tabs",
    "rip",
    "rip-lang"
