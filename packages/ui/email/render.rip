# ==============================================================================
# Render — instantiate a Rip component and produce email HTML + plain text
#
# Usage:
#   import { toHTML, toText, toEmail } from '@rip-lang/ui/email'
#
#   html = toHTML(MyEmail, name: "Alice")              # XHTML body string
#   text = toText(MyEmail, name: "Alice")              # plain text string
#   { html, text } = toEmail(MyEmail, name: "Alice")   # combined deliverable
#
# Wraps the shared renderer in `../shared/render.rip` with email-specific
# concerns: an XHTML 1.0 Transitional doctype and Tailwind class
# inlining (Tailwind doesn't run client-side in email).
#
# Naming: the email module disambiguates by FORMAT (toHTML / toText /
# toEmail). The html module disambiguates by SHAPE (toFragment / toPage)
# because all of its outputs are HTML. Path provides domain context, so
# `email.toHTML` doesn't repeat "Email" and `html.toPage` doesn't repeat
# "HTML".
#
# Notes:
# - rendering is synchronous and swaps in a temporary global DOM shim
# - do not add awaits or async work inside this render path; see the
#   serialization invariant in `../shared/render.rip`
# - custom Tailwind configs must be prepared ahead of time via
#   `@rip-lang/ui/tailwind.prepareConfig(config)` before sync rendering
# ==============================================================================

import { _renderComponent } from '../shared/render.rip'
import { serializeChildren, toPlainText } from './dom.rip'
import { inlineEmailTree, takeEmailTailwindRoots, configKey } from '../tailwind/tailwind.rip'

XHTML_DOCTYPE =! '<!DOCTYPE html PUBLIC "-//W3C//DTD XHTML 1.0 Transitional//EN" "http://www.w3.org/TR/xhtml1/DTD/xhtml1-transitional.dtd">'

_resolveTailwindConfig = (entries = []) ->
  configs = []
  for entry in entries
    continue unless entry?.config?
    configs.push(entry.config)

  return {} unless configs.length

  first = configs[0]
  firstKey = configKey(first)

  for config, idx in configs
    continue unless idx
    continue if configKey(config) is firstKey
    raise 'Tailwind: multiple different Tailwind configs were registered during one email render. Use a single shared config per render and call prepareConfig(config) before synchronous rendering.'

  first

# Hook passed to the shared renderer: inline Tailwind classes after the
# component tree is mounted but while the DOM shim is still active. The
# shared renderer's `after(root)` callback contract puts us in exactly
# the right spot — root is fully built, globalThis.document still
# points at the render's shim, and we run inside the same try/finally
# so any throw still restores the prior globals.
_inlineTailwind = (root) ->
  entries = takeEmailTailwindRoots()
  return unless entries.length
  result = inlineEmailTree(root, _resolveTailwindConfig(entries))
  warn "Tailwind: unsupported classes ignored: #{result.unsupported.join(' ')}" if result.unsupported?.length

export toHTML = (ComponentClass, props = {}) ->
  root = _renderComponent(ComponentClass, props, _inlineTailwind)
  "#{XHTML_DOCTYPE}#{serializeChildren(root)}"

export toText = (ComponentClass, props = {}) ->
  root = _renderComponent(ComponentClass, props, _inlineTailwind)
  toPlainText(root)

export toEmail = (ComponentClass, props = {}) ->
  root = _renderComponent(ComponentClass, props, _inlineTailwind)
  html = serializeChildren(root)
  text = toPlainText(root)
  { html: "#{XHTML_DOCTYPE}#{html}", text }
