{
  "name": "@rip-lang/data",
  "version": "0.1.0",
  "description": "Revolutionary data platform: DuckDB as both transactional and analytical store",
  "type": "module",
  "main": "index.ts",
  "exports": {
    ".": "./index.ts",
    "./server": "./rip-data-server.ts",
    "./client": "./rip-data-client.ts"
  },
  "scripts": {
    "dev": "bun run --watch index.ts",
    "build": "bun build index.ts --outdir dist --target bun",
    "start": "bun run index.ts",
    "test": "bun test"
  },
  "keywords": [
    "data",
    "database",
    "duckdb",
    "analytics",
    "data-lake",
    "bun",
    "rip"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/shreeve/rip-lang.git",
    "directory": "packages/data"
  },
  "homepage": "https://github.com/shreeve/rip-lang/tree/main/packages/data#readme",
  "bugs": {
    "url": "https://github.com/shreeve/rip-lang/issues"
  },
  "author": "Steve Shreeve <steve.shreeve@gmail.com>",
  "license": "MIT",
  "dependencies": {
    "duckdb": "^1.1.3",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/ws": "^8.5.13",
    "bun-types": "latest"
  },
  "peerDependencies": {
    "rip-lang": "^2.0.0"
  },
  "files": [
    "index.ts",
    "rip-data-server.ts",
    "rip-data-client.ts",
    "README.md"
  ]
}
