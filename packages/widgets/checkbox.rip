# Checkbox — accessible headless checkbox/switch widget
#
# Toggles on click, Enter, or Space. Supports indeterminate state.
# Exposes data-checked, data-indeterminate, data-disabled. Ships zero CSS.
# Set @switch to true for switch semantics (role="switch").
#
# Usage:
#   Checkbox checked <=> isActive, @change: handleChange
#     span "Enable notifications"
#
#   Checkbox checked <=> isDark, switch: true
#     span "Dark mode"

export Checkbox = component
  @checked := false
  @disabled := false
  @indeterminate := false
  @switch := false

  onMousedown: (e) -> e.preventDefault()

  onClick: (e) ->
    return if @disabled
    @indeterminate = false
    @checked = not @checked
    @emit 'change', @checked
    e.target.closest('button')?.focus({ preventScroll: true })

  render
    button role: @switch ? 'switch' : 'checkbox'
      aria-checked: @indeterminate ? 'mixed' : !!@checked
      aria-disabled: @disabled?!
      data-checked: @checked?!
      data-indeterminate: @indeterminate?!
      data-disabled: @disabled?!
      slot
