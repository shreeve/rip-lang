# Widget Gallery — dev server for testing all widgets

import { get, use, start } from '@rip-lang/server'
import { serve } from '@rip-lang/server/middleware'

dir = import.meta.dir

use serve dir: "#{dir}/demo"

get '/*.rip' -> @send "#{dir}/#{@req.path.slice(1)}", 'text/plain; charset=UTF-8'
get '/*' -> @send "#{dir}/demo/index.html", 'text/html; charset=UTF-8'

start port: 3005
