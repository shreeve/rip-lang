{
  "name": "vscode-rip",
  "displayName": "Rip Language",
  "description": "Rip language support - syntax highlighting, types, and editor integration",
  "version": "0.7.0",
  "publisher": "rip-lang",
  "license": "MIT",
  "main": "./dist/extension.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/shreeve/rip-lang.git",
    "directory": "packages/vscode"
  },
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "keywords": [
    "rip",
    "reactive",
    "types",
    "compiler"
  ],
  "icon": "icon.png",
  "contributes": {
    "languages": [
      {
        "id": "rip",
        "extensions": [
          ".rip"
        ],
        "aliases": [
          "Rip",
          "rip"
        ],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "./icon.png",
          "dark": "./icon.png"
        }
      }
    ],
    "grammars": [
      {
        "language": "rip",
        "scopeName": "source.rip",
        "path": "./syntaxes/rip.tmLanguage.json"
      },
      {
        "scopeName": "rip.injection.html",
        "path": "./syntaxes/rip-html-injection.tmLanguage.json",
        "injectTo": [
          "text.html.basic",
          "text.html.derivative"
        ],
        "embeddedLanguages": {
          "meta.embedded.block.rip": "rip"
        }
      },
      {
        "scopeName": "rip.injection.markdown",
        "path": "./syntaxes/rip-markdown-injection.tmLanguage.json",
        "injectTo": [
          "text.html.markdown"
        ],
        "embeddedLanguages": {
          "meta.embedded.block.rip": "rip"
        }
      }
    ],
    "semanticTokenTypes": [
      {
        "id": "attribute",
        "description": "A render-block boolean flag (e.g. a bare `disabled` on its own line)"
      }
    ],
    "semanticTokenScopes": [
      {
        "scopes": {
          "attribute": ["entity.other.attribute-name.rip"]
        }
      }
    ],
    "configurationDefaults": {
      "[rip]": {
        "editor.tabSize": 2,
        "editor.insertSpaces": true,
        "diffEditor.ignoreTrimWhitespace": false
      },
      "tailwindCSS.includeLanguages": {
        "rip": "html"
      },
      "tailwindCSS.experimental.classRegex": [
        "class:\\s*[\"']([^\"']*)[\"']",
        ["class:\\s*\\[((?:[^\\[\\]]|\\[[^\\]]*\\])*)\\]", "[\"']([^\"']*)[\"']"],
        ["\\.\\(((?:[^()]|\\([^)]*\\))*)\\)", "[\"']([^\"']*)[\"']"]
      ]
    }
  },
  "scripts": {
    "build": "bunx esbuild src/extension.js --bundle --outfile=dist/extension.js --format=cjs --platform=node --external:vscode --minify && bunx esbuild src/lsp.js --bundle --outfile=dist/lsp.js --format=cjs --platform=node --external:typescript --minify",
    "package": "rm -f vscode-rip-*.vsix && bun run build && bun scripts/package.js",
    "install-vscode": "bun run package && code --install-extension vscode-rip-*.vsix --force",
    "install-cursor": "bun run package && cursor --install-extension vscode-rip-*.vsix --force"
  },
  "dependencies": {
    "typescript": "catalog:"
  },
  "devDependencies": {
    "esbuild": "^0.27.3",
    "vscode-languageclient": "^9.0.1",
    "vscode-languageserver": "^9.0.1",
    "vscode-languageserver-textdocument": "^1.0.12"
  }
}
