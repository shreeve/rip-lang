# 09-components.rip — Typed component props
#
# Rip components define typed props with @prop:: type := default.
# The component definitions emit typed DTS declarations.
# Prop type checking on construction is a known gap (see bottom of file).

# ── Components ──

export Input = component extends input
  @label:: string := ""
  @value:: string := ""
  @error:: string := ""

  render
    fieldset
      if label
        label label
      input
        value <=> value
      if error
        div error

export Button = component extends button
  @variant:: "primary" | "secondary"
  @shape:: "rounded" | "pill" := "rounded"
  @loading:: boolean := false

  bg ~= if variant is "primary" then "#0066ff" else "#e5e5e5"
  fg ~= if variant is "primary" then "#fff" else "#333"

  render
    button
      style: "background: #{bg}; color: #{fg}"
      if loading
        "Loading..."
      else
        slot

export Form = component
  @title:: string := ""
  email := ""
  password := ""
  loading := false

  onSubmit: (e:: SubmitEvent) ->
    e.preventDefault()
    loading = true
    p "Signing in: #{email}"
    loading = false

  render
    form @submit: @onSubmit
      h1 title
      Input
        label: "Email"
        value <=> email
        placeholder: "jane@example.com"
        type: "email"
      Input
        label: "Password"
        value <=> password
        placeholder: "••••••••"
        type: "password"
      Button
        variant: "primary"
        type: "submit"
        loading: loading
        "Sign In"

# ── Negative: wrong prop types must be caught ──
#
# These match the TSX companion's negative prop-type tests.
# The enriched stub emits constructor calls in _render(),
# so TypeScript catches wrong literals, type mismatches, etc.

export PropTypeTests = component
  render
    div
      # @ts-expect-error — wrong variant literal
      Button variant: "danger"
      # @ts-expect-error — disabled expects boolean
      Button variant: "primary", disabled: "yes"
      # @ts-expect-error — wrong type for label
      Input label: 123
      # @ts-expect-error — inherited intrinsic: maxLength expects number
      Input maxLength: "ten"

# ── Two-way binding type safety ──
#
# The <=> operator passes the parent's Signal directly to the child.
# The constructor accepts __bind_prop__?: Signal<T> for each public
# state prop, so TypeScript can check that the bound signal matches
# the child's expected type.

export BindingTypeTests = component
  email := ""
  count := 0

  render
    div
      # Correct: string <=> string — no error
      Input
        value <=> email
      # @ts-expect-error — Type 'number' is not assignable to type 'string'
      Input
        value <=> count

# ── Negative: type safety inside component bodies ──

export TypeTestComp = component
  @variant:: "primary" | "secondary" := "primary"
  @count:: number := 0
  loading := false

  ok ~= if variant is "primary" then "#0066ff" else "#e5e5e5"

  # @ts-expect-error — toFixed doesn't exist on string union
  badFixed ~= variant.toFixed(2)

  # @ts-expect-error — arithmetic on string type
  badMath ~= variant * 2

  badMethod = ->
    # @ts-expect-error — string assigned to number state
    count = "hello"

  badBodyAssign = ->
    # @ts-expect-error — string assigned to inferred boolean state
    loading = "wrong"

  render
    null

# ── Negative: render block expression type checking ──
#
# Conditionals, switch discriminants, loop iterables, and text expressions
# in render blocks are type-checked. Typos emit into the stub so TS catches them.

export RenderCondTest = component
  label := ""
  error := ""
  items := ["a", "b"]
  status := "active"
  loading := false
  count := 42

  render
    div
      # @ts-expect-error — typo: 'labelz' does not exist on component
      if labelz
        span "label"
      # @ts-expect-error — typo: 'loadingz' does not exist
      unless loadingz
        span "ready"
      # @ts-expect-error — typo: 'statusz' does not exist
      switch statusz
        when "active" then span "on"
        when "inactive" then span "off"
      # @ts-expect-error — typo: 'itemsz' does not exist
      for item in itemsz
        span "list"
      # @ts-expect-error — typo: 'countz' does not exist
      = countz

# ── Event handler typing ──
#
# Both inline and named method refs are typed:
#   @click: (e) -> ...        # inline — contextual typing from __RipEvents
#   @submit: @handleSubmit    # named — stub injects HTMLElementEventMap type
#
# The stub pre-scans the render block for @event: @method bindings
# and annotates the first untyped parameter with the event type.

export EventHandlerTest = component
  # Named method refs — stub injects event parameter types
  handleSubmit: (e) -> e.preventDefault()
  handleClick: (e) -> p e.clientX

  render
    form @submit: @handleSubmit
      button @click: @handleClick, "Click"
      # Inline handlers — contextual typing from __RipEvents
      button @click: (e) -> p e.clientX, "Inline"
      input @keydown: (e) -> p e.key

# ── Generic components ──
#
# Components can be parameterized by type. A real-world Select uses
# a bounded generic — options must be strings or { value, label }.

type TOptionShape = string | { value: string, label: string }

export Select<TOption extends TOptionShape> = component extends select
  @label:: string := ""
  @options:: TOption[] := []
  @placeholder:: string := ""
  @error:: string := ""

  render
    fieldset
      if label
        label label
      select
        if placeholder
          option value: "", disabled: true, placeholder
        for option in options
          option
            key: typeof option is "string" ? option : option.value
            value: typeof option is "string" ? option : option.value
            typeof option is "string" ? option : option.label
      if error
        div error

# Usage — T is inferred from the options array
export GenericUsageTests = component
  render
    div
      # Simple: string options
      Select options: ["Red", "Green", "Blue"]

      # Structured: { value, label } options
      Select options: [{ value: "admin", label: "Admin" }, { value: "user", label: "User" }]

      # @ts-expect-error — number doesn't extend TOptionShape
      Select options: [1, 2, 3]

      # @ts-expect-error — object missing 'label' field (has 'name' instead)
      Select options: [{ value: "a", name: "A" }]

# ── Stash vs zustand: shared client state (shopping cart) ──
#
# A shopping cart is pure client state — created in the browser,
# shared across routes/components, persisted to localStorage.
# This is exactly what stash and zustand are for.

# Define the cart shape — data + methods, like a zustand store:
type CartItem =
  id: number
  name: string
  price: number
  quantity: number

type Cart =
  items: CartItem[]
  addItem: (item: CartItem) => void
  removeItem: (item: CartItem) => void
  total: () => number

# In a real Rip app, the stash is seeded (possibly empty) and shared:
#   <script data-state='{"cart": {"items": []}}'>
#
# There is ONE global stash per app — a deep reactive proxy. Different
# "stores" are just paths within it (stash.cart, stash.theme, etc.).
# This is unlike zustand, where each store is a separate create() call.
# Below we simulate this with a module-level object — the access pattern
# is identical to how components use stash in the browser.

stash:: { cart: Cart } =
  cart:
    items: []
    addItem: (item) -> stash.cart.items = [...stash.cart.items, item]
    removeItem: (item) -> stash.cart.items = stash.cart.items.filter (i) -> i.id isnt item.id
    total: -> stash.cart.items.reduce ((sum:: number, i) -> sum + i.price * i.quantity), 0

export CartDemo = component
  render
    div
      span "#{stash.cart.items.length} items — $#{stash.cart.total()}"
      button
        @click: -> stash.cart.addItem { id: 1, name: "Widget", price: 9.99, quantity: 1 }
        "Add to Cart"
      ul
        for item in stash.cart.items
          li "#{item.name} x#{item.quantity} — $#{item.price}"

# ── Negative: stash type safety ──
#
# The :: annotation on stash flows through to the .d.ts, so TypeScript
# catches every mistake — reads, writes, and method calls.

export StashTypeTests = component
  badAccess: ->
    # Writes
    # @ts-expect-error — wrong type: items should be CartItem[], not string
    stash.cart.items = "not an array"
    # @ts-expect-error — wrong item shape: missing required fields
    stash.cart.addItem { broken: true }
    # @ts-expect-error — wrong arg type: number instead of CartItem
    stash.cart.removeItem 42

    # Reads
    # @ts-expect-error — typo: 'item' doesn't exist, it's 'items'
    stash.cart.item
    # @ts-expect-error — nonexistent path
    stash.cart.tax

  render
    null
