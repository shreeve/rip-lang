# 09-components.rip — Typed component props
#
# Rip components define typed props with @prop:: type := default.
# The component definitions emit typed DTS declarations.
# Prop type checking on construction is a known gap (see bottom of file).

# ── Components ──

export Input = component
  @label:: string := ""
  @value:: string := ""
  @placeholder:: string := ""
  @type:: string := "text"
  @error:: string := ""

  render
    fieldset
      if label
        label label
      input
        value <=> value
        placeholder: placeholder
        type: type
      if error
        div error

export InheritedInput = component extends input
  @label:: string := ""
  @error:: string := ""

  render
    fieldset
      if label
        label label
      input
      if error
        div error

export Button = component
  @variant:: "primary" | "secondary"
  @type:: "submit" | "reset" | "button" := "button"
  @shape:: "rounded" | "pill" := "rounded"
  @loading:: boolean := false
  @disabled:: boolean := false

  bg ~= if variant is "primary" then "#0066ff" else "#e5e5e5"
  fg ~= if variant is "primary" then "#fff" else "#333"

  render
    button
      type: type
      disabled: disabled or loading
      style: "background: #{bg}; color: #{fg}"
      if loading
        "Loading..."
      else
        slot

export Form = component
  @title:: string := ""
  email := ""
  password := ""
  loading := false

  onSubmit: (e:: Event) ->
    e.preventDefault()
    loading = true
    p "Signing in: #{email}"
    loading = false

  render
    form @submit: @onSubmit
      h1 title
      Input
        label: "Email"
        value <=> email
        placeholder: "jane@example.com"
        type: "email"
      Input
        label: "Password"
        value <=> password
        placeholder: "••••••••"
        type: "password"
      Button
        variant: "primary"
        type: "submit"
        loading: loading
        "Sign In"

# ── Negative: wrong prop types must be caught ──
#
# These match the TSX companion's negative prop-type tests.
# The enriched stub emits constructor calls in _render(),
# so TypeScript catches wrong literals, type mismatches, etc.

export PropTypeTests = component
  render
    div
      # @ts-expect-error — wrong variant literal
      Button variant: "danger"
      # @ts-expect-error — disabled expects boolean
      Button variant: "primary", disabled: "yes"
      # @ts-expect-error — wrong type for label
      Input label: 123
      InheritedInput label: "Email", autofocus: true, maxLength: 100
      # @ts-expect-error — autofocus expects boolean
      InheritedInput autofocus: "yes"

# ── Two-way binding type safety ──
#
# The <=> operator passes the parent's Signal directly to the child.
# The constructor accepts __bind_prop__?: Signal<T> for each public
# state prop, so TypeScript can check that the bound signal matches
# the child's expected type.

export BindingTypeTests = component
  email := ""
  count := 0

  render
    div
      # Correct: string <=> string — no error
      Input
        value <=> email
      # @ts-expect-error — Signal<number> not assignable to Signal<string>
      Input
        value <=> count

# ── Negative: type safety inside component bodies ──
#
# The enriched stub gives TypeScript typed property declarations
# (Signal<T>, Computed<T>) so type errors in computeds and methods
# are caught. Each @ts-expect-error must suppress a real TS error.

export TypeTestComp = component
  @variant:: "primary" | "secondary" := "primary"
  @count:: number := 0
  loading := false

  ok ~= if variant is "primary" then "#0066ff" else "#e5e5e5"

  # @ts-expect-error — toFixed doesn't exist on string union
  badFixed ~= variant.toFixed(2)

  # @ts-expect-error — arithmetic on string type
  badMath ~= variant * 2

  badMethod = ->
    # @ts-expect-error — string assigned to number state
    count = "hello"

  badBodyAssign = ->
    # @ts-expect-error — string assigned to inferred boolean state
    loading = "wrong"

  render
    null

# ── Partially resolved: render block type safety ──
#
# Render blocks are now partially type-checked via __ripEl():
#
# What works (see 12-intrinsics.rip for full coverage):
#   - Intrinsic element attributes are type-checked against lib.dom.d.ts
#     (e.g. `button disabled: "yes"` errors — disabled expects boolean)
#   - Event handlers get contextual typing via HTMLElementEventMap
#     (`@click: (e) -> ...` knows `e` is MouseEvent for inline handlers)
#   - Global attrs (class, style, data-*, aria-*) accepted on any element
#   - Child component constructor calls still checked as before
#
# Remaining gaps:
#   - Own-template conditionals like `if labelz` still go uncaught
#   - Text expressions (`= expr`) are unchecked
#
# Non-issues (clarified during review):
#   - Unknown lowercase names like `fieldsetz` are treated as expressions
#     (variable refs / method calls), which TS catches via "Cannot find name"
#     in typed files — this is correct behavior, not a gap
#   - Event typing is global (same HTMLElementEventMap for all elements) —
#     this matches how the DOM actually works; React has the same behavior

# ── Partially resolved: event handler typing ──
#
# Inline event handlers on intrinsic elements now get contextual typing:
#   @click: (e) -> ...   # e is MouseEvent (from HTMLElementEventMap)
#   @submit: (e) -> ...  # e is SubmitEvent
#
# Named method refs like `@submit: @handleSubmit` remain untyped —
# TS can only contextually type inline function literals, not already-
# declared methods. Workaround: annotate the param explicitly:
#   handleSubmit: (e:: SubmitEvent) -> e.preventDefault()
#
# Tracked in AGENTS.md gap table under "Event handler typing".

# ── Element type inheritance ──
#
# `component extends input` widens the constructor props with
# `__RipProps<'input'>`, giving access to ALL of <input>'s props
# (autofocus, maxLength, aria-*, etc.) for free. The runtime
# forwards unknown props to the first matching element in the
# render block.

# ── Gap: generic components ──
#
# Can't parameterize a component by type. A real-world Select needs
# a bounded generic — options must be strings or { value, label }:
#
#   # Not valid Rip syntax:
#   type TOptionShape = string | { value: string, label: string }
#
#   export Select<TOption extends TOptionShape> = component
#     @options:: TOption[] := []
#     @placeholder:: string := ""
#     @error:: string := ""
#
# In React/TS (see 09-components.tsx), this is straightforward:
#   type TOptionShape = string | { value: string; label: string }
#   function Select<TOption extends TOptionShape>(props: SelectProps<TOption>) { ... }
#
# The constraint ensures callers can only pass valid option shapes.
# Numbers, objects missing 'label', etc. are caught at the call site.
# In Rip, @options would be typed as `any[]` — no constraint links
# the option shape to a known interface, and no way to express
# `extends` bounds on component type parameters.
#
# Tracked in AGENTS.md gap table under "Generic components".

# ── Stash vs zustand: shared client state (shopping cart) ──
#
# A shopping cart is pure client state — created in the browser,
# shared across routes/components, persisted to localStorage.
# This is exactly what stash and zustand are for.

# Define the cart shape (Rip can express this type):
type CartItem =
  id: number
  name: string
  price: number
  quantity: number

# In a real Rip app, the stash is seeded (possibly empty) and shared:
#   <script data-state='{"cart": {"items": []}}'>
#
# There is ONE global stash per app — a deep reactive proxy. Different
# "stores" are just paths within it (stash.cart, stash.theme, etc.).
# This is unlike zustand, where each store is a separate create() call.
# Below we simulate this with a module-level object — the access pattern
# is identical to how components use stash in the browser.

stash:: { cart: { items: CartItem[] } } = { cart: { items: [] } }

def addItem(item:: CartItem)
  stash.cart.items = [...stash.cart.items, item]

def removeItem(item:: CartItem)
  stash.cart.items = stash.cart.items.filter (i) -> i.id isnt item.id

def total():: number
  stash.cart.items.reduce ((sum:: number, i) -> sum + i.price * i.quantity), 0

export CartBadge = component
  render
    span "#{stash.cart.items.length} items"

export CartTotal = component
  render
    div
      span "Total: $#{total()}"

export AddToCart = component
  add: ->
    addItem { id: 1, name: "Widget", price: 9.99, quantity: 1 }

  render
    button @click: @add, "Add to Cart"

# ── What stash can't catch (all of these compile silently) ──
#
#   stash.cart.items = "not an array"        # wrong type
#   addItem { broken: true }                 # wrong item shape
#   stash.cart.item                          # typo — 'item' not 'items'
#   stash.cart.tax                           # nonexistent path
#   removeItem 42                            # wrong arg type — number for CartItem
#
# CartItem type exists but has NO connection to the stash object or
# the addItem/removeItem/total functions. It generates a .d.ts
# declaration but doesn't constrain anything at compile time.
# The stash is a plain reactive proxy — any property access or
# assignment is valid.
#
# In zustand (see 09-components.tsx), ALL of these are caught at
# compile time. The store is typed from creation and every
# selector/mutation is checked.
#
# Tracked in AGENTS.md gap table under "Shared state typing (stash)".
