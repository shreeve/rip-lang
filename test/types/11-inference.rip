# 11-inference.rip — Type inference on unannotated variables
#
# Two mechanisms enable inference on unannotated variables:
#
#   1. Inline-let — the compiler emits `let x = value;` instead of
#      `let x; x = value;` when safe, giving TS a direct initializer.
#      Works at program level, inside functions, and in block-confined
#      variables (e.g., only used inside one if-branch).
#
#   2. patchUninitializedTypes — for variables that must be hoisted
#      (e.g., used across multiple blocks), the type-checker patches
#      the symbol's type from the first assignment at check time.

# ── Setup ──

count = 0
ratio = 3.14
items = ["a", "b", "c"]

def double(n:: number)
  n * 2

def expectString(x:: string)
  x

# ──────────────────────────────────────────────────
# Top-level assignment with a concrete RHS
# ──────────────────────────────────────────────────

# ── Primitives ──

total = count + ratio
label = "hello"
active = true

# @ts-expect-error — inferred number
total = "oops"
# @ts-expect-error — inferred string
label = 42
# @ts-expect-error — inferred boolean
active = "yes"

# ── Typed function return ──

result = double 5
# @ts-expect-error — inferred number
result = "oops"

# ── Method calls on typed values ──

upper = "hello".toUpperCase()
joined = items.join ", "

# @ts-expect-error — inferred string
upper = 42
# @ts-expect-error — inferred string
joined = false

# ── Array element access ──

first = items[0]
# @ts-expect-error — inferred string | undefined
first = 99

# ── Template literals ──

msg = "count is #{count}"
# @ts-expect-error — inferred string
msg = 42

console.log total, label, active, result, upper, joined, first, msg

# ──────────────────────────────────────────────────
# Block-scoped and destructured assignments
# ──────────────────────────────────────────────────

# ── Block-scoped first assignment ──
#
# The patcher recurses into if/for/while/try/switch blocks to find
# the first assignment, so insideIf is inferred as number.

if true
  insideIf = count + ratio
# @ts-expect-error — number not assignable to string (block-scoped inference patched)
expectString insideIf

# ── Destructuring ──
#
# The patcher walks destructuring patterns and infers each property's
# type from the RHS object type.

{a, b} = {a: 1, b: "hello"}
# @ts-expect-error — number not assignable to string (destructured inference patched)
expectString a

console.log insideIf, a, b

# ──────────────────────────────────────────────────
# Inline-let inside functions
# ──────────────────────────────────────────────────

# Variables inside functions get `let x = value;` at the assignment
# site. TS infers the type directly from the initializer — no patcher
# needed. This is the inline-let mechanism at work.

def expectNum(x:: number)
  x

def process(data:: string[])
  csv = data.join ", "
  loud = csv.toUpperCase()
  loud

out = process items
# @ts-expect-error — out inferred as string
expectNum out

def filterBy(query:: string)
  q = query.toLowerCase()
  items.filter (s) -> s.includes(q)

matches = filterBy "a"
# @ts-expect-error — matches inferred as string[]
expectNum matches

console.log out, matches

# ──────────────────────────────────────────────────
# Block-confined inside functions
# ──────────────────────────────────────────────────

# Variables confined to one branch inside a function get `let`
# emitted at the block level. Before inline-let, these were
# hoisted to the function top as `let x;` — TS saw `any`.

def search(data:: string[], query:: string)
  if query.length > 0
    needle = query.toLowerCase()
    hits = data.filter (n) -> n.toLowerCase().includes(needle)
    # @ts-expect-error — hits inferred as string[]
    expectNum hits
    hits.join ", "
  else
    "no results"

found = search items, "a"
# @ts-expect-error — found inferred as string
expectNum found

console.log found
