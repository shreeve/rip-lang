# 12-cast.rip — `expr as Type` cast operator
#
# A TypeScript-style postfix type assertion. The cast is ERASED at runtime
# (the emitted JS is the bare value) and only re-materializes as a real TS
# `(expr as Type)` in the shadow-TS check path, so it narrows for the checker.
# Each negative below proves the same line errors WITHOUT the cast.

type Base =
  id: number

type Rich =
  id: number
  label: string

def makeRich(): Rich
  ({ id: 1, label: 'one' })

# ── Downcast: base type → richer subtype ──

b: Base = makeRich()
# @ts-expect-error — `label` is not on Base
b.label
r = b as Rich
console.log r.label

# ── `unknown` → concrete ──

raw: unknown = 'hello'
# @ts-expect-error — value is of type 'unknown'
raw.toUpperCase()
upper = (raw as string).toUpperCase()
console.log upper

# ── Augmented shape (extra custom property) — mirrors the ARIA `__aria*` props ──

type Meta =
  tag: string
  __meta: number

def getEl(): { tag: string }
  o = { tag: 'div', __meta: 9 }
  o

e = getEl()
# @ts-expect-error — `__meta` is not on { tag: string }
e.__meta
console.log (e as Meta).__meta

# ── Precedence: the cast binds tighter than `+` ──

n: unknown = 3
# @ts-expect-error — arithmetic on 'unknown'
n + 1
sum = (n as number) + 1
console.log sum

# ── Chained cast: unknown → Base → Rich ──

u: unknown = makeRich()
chained = (u as Base as Rich).label
console.log chained

# ── Member access narrows too (the carrier is the property) ──

box: { inner: Base } = { inner: makeRich() }
# @ts-expect-error — `label` is not on Base
box.inner.label
mlabel = (box.inner as Rich).label
console.log mlabel

# ── Known gap (pending RFC-12): call / index / parenthesized results do NOT
# narrow. The runtime erase is still correct; only the type narrowing is lost,
# so these forms are deliberately NOT exercised as positive narrowing cases.
# e.g. `(makeRich() as Rich)`, `(arr[0] as Rich)`, and `((b) as Rich)` compile
# and erase, but the assertion is dropped from the checker's view. Use an
# identifier or member-access carrier when you need narrowing today.
