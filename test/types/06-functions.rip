# 06-functions.rip — Typed functions, arrows, and array transforms

type Point =
  x: number
  y: number

# ── Declare: typed functions ──

export def add(a:: number, b:: number):: number
  a + b

export def greet(name:: string):: string
  "Hello, #{name}!"

export def clamp(val:: number, lo:: number, hi:: number):: number
  Math.max(lo, Math.min(hi, val))

export def makePoint(x:: number, y:: number):: Point
  { x, y }

export def parse(input:: string):: number | null
  num = parseInt(input)
  if isNaN(num) then null else num

export def sum(...nums:: number[]):: number
  nums.reduce ((a, b) => a + b), 0

export def isPositive(n:: number):: boolean
  n > 0

# Default param (emits title?: string in .d.ts)
export def formal(name:: string, title:: string = "Mr"):: string
  "#{title} #{name}"

# Void return (! suppresses return value)
export def logMsg!(msg:: string)
  console.log msg

# Optional param (? suffix — emits title?: string in .d.ts)
export def greetOpt(name:: string, title?:: string):: string
  if title then "#{title} #{name}" else name

# Inferred return type (no :: annotation — TS infers from body)
export def double(n:: number)
  n * 2

# ── Use: inferred results (no :: annotations) ──

result1  = add(3, 4)
result2  = greet("World")
result3  = clamp(15, 0, 10)
result4  = makePoint(1, 2)
result5  = parse("42")
result6  = sum(1, 2, 3, 4)
result7  = isPositive(5)
result8  = formal("Smith")
result9  = formal("Smith", "Dr")
logMsg!("hello")
result10 = greetOpt("Smith")
result11 = greetOpt("Smith", "Dr")
result12 = double(21)

console.log result1, result2, result3, result4, result5, result6, result7, result8, result9, result10, result11, result12

# ── Negative: wrong param types ──

# @ts-expect-error — string args where numbers expected
badAdd:: number = add("a", "b")
# @ts-expect-error — number arg where string expected
badGreet:: string = greet(42)
# @ts-expect-error — too few arguments
badClamp:: number = clamp(5, 0)
# @ts-expect-error — boolean arg where number expected
badPoint:: Point = makePoint(true, false)
# @ts-expect-error — number arg where string expected
badParse:: number | null = parse(123)
# @ts-expect-error — string args where numbers expected
badSum:: number = sum("a", "b")
# @ts-expect-error — string arg where number expected
badPos:: boolean = isPositive("five")

# ── Negative: wrong return types ──

# @ts-expect-error — add returns number, not string
badRet1:: string = add(1, 2)
# @ts-expect-error — greet returns string, not number
badRet2:: number = greet("hi")
# @ts-expect-error — makePoint returns Point, not string
badRet3:: string = makePoint(1, 2)
# @ts-expect-error — sum returns number, not boolean
badRet4:: boolean = sum(1, 2, 3)
# @ts-expect-error — isPositive returns boolean, not number
badRet5:: number = isPositive(1)
# @ts-expect-error — double infers number return, not string
badRet6:: string = double(1)

# ── Arrow functions and array transforms ──

nums:: number[] = [1, 2, 3, 4, 5]
doubled = nums.map (x) => x * 2
evens = nums.filter (x) => x % 2 == 0
arrTotal = nums.reduce ((acc, x) => acc + x), 0

words:: string[] = ["hello", "world", "rip"]
upper = words.map (w) => w.toUpperCase()
long = words.filter (w) => w.length > 3
joined = words.join(", ")

console.log "doubled:", doubled
console.log "evens:", evens
console.log "arrTotal:", arrTotal
console.log "upper:", upper
console.log "long:", long
console.log "joined:", joined

# @ts-expect-error — map returns number[], not string[]
badMap:: string[] = nums.map (x) => x * 2
# @ts-expect-error — filter returns number[], not string[]
badFilter:: string[] = nums.filter (x) => x > 2
# @ts-expect-error — reduce returns number, not string
badReduce:: string = nums.reduce ((acc, x) => acc + x), 0

# ── Destructured params ──

export def createUser({name:: string, age:: number}):: string
  "#{name} is #{age}"

result13 = createUser({ name: "Jane", age: 30 })

console.log result13

# @ts-expect-error — number where string expected in destructured param
badCreate:: string = createUser({ name: 42, age: 30 })

# ── Destructured params: defaults ──

export def withDefaults({name:: string = "anon", age:: number = 0}):: string
  "#{name} is #{age}"

result14 = withDefaults({})
result15 = withDefaults({ name: "Eve", age: 25 })

console.log result14, result15

# @ts-expect-error — number where string expected
badDefaults:: string = withDefaults({ name: 42 })

# ── Destructured params: rest ──

export def withRest({name:: string, ...rest}):: string
  "#{name}"

result16 = withRest({ name: "Alice", extra: true })

console.log result16

# ── Destructured params: rename ──

export def withRename({name: userName:: string, age:: number}):: string
  "#{userName} is #{age}"

result17 = withRename({ name: "Bob", age: 42 })

console.log result17

# @ts-expect-error — number where string expected in renamed prop
badRename:: string = withRename({ name: 123, age: 42 })

# ── Destructured params: array ──

export def withArray([first:: string, second:: string]):: string
  "#{first} and #{second}"

result18 = withArray(["hello", "world"])

console.log result18

# @ts-expect-error — number where string expected in array destructured param
badArray:: string = withArray([42, "world"])

# ── Destructured params: nested ──

export def withNested({user: {name:: string, age:: number}}):: string
  "#{name} is #{age}"

result19 = withNested({ user: { name: "Carol", age: 35 } })

console.log result19

# @ts-expect-error — number where string expected in nested destructured param
badNested:: string = withNested({ user: { name: 123, age: 35 } })

# ── Semantic token showcase ──
# With the LSP's semantic token provider enabled, these get richer
# highlighting than TextMate alone can provide:
#   - `input`, `radix`, `fallback` stay colored as parameters in the body
#   - `parseInt`, `isNaN`, `Math` get the defaultLibrary modifier
#   - `double` passed by name (no parens) is colored as a function
#   - `it` (implicit param) is colored as a parameter

export def parseNums(input:: string, radix:: number, fallback:: number):: number[]
  input.split(",").map (part) ->
    parsed = parseInt(part.trim(), radix)
    value = if isNaN(parsed) then fallback else parsed
    Math.max(0, Math.min(value, 1000))

result20 = parseNums("10, 20, ff, zz", 16, -1)
result21 = [1, 2, 3].map(double)
result22 = ["3", "7", "nope"].map -> parseInt(it) or 0
console.log "parseNums:", result20
console.log "map double:", result21
console.log "map it:", result22

# ── Async/await with ! (dammit) operator ──
# The ! operator calls a function and awaits the result in one step.
# Return types flow through: explicit annotations validate against
# the body, and unannotated functions infer the return type.

def delay(ms:: number):: Promise<string>
  sleep! ms
  "done after #{ms}ms"

# ! operator: calls + awaits in one step
r1 = delay! 50
console.log "r1: #{r1}"

# If we wrote `r2:: number = delay! 50`, rip check catches:
#   "Type 'string' is not assignable to type 'number'" ✓
# (@ts-expect-error doesn't work here — shadow file line misalignment)

# Without return annotation, TS infers the return type from the body
def delayUntyped(ms:: number)
  sleep! ms
  "untyped after #{ms}ms"

r3 = delayUntyped! 50
console.log "r3: #{r3}"
# r3 is inferred as string — assigning to number is caught
# @ts-expect-error — Type 'string' is not assignable to type 'number'
r4:: number = r3
