# Test: Aggressive Logical Unwrapping (with safety checks)
# Tests that pure logical chains unwrap fully, but mixed precedence stays safe

# ============================================================================
# SAFETY CRITICAL: Mixed Precedence (MUST keep parens)
# ============================================================================

test "arithmetic with or preserves parens", "x = 5 - (3 || 2)", 2
test "array index with or preserves parens", "arr = [10, 20, 30]; len = 0; arr[len - (len || 1)]", 30
code "arithmetic mixed precedence", "x = a - (b || c)", "let x;\n\nx = a - (b || c);"

# ============================================================================
# Pure Logical Chains (should unwrap all layers)
# ============================================================================

code "postfix if two operators", "x = 5 if !isEmpty && isValid", "let x;\n\nif (!isEmpty && isValid) x = 5;"
code "postfix if three operators", "x = 5 if !isEmpty && !isPassthrough && hasPrecedence", "let x;\n\nif (!isEmpty && !isPassthrough && hasPrecedence) x = 5;"
code "postfix if four operators", "x = 5 if !a && !b && !c && d", "let x;\n\nif (!a && !b && !c && d) x = 5;"

# ============================================================================
# Mixed Operators in Conditions (keep inner parens, unwrap outer)
# ============================================================================

code "comparison with logical", "if (x > 5) && (y < 10) then z", "if ((x > 5) && (y < 10)) {\n  z;\n}"
test "comparison with logical execution", "x = 6; y = 8; result = 'yes' if (x > 5) && (y < 10); result", "yes"
