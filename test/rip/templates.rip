# ==============================================================================
# Template Tests - h() Runtime
# ==============================================================================
# Tests for the template DSL using h(), frag(), txt() runtime helpers
#

# ------------------------------------------------------------------------------
# Basic Element Creation
# ------------------------------------------------------------------------------

code "simple div", "render\n  div", "h('div', 0)"

code "div with single class", "render\n  div.card", "h('div.card', 0)"

code "div with multiple classes", "render\n  div.card.active.highlight", "h('div.card.active.highlight', 0)"

code "span element", "render\n  span", "h('span', 0)"

code "button element", "render\n  button", "h('button', 0)"

# ------------------------------------------------------------------------------
# Text Content
# ------------------------------------------------------------------------------

code "element with text", 'render\n  span "Hello"', 'h(\'span\', 0, "Hello")'

code "h1 with text", 'render\n  h1 "Title"', 'h(\'h1\', 0, "Title")'

# ------------------------------------------------------------------------------
# Attributes
# ------------------------------------------------------------------------------

code "input with type", 'render\n  input type: "text"', 'h(\'input\', { type: "text" })'

code "multiple attributes", 'render\n  input type: "email", placeholder: "you@example.com"', 'h(\'input\', { type: "email", placeholder: "you@example.com" })'

code "button with text and attr", 'render\n  button type: "submit", "Submit"', 'h(\'button\', { type: "submit" }, "Submit")'

# ------------------------------------------------------------------------------
# Event Handlers
# ------------------------------------------------------------------------------

code "click handler", 'render\n  button @click: handleClick, "Click"', 'h(\'button\', { onclick: handleClick }, "Click")'

# ------------------------------------------------------------------------------
# Nested Elements (Arrow Syntax)
# ------------------------------------------------------------------------------

code "nested children", 'render\n  div.card ->\n    h1 "Title"\n    p "Content"', 'h(\'div.card\', 0, [h(\'h1\', 0, "Title"), h(\'p\', 0, "Content")])'

# ------------------------------------------------------------------------------
# Multiple Root Elements (Fragment)
# ------------------------------------------------------------------------------

code "sibling elements", 'render\n  div\n  span "Hello"', 'frag(h(\'div\', 0), h(\'span\', 0, "Hello"))'

# ------------------------------------------------------------------------------
# Event Modifiers
# ------------------------------------------------------------------------------

code "prevent modifier", 'render\n  button [@click.prevent]: handleClick, "Click"', 'h(\'button\', { onclick: (e) => { e.preventDefault(); (handleClick)(e); } }, "Click")'

code "stop modifier", 'render\n  button [@click.stop]: handleClick, "Click"', 'h(\'button\', { onclick: (e) => { e.stopPropagation(); (handleClick)(e); } }, "Click")'

code "prevent and stop modifiers", 'render\n  button [@click.prevent.stop]: handleClick, "Click"', 'h(\'button\', { onclick: (e) => { e.preventDefault(); e.stopPropagation(); (handleClick)(e); } }, "Click")'

code "enter key modifier", 'render\n  input [@keydown.enter]: submit', "h('input', { onkeydown: (e) => { if (e.key !== 'Enter') return; (submit)(e); } })"

code "escape key modifier", 'render\n  input [@keydown.escape]: cancel', "h('input', { onkeydown: (e) => { if (e.key !== 'Escape') return; (cancel)(e); } })"

code "ctrl enter combo", 'render\n  input [@keydown.ctrl.enter]: handleCtrlEnter', "h('input', { onkeydown: (e) => { if (!e.ctrlKey) return; if (e.key !== 'Enter') return; (handleCtrlEnter)(e); } })"

code "self modifier", 'render\n  div [@click.self]: handleSelf', "h('div', { onclick: (e) => { if (e.target !== e.currentTarget) return; (handleSelf)(e); } })"

# ------------------------------------------------------------------------------
# Control Flow in Templates
# ------------------------------------------------------------------------------

code "if-else conditional", 'render\n  div.card ->\n    if loading\n      span "Loading..."\n    else\n      span "Done"', 'h(\'div.card\', 0, (loading ? h(\'span\', 0, "Loading...") : h(\'span\', 0, "Done")))'

code "for loop", 'render\n  ul ->\n    for item in items\n      li item', "h('ul', 0, frag(...items.map((item, __i) => h('li', 0, String(item)))))"

code "postfix if", 'render\n  div.card ->\n    span.badge "Admin" if user.isAdmin', 'h(\'div.card\', 0, (user.isAdmin ? h(\'span.badge\', 0, "Admin") : null))'

# ------------------------------------------------------------------------------
# Special Attributes (ref, key)
# ------------------------------------------------------------------------------

code "ref attribute", 'render\n  input ref: inputEl, type: "text"', '(inputEl = h(\'input\', { type: "text" }))'

code "key attribute", 'render\n  li key: item.id, item.name', "h('li', { key: item.id }, txt(item.name))"

code "variable property as text", 'render\n  span user.name', "h('span', 0, txt(user.name))"

# ------------------------------------------------------------------------------
# SVG Support
# ------------------------------------------------------------------------------

code "svg element", 'render\n  svg width: "100", height: "100"', 'h(\'svg\', { width: "100", height: "100" })'

code "svg with children", 'render\n  svg width: "100", height: "100", ->\n    circle cx: "50", cy: "50", r: "40"', 'h(\'svg\', { width: "100", height: "100" }, h(\'circle\', { cx: "50", cy: "50", r: "40" }))'

code "svg path", 'render\n  path d: "M0 0 L10 10"', 'h(\'path\', { d: "M0 0 L10 10" })'

# ------------------------------------------------------------------------------
# Implicit Nesting (no -> required)
# ------------------------------------------------------------------------------

code "implicit nesting", 'render\n  div.card\n    h1 "Title"', 'h(\'div.card\', 0, h(\'h1\', 0, "Title"))'

code "implicit nesting multiple", 'render\n  div.card\n    h1 "Title"\n    p "Content"', 'h(\'div.card\', 0, [h(\'h1\', 0, "Title"), h(\'p\', 0, "Content")])'

code "implicit nesting deep", 'render\n  div\n    ul\n      li "Item"', 'h(\'div\', 0, h(\'ul\', 0, h(\'li\', 0, "Item")))'

code "implicit with attrs", 'render\n  div.card\n    a href: "/", "Link"', 'h(\'div.card\', 0, h(\'a\', { href: "/" }, "Link"))'

# ------------------------------------------------------------------------------
# ID Selectors (#id syntax)
# ------------------------------------------------------------------------------

code "id selector basic", 'render\n  div#main', 'h(\'div#main\', 0)'

code "id selector with text", 'render\n  div#main "Hello"', 'h(\'div#main\', 0, "Hello")'

code "id with class", 'render\n  div#main.card "Hi"', 'h(\'div#main.card\', 0, "Hi")'

code "id with multiple classes", 'render\n  div#app.container.fluid', 'h(\'div#app.container.fluid\', 0)'

# ------------------------------------------------------------------------------
# Dynamic Classes (.() syntax with cx())
# ------------------------------------------------------------------------------

code "dynamic class basic", 'render\n  div.("card", isActive && "active")', "h('div', { class: cx(\"card\", (isActive && \"active\")) })"

code "dynamic class with static", 'render\n  div.card.(isActive && "active")', "h('div.card', { class: cx((isActive && \"active\")) })"

code "dynamic class with children", 'render\n  div.(size)\n    span "Hi"', "h('div', { class: cx(size) }, h('span', 0, \"Hi\"))"

code "dynamic class object syntax", 'render\n  div.({ active: isActive })', "h('div', { class: cx({ active: isActive }) })"

# ------------------------------------------------------------------------------
# Spread Attributes
# ------------------------------------------------------------------------------

code "spread basic", 'render\n  div ...props', "h('div', { ...props })"

code "spread with static class", 'render\n  div.card ...props', "h('div.card', { ...props })"

code "spread with extra attrs", 'render\n  div ...props, class: "extra"', "h('div', { ...props, class: \"extra\" })"

code "spread with children", 'render\n  div.card ...props\n    span "Hi"', "h('div.card', { ...props }, h('span', 0, \"Hi\"))"

# ------------------------------------------------------------------------------
# Two-way Binding ([@bind.prop]: var)
# ------------------------------------------------------------------------------

code "bind value on input", 'render\n  input [@bind.value]: username', "h('input', { value: username, oninput: (e) => username = e.target.value })"

code "bind checked on checkbox", 'render\n  input type: "checkbox", [@bind.checked]: isActive', "h('input', { type: \"checkbox\", checked: isActive, onchange: (e) => isActive = e.target.checked })"

code "bind value on select", 'render\n  select [@bind.value]: selectedId', "h('select', { value: selectedId, onchange: (e) => selectedId = e.target.value })"

code "bind value on textarea", 'render\n  textarea [@bind.value]: content', "h('textarea', { value: content, oninput: (e) => content = e.target.value })"
