# Test: Component System (86 tests)
# Covers every code path in src/components.js — render blocks, conditional/loop
# codegen, block factories, attributes, events, auto-wired event handlers (on*
# convention), two-way binding (<=>), dynamic classes (__clsx), child component
# prop passing, slot projection (@children), lifecycle hooks, context API, SVG
# rendering, hyphenated attributes, DOM properties, expression-as-text,
# computed/effect block bodies, and edge cases.

opts = { skipPreamble: true, skipRuntimes: true, skipDataPart: true }

# ==============================================================================
# Basic Rendering — elements and text nodes
# ==============================================================================

code "single element", '''
  export A = component
    render
      div
  ''', '''
  export const A = class extends __Component {
    _init(props) {}
    _create() {
      this._el0 = document.createElement('div');
      return this._el0;
    }
  }
  ''', opts

code "element with text child", '''
  export A = component
    render
      span "hello"
  ''', '''
  export const A = class extends __Component {
    _init(props) {}
    _create() {
      this._el0 = document.createElement('span');
      this._t0 = document.createTextNode("hello");
      this._el0.appendChild(this._t0);
      return this._el0;
    }
  }
  ''', opts

code "nested elements", '''
  export A = component
    render
      div
        span "inner"
  ''', '''
  export const A = class extends __Component {
    _init(props) {}
    _create() {
      this._el0 = document.createElement('div');
      this._el1 = document.createElement('span');
      this._t0 = document.createTextNode("inner");
      this._el1.appendChild(this._t0);
      this._el0.appendChild(this._el1);
      return this._el0;
    }
  }
  ''', opts

code "element with id", '''
  export A = component
