      this._el0 = document.createElement('div');
      this._t0 = document.createTextNode('');
      this._el0.appendChild(this._t0);
      return this._el0;
    }
    _setup() {
      __effect(() => { this._t0.data = this.title.value; });
    }
  }
  ''', opts

