# ==============================================================================
# Auto-allocated loop index never collides with a nested explicit index
# ==============================================================================
# Regression: an outer `for x in xs` (no explicit index) used to silently
# allocate `i`. An inner `for v, i in ys` then explicitly bound `i`, and both
# ended up as positional parameters of the deepest factory's patch function,
# producing `function p(ctx, v, i, item, i)` — strict-mode SyntaxError. The
# fix pre-scans the loop body for explicit descendant indices and skips any
# name that would collide.

code "outer auto-index avoids inner explicit `i`", '''
  export A = component
    items := [{options: [1, 2]}]
    render
      for item in items
        for v, i in item.options
          span "#{v}#{i}"
  ''', '''
  export const A = (() => {
  function create_block_1(ctx, v, i, item, j) {
    let _el2, _t0;
    let _factoryChildren = [];
    return {
   _s: true,
   c() {
     _el2 = document.createElement('span');
     _t0 = document.createTextNode(String(`${v}${i}`));
     _el2.appendChild(_t0);
     this._first = _el2;
   },
   m(target, anchor) {
