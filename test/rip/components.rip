# Scope-based disambiguation: a bare identifier that resolves to NOTHING in
# scope is boolean-attribute shorthand on a DOM element too (`form noValidate`).
code "bare-ident shorthand — unresolved name is a boolean attribute", '''
  export A = component
    render
      div outline
  ''', '''
  export const A = class extends __Component {
    _init(props) {
    }
    _create() {
      this._el0 = document.createElement('div');
      this._el0.setAttribute('outline', true);
      return this._el0;
    }
  }
  ''', opts

# But a bare identifier that DOES resolve to an in-scope value (here a member)
# renders as a text child — the common `span title` pattern, unchanged.
