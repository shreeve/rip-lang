# ============================================================================
# Component Tests
# ============================================================================

# ------------------------------------------------------------------------------
# Basic Component Structure
# ------------------------------------------------------------------------------

codeBody "minimal component", "component Hello\n  render\n    div", 'class Hello {\n  constructor(props = {}) {\n  }\n  render() { return h(\'div\', 0); }\n  mount(target) {\n    this._target = target;\n    this._dispose = __effect(() => {\n      const el = this.render();\n      if (this._el) this._el.replaceWith(el);\n      else target.appendChild(el);\n      this._el = el;\n    });\n    if (this.mounted) this.mounted();\n    return this;\n  }\n  unmount() {\n    if (this.unmounted) this.unmounted();\n    if (this._dispose) this._dispose();\n    if (this._el && this._el.parentNode) {\n      this._el.parentNode.removeChild(this._el);\n    }\n  }\n}'

codeBody "component with text", 'component Hello\n  render\n    div "Hello"', 'class Hello {\n  constructor(props = {}) {\n  }\n  render() { return h(\'div\', 0, "Hello"); }\n  mount(target) {\n    this._target = target;\n    this._dispose = __effect(() => {\n      const el = this.render();\n      if (this._el) this._el.replaceWith(el);\n      else target.appendChild(el);\n      this._el = el;\n    });\n    if (this.mounted) this.mounted();\n    return this;\n  }\n  unmount() {\n    if (this.unmounted) this.unmounted();\n    if (this._dispose) this._dispose();\n    if (this._el && this._el.parentNode) {\n      this._el.parentNode.removeChild(this._el);\n    }\n  }\n}'

# ------------------------------------------------------------------------------
# Component State
# ------------------------------------------------------------------------------

codeBody "component with state", "component Counter\n  count = 0\n  render\n    span count", 'class Counter {\n  constructor(props = {}) {\n    this.count = __signal(0);\n  }\n  render() { return h(\'span\', 0, this.count.value); }\n  mount(target) {\n    this._target = target;\n    this._dispose = __effect(() => {\n      const el = this.render();\n      if (this._el) this._el.replaceWith(el);\n      else target.appendChild(el);\n      this._el = el;\n    });\n    if (this.mounted) this.mounted();\n    return this;\n  }\n  unmount() {\n    if (this.unmounted) this.unmounted();\n    if (this._dispose) this._dispose();\n    if (this._el && this._el.parentNode) {\n      this._el.parentNode.removeChild(this._el);\n    }\n  }\n}'

codeBody "component with derived", "component Doubler\n  count = 1\n  doubled ~= count * 2\n  render\n    span doubled", 'class Doubler {\n  constructor(props = {}) {\n    this.count = __signal(1);\n    this.doubled = __computed(() => (this.count.value * 2));\n  }\n  render() { return h(\'span\', 0, this.doubled.value); }\n  mount(target) {\n    this._target = target;\n    this._dispose = __effect(() => {\n      const el = this.render();\n      if (this._el) this._el.replaceWith(el);\n      else target.appendChild(el);\n      this._el = el;\n    });\n    if (this.mounted) this.mounted();\n    return this;\n  }\n  unmount() {\n    if (this.unmounted) this.unmounted();\n    if (this._dispose) this._dispose();\n    if (this._el && this._el.parentNode) {\n      this._el.parentNode.removeChild(this._el);\n    }\n  }\n}'

