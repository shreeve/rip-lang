# ==============================================================================
# Event Handlers
# ==============================================================================

code "event handler with method reference", '''
  export A = component
    handleClick = -> p "clicked"
    render
      button @click: handleClick
  ''', '''
  export const A = class extends __Component {
    _init(props) {}
    handleClick() { return p("clicked"); }
    _create() {
      this._el0 = document.createElement('button');
      this._el0.addEventListener('click', (e) => __batch(() => this.handleClick(e)));
      return this._el0;
    }
  }
  ''', opts

