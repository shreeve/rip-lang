    _init(props) {
      this.x = __state(0);
      this.doubled = __computed(() => {
    let v;
    v = this.x.value * 2;
    return (v + 0);
  });
    }
    _create() {
      this._el0 = document.createElement('span');
      this._t0 = document.createTextNode('');
      this._el0.appendChild(this._t0);
      return this._el0;
    }
    _setup() {
      __effect(() => { this._t0.data = this.doubled.value; });
    }
  }
  ''', opts

