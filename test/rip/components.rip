codeBody "children prop", 'component Wrapper\n  @children?\n  render\n    div.wrapper @children', 'class Wrapper {\n  constructor(props = {}) {\n    this.children = props.children;\n  }\n  _create() {\n    this._el0 = document.createElement(\'div\');\n    this._el0.className = \'wrapper\';\n    this._slot1 = this.children instanceof Node ? this.children : (this.children != null ? document.createTextNode(String(this.children)) : document.createComment(\'\'));\n    this._el0.appendChild(this._slot1);\n    return this._el0;\n  }\n  mount(target) {\n    if (typeof target === \"string\") target = document.querySelector(target);\n    this._target = target;\n    this._root = this._create();\n    target.appendChild(this._root);\n    if (this._setup) this._setup();\n    if (this.mounted) this.mounted();\n    return this;\n  }\n  unmount() {\n    if (this.unmounted) this.unmounted();\n    if (this._root && this._root.parentNode) {\n      this._root.parentNode.removeChild(this._root);\n    }\n  }\n}'

