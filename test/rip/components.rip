codeBody "component with classes", "component Card\n  render\n    div.card.shadow", "class Card {\n  constructor(props = {}) {\n  }\n  _create() {\n    this._el0 = document.createElement('div');\n    this._el0.className = 'card shadow';\n    return this._el0;\n  }\n  mount(target) {\n    if (typeof target === \"string\") target = document.querySelector(target);\n    this._target = target;\n    this._root = this._create();\n    target.appendChild(this._root);\n    if (this._setup) this._setup();\n    if (this.mounted) this.mounted();\n    return this;\n  }\n  unmount() {\n    if (this.unmounted) this.unmounted();\n    if (this._root && this._root.parentNode) {\n      this._root.parentNode.removeChild(this._root);\n    }\n  }\n}"

codeBody "component with multiple roots", 'component Multi\n  render\n    div "One"\n    div "Two"', 'class Multi {\n  constructor(props = {}) {\n  }\n  _create() {\n    this._frag0 = document.createDocumentFragment();\n    this._el1 = document.createElement(\'div\');\n    this._t0 = document.createTextNode("One");\n    this._el1.appendChild(this._t0);\n    this._frag0.appendChild(this._el1);\n    this._el2 = document.createElement(\'div\');\n    this._t1 = document.createTextNode("Two");\n    this._el2.appendChild(this._t1);\n    this._frag0.appendChild(this._el2);\n    return this._frag0;\n  }\n  mount(target) {\n    if (typeof target === \"string\") target = document.querySelector(target);\n    this._target = target;\n    this._root = this._create();\n    target.appendChild(this._root);\n    if (this._setup) this._setup();\n    if (this.mounted) this.mounted();\n    return this;\n  }\n  unmount() {\n    if (this.unmounted) this.unmounted();\n    if (this._root && this._root.parentNode) {\n      this._root.parentNode.removeChild(this._root);\n    }\n  }\n}'

# ------------------------------------------------------------------------------
# Component Props
# ------------------------------------------------------------------------------

codeBody "required prop", "component Button\n  @label\n  render\n    button @label", 'class Button {\n  constructor(props = {}) {\n    if (props.label === undefined) throw new Error(\'Required prop: label\');\n    this.label = props.label;\n  }\n  _create() {\n    this._el0 = document.createElement(\'button\');\n    this._slot1 = this.label instanceof Node ? this.label : (this.label != null ? document.createTextNode(String(this.label)) : document.createComment(\'\'));\n    this._el0.appendChild(this._slot1);\n    return this._el0;\n  }\n  mount(target) {\n    if (typeof target === \"string\") target = document.querySelector(target);\n    this._target = target;\n    this._root = this._create();\n    target.appendChild(this._root);\n    if (this._setup) this._setup();\n    if (this.mounted) this.mounted();\n    return this;\n  }\n  unmount() {\n    if (this.unmounted) this.unmounted();\n    if (this._root && this._root.parentNode) {\n      this._root.parentNode.removeChild(this._root);\n    }\n  }\n}'

codeBody "optional prop", "component Card\n  @subtitle?\n  render\n    div", 'class Card {\n  constructor(props = {}) {\n    this.subtitle = props.subtitle;\n  }\n  _create() {\n    this._el0 = document.createElement(\'div\');\n    return this._el0;\n  }\n  mount(target) {\n    if (typeof target === \"string\") target = document.querySelector(target);\n    this._target = target;\n    this._root = this._create();\n    target.appendChild(this._root);\n    if (this._setup) this._setup();\n    if (this.mounted) this.mounted();\n    return this;\n  }\n  unmount() {\n    if (this.unmounted) this.unmounted();\n    if (this._root && this._root.parentNode) {\n      this._root.parentNode.removeChild(this._root);\n    }\n  }\n}'

codeBody "prop with default", 'component Button\n  @size = "md"\n  render\n    button', 'class Button {\n  constructor(props = {}) {\n    this.size = props.size ?? "md";\n  }\n  _create() {\n    this._el0 = document.createElement(\'button\');\n    return this._el0;\n  }\n  mount(target) {\n    if (typeof target === \"string\") target = document.querySelector(target);\n    this._target = target;\n    this._root = this._create();\n    target.appendChild(this._root);\n    if (this._setup) this._setup();\n    if (this.mounted) this.mounted();\n    return this;\n  }\n  unmount() {\n    if (this.unmounted) this.unmounted();\n    if (this._root && this._root.parentNode) {\n      this._root.parentNode.removeChild(this._root);\n    }\n  }\n}'

codeBody "rest props", "component Input\n  @label\n  @...rest\n  render\n    div", 'class Input {\n  constructor(props = {}) {\n    if (props.label === undefined) throw new Error(\'Required prop: label\');\n    this.label = props.label;\n    const { label, ...rest } = props;\n    this.rest = rest;\n  }\n  _create() {\n    this._el0 = document.createElement(\'div\');\n    return this._el0;\n  }\n  mount(target) {\n    if (typeof target === \"string\") target = document.querySelector(target);\n    this._target = target;\n    this._root = this._create();\n    target.appendChild(this._root);\n    if (this._setup) this._setup();\n    if (this.mounted) this.mounted();\n    return this;\n  }\n  unmount() {\n    if (this.unmounted) this.unmounted();\n    if (this._root && this._root.parentNode) {\n      this._root.parentNode.removeChild(this._root);\n    }\n  }\n}'

