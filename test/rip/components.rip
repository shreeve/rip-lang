# ==============================================================================
# Event Handlers
# ==============================================================================

code "event handler with method reference", '''
  export A = component
    handleClick = -> p "clicked"
    render
      button @click: handleClick
  ''', '''
  export const A = class extends __Component {
    _init(props) {}
    handleClick() { return p("clicked"); }
    _create() {
      this._el0 = document.createElement('button');
      this._el0.addEventListener('click', (e) => __batch(() => this.handleClick(e)));
      return this._el0;
    }
  }
  ''', opts

# ==============================================================================
# Auto-wired Event Handlers (on* convention)
# ==============================================================================

code "auto-wire onClick to root element", '''
  export A = component
    onClick: -> p "clicked"
    render
      button "Click me"
  ''', '''
  export const A = class extends __Component {
    _init(props) {}
    onClick() { return p("clicked"); }
    _create() {
      this._el0 = document.createElement('button');
      this._t0 = document.createTextNode("Click me");
      this._el0.appendChild(this._t0);
      this._el0.addEventListener('click', (e) => __batch(() => this.onClick(e)));
      return this._el0;
    }
  }
  ''', opts

code "auto-wire multiple on* methods", '''
  export A = component
    onClick: -> p "click"
    onKeydown: (e) -> p e.key
    render
      button "Press"
  ''', '''
  export const A = class extends __Component {
    _init(props) {}
    onClick() { return p("click"); }
    onKeydown(e) { return p(e.key); }
    _create() {
      this._el0 = document.createElement('button');
      this._t0 = document.createTextNode("Press");
      this._el0.appendChild(this._t0);
      this._el0.addEventListener('click', (e) => __batch(() => this.onClick(e)));
      this._el0.addEventListener('keydown', (e) => __batch(() => this.onKeydown(e)));
      return this._el0;
    }
  }
  ''', opts

code "explicit event on root overrides auto-wire", '''
  export A = component
    onClick: -> p "auto"
    toggle: -> p "explicit"
    render
      button @click: toggle
  ''', '''
  export const A = class extends __Component {
    _init(props) {}
    onClick() { return p("auto"); }
    toggle() { return p("explicit"); }
    _create() {
