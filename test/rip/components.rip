test "text output in switch loop with postfix if else compiles", '''
  A = component
    items := [{status: "ready"}]
    tab := "reports"
    render
      switch tab
        when "reports"
          div
            for report in items
              span
                = "Ready" if report.status is "ready" else "Processing"
        else
          div "Other"
  typeof A
''', "function"

test "text output in switch loop with attrs and postfix if else compiles", '''
  A = component
    items := [{status: "ready"}]
    tab := "reports"
    render
      switch tab
        when "reports"
          div
            for report in items
              span
                class: if report.status is "ready" then "a" else "b"
                = "Ready" if report.status is "ready" else "Processing"
        else
          div "Other"
  typeof A
''', "function"

test "uppercase loop iterable in render compiles as data, not component", '''
  A = component
    render
      div
        for report in RESULTS_REPORTS
          span
            = "Ready" if report.status is "ready" else "Processing"
  typeof A
''', "function"

# ==============================================================================
# Nested Structures — variable threading through block factories
# ==============================================================================

