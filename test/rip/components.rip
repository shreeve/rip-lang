# ==============================================================================
# Context API — setContext / getContext
# ==============================================================================

test "setContext and getContext via effect", '''
  result = null
  A = component
    theme =! "dark"
    ~>
      setContext("theme", @theme)
      result = getContext("theme")
  a = A.new()
  result
  ''', "dark"

test "getContext returns undefined when not set", '''
  A = component
    val =! getContext("missing")
  a = A.new()
  a.val
  ''', undefined

