code "static attribute", '''
  export A = component
    render
      input type: "text", placeholder: "name"
  ''', '''
  export const A = class extends __Component {
    _init(props) {}
    _create() {
      this._el0 = document.createElement('input');
      this._el0.setAttribute('type', "text");
      this._el0.setAttribute('placeholder', "name");
      return this._el0;
    }
  }
  ''', opts

code "boolean attribute", '''
  export A = component
    render
      input disabled: true
  ''', '''
  export const A = class extends __Component {
    _init(props) {}
    _create() {
      this._el0 = document.createElement('input');
      if (true) this._el0.setAttribute('disabled', '');
      return this._el0;
    }
  }
  ''', opts

# ==============================================================================
# Reactive Attributes — effect-based updates
# ==============================================================================

code "reactive attribute", '''
  export A = component
    href ~= "/home"
    render
      a href: href
  ''', '''
  export const A = class extends __Component {
    _init(props) {
      this.href = __computed(() => "/home");
    }
    _create() {
      this._el0 = document.createElement('a');
      return this._el0;
    }
    _setup() {
      __effect(() => { this._el0.setAttribute('href', this.href.value); });
    }
  }
  ''', opts

code "reactive boolean attribute", '''
  export A = component
    loading := true
    render
      button disabled: loading
  ''', '''
  export const A = class extends __Component {
    _init(props) {
      this.loading = __state(true);
    }
    _create() {
      this._el0 = document.createElement('button');
      return this._el0;
    }
    _setup() {
      __effect(() => { this._el0.toggleAttribute('disabled', !!this.loading.value); });
    }
  }
  ''', opts

