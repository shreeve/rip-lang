test "onError catches error from effect in _init", '''
  caught = null
  A = component
    onError = (err) -> caught = err.message
    ~> raise "boom"
  a = A.new()
  caught
  ''', "boom"

test "onError receives source component", '''
  source = null
  A = component
    onError = (err, comp) -> source = comp
    ~> raise "test"
  a = A.new()
  source is a
  ''', true

test "error without onError throws normally", '''
  threw = false
  A = component
    ~> raise "unhandled"
  try
    a = A.new()
  catch e
    threw = e.message
  threw
  ''', "unhandled"

test "onError on parent catches child error", '''
  caught = null
  Parent = component
    onError = (err, comp) -> caught = err.message
    ~> noop()
  Child = component
    ~> raise "child boom"
  p = Parent.new()
  __pushComponent(p)
  c = Child.new()
  __popComponent(null)
  caught
  ''', "child boom"

