# Test: Component System
# Tests render blocks, conditional/loop codegen, block factories,
# attributes, events, bindings, child components, and edge cases.

opts = { skipPreamble: true, skipRuntimes: true }

# ==============================================================================
# Basic Rendering — elements and text nodes
# ==============================================================================

code "single element", '''
  export A = component
    render
      div
  ''', '''
  export const A = class extends __Component {
    _init(props) {}
    _create() {
      this._el0 = document.createElement('div');
      return this._el0;
    }
  }
  ''', opts

code "element with text child", '''
  export A = component
    render
      span "hello"
  ''', '''
  export const A = class extends __Component {
    _init(props) {}
    _create() {
      this._el0 = document.createElement('span');
      this._t0 = document.createTextNode("hello");
      this._el0.appendChild(this._t0);
      return this._el0;
    }
  }
  ''', opts

code "nested elements", '''
  export A = component
    render
      div
        span "inner"
  ''', '''
  export const A = class extends __Component {
    _init(props) {}
    _create() {
      this._el0 = document.createElement('div');
      this._el1 = document.createElement('span');
      this._t0 = document.createTextNode("inner");
      this._el1.appendChild(this._t0);
      this._el0.appendChild(this._el1);
      return this._el0;
    }
  }
  ''', opts

code "element with id", '''
  export A = component
    render
      div#main
  ''', '''
  export const A = class extends __Component {
    _init(props) {}
    _create() {
      this._el0 = document.createElement('div');
      this._el0.id = 'main';
      return this._el0;
    }
  }
  ''', opts

code "element with static class", '''
  export A = component
    render
      div.card
  ''', '''
  export const A = class extends __Component {
    _init(props) {}
    _create() {
      this._el0 = document.createElement('div');
      this._el0.className = 'card';
      return this._el0;
    }
  }
  ''', opts

code "element with multiple classes", '''
  export A = component
    render
      div.card.active
  ''', '''
  export const A = class extends __Component {
    _init(props) {}
    _create() {
      this._el0 = document.createElement('div');
      this._el0.className = 'card active';
      return this._el0;
    }
  }
  ''', opts

# ==============================================================================
# Fragment roots — multiple top-level render elements
# ==============================================================================

code "fragment root", '''
  export A = component
    render
      span "a"
      span "b"
  ''', '''
  export const A = class extends __Component {
    _init(props) {}
    _create() {
      this._frag0 = document.createDocumentFragment();
      this._el1 = document.createElement('span');
      this._t0 = document.createTextNode("a");
      this._el1.appendChild(this._t0);
      this._frag0.appendChild(this._el1);
      this._el2 = document.createElement('span');
      this._t1 = document.createTextNode("b");
      this._el2.appendChild(this._t1);
      this._frag0.appendChild(this._el2);
      return this._frag0;
    }
  }
  ''', opts

# ==============================================================================
# Static Attributes
# ==============================================================================

code "static attribute", '''
  export A = component
    render
      input type: "text", placeholder: "name"
  ''', '''
  export const A = class extends __Component {
    _init(props) {}
    _create() {
      this._el0 = document.createElement('input');
      this._el0.setAttribute('type', "text");
      this._el0.setAttribute('placeholder', "name");
      return this._el0;
    }
  }
  ''', opts

code "boolean attribute", '''
  export A = component
    render
      input disabled: true
  ''', '''
  export const A = class extends __Component {
    _init(props) {}
    _create() {
      this._el0 = document.createElement('input');
      if (true) this._el0.setAttribute('disabled', '');
      return this._el0;
    }
  }
  ''', opts

# ==============================================================================
# Reactive Attributes — effect-based updates
# ==============================================================================

code "reactive attribute", '''
  export A = component
    href ~= "/home"
    render
      a href: href
  ''', '''
  export const A = class extends __Component {
    _init(props) {
      this.href = __computed(() => "/home");
    }
    _create() {
      this._el0 = document.createElement('a');
      return this._el0;
    }
    _setup() {
      __effect(() => { this._el0.setAttribute('href', this.href.value); });
    }
  }
  ''', opts

code "reactive boolean attribute", '''
  export A = component
    loading := true
    render
      button disabled: loading
  ''', '''
  export const A = class extends __Component {
    _init(props) {
      this.loading = __state(true);
    }
    _create() {
      this._el0 = document.createElement('button');
      return this._el0;
    }
    _setup() {
      __effect(() => { this._el0.toggleAttribute('disabled', !!this.loading.value); });
    }
  }
  ''', opts

# ==============================================================================
# Reactive Text
# ==============================================================================

code "reactive text node", '''
  export A = component
    name := "world"
    render
      span name
  ''', '''
  export const A = class extends __Component {
    _init(props) {
      this.name = __state("world");
    }
    _create() {
      this._el0 = document.createElement('span');
      this._t0 = document.createTextNode('');
      this._el0.appendChild(this._t0);
      return this._el0;
    }
    _setup() {
      __effect(() => { this._t0.data = this.name.value; });
    }
  }
  ''', opts

# ==============================================================================
# Conditional Rendering — if/else block factories
# ==============================================================================

code "simple conditional", '''
  export A = component
    show := true
    render
      if show
        span "yes"
  ''', '''
  export const A = (() => {
  function create_block_0(ctx) {
    let _el1, _t0;
    return {
      c() {
        _el1 = document.createElement('span');
        _t0 = document.createTextNode("yes");
        _el1.appendChild(_t0);
      },
      m(target, anchor) {
        if (target) target.insertBefore(_el1, anchor);
      },
      p(ctx) {},
      d(detaching) {
        if (detaching && _el1) _el1.remove();
      }
    };
  }

  return class extends __Component {
    _init(props) {
      this.show = __state(true);
    }
    _create() {
      this._anchor0 = document.createComment('if');
      return this._anchor0;
    }
    _setup() {
      // Conditional: create_block_0
      {
        const anchor = this._anchor0;
        let currentBlock = null;
        let showing = null;
        __effect(() => {
          const show = !!(this.show.value);
          const want = show ? 'then' : null;
          if (want === showing) return;
          if (currentBlock) {
            currentBlock.d(true);
            currentBlock = null;
          }
          showing = want;
          if (want === 'then') {
            currentBlock = create_block_0(this);
            currentBlock.c();
            if (anchor.parentNode) currentBlock.m(anchor.parentNode, anchor.nextSibling);
            currentBlock.p(this);
          }
        });
      }
    }
  };
  })()
  ''', opts

code "if-else conditional", '''
  export A = component
    show := true
    render
      if show
        span "yes"
      else
        span "no"
  ''', '''
  export const A = (() => {
  function create_block_0(ctx) {
    let _el1, _t0;
    return {
      c() {
        _el1 = document.createElement('span');
        _t0 = document.createTextNode("yes");
        _el1.appendChild(_t0);
      },
      m(target, anchor) {
        if (target) target.insertBefore(_el1, anchor);
      },
      p(ctx) {},
      d(detaching) {
        if (detaching && _el1) _el1.remove();
      }
    };
  }

  function create_block_1(ctx) {
    let _el2, _t1;
    return {
      c() {
        _el2 = document.createElement('span');
        _t1 = document.createTextNode("no");
        _el2.appendChild(_t1);
      },
      m(target, anchor) {
        if (target) target.insertBefore(_el2, anchor);
      },
      p(ctx) {},
      d(detaching) {
        if (detaching && _el2) _el2.remove();
      }
    };
  }

  return class extends __Component {
    _init(props) {
      this.show = __state(true);
    }
    _create() {
      this._anchor0 = document.createComment('if');
      return this._anchor0;
    }
    _setup() {
      // Conditional: create_block_0 / create_block_1
      {
        const anchor = this._anchor0;
        let currentBlock = null;
        let showing = null;
        __effect(() => {
          const show = !!(this.show.value);
          const want = show ? 'then' : 'else';
          if (want === showing) return;
          if (currentBlock) {
            currentBlock.d(true);
            currentBlock = null;
          }
          showing = want;
          if (want === 'then') {
            currentBlock = create_block_0(this);
            currentBlock.c();
            if (anchor.parentNode) currentBlock.m(anchor.parentNode, anchor.nextSibling);
            currentBlock.p(this);
          }
          if (want === 'else') {
            currentBlock = create_block_1(this);
            currentBlock.c();
            if (anchor.parentNode) currentBlock.m(anchor.parentNode, anchor.nextSibling);
            currentBlock.p(this);
          }
        });
      }
    }
  };
  })()
  ''', opts

# ==============================================================================
# Loop Rendering — for...in block factories
# ==============================================================================

code "simple loop", '''
  export A = component
    items := [1, 2, 3]
    render
      for item in items
        span item
  ''', '''
  export const A = (() => {
  function create_block_0(ctx, item, i) {
    let _el1, _t0;
    return {
      c() {
        _el1 = document.createElement('span');
        _t0 = document.createTextNode(item);
        _el1.appendChild(_t0);
      },
      m(target, anchor) {
        if (target) target.insertBefore(_el1, anchor);
      },
      p(ctx, item, i) {},
      d(detaching) {
        if (detaching && _el1) _el1.remove();
      }
    };
  }

  return class extends __Component {
    _init(props) {
      this.items = __state([1, 2, 3]);
    }
    _create() {
      this._anchor0 = document.createComment('for');
      return this._anchor0;
    }
    _setup() {
      // Loop: create_block_0
      {
        const __anchor = this._anchor0;
        const __map = new Map();
        __effect(() => {
          const __items = this.items.value;
          const __parent = __anchor.parentNode;
          const __newMap = new Map();
          for (let i = 0; i < __items.length; i++) {
            const item = __items[i];
            const __key = item;
            let __block = __map.get(__key);
            if (!__block) {
              __block = create_block_0(this, item, i);
              __block.c();
            }
            __block.m(__parent, __anchor);
            __block.p(this, item, i);
            __newMap.set(__key, __block);
          }
          for (const [__k, __b] of __map) {
            if (!__newMap.has(__k)) __b.d(true);
          }
          __map.clear();
          for (const [__k, __v] of __newMap) __map.set(__k, __v);
        });
      }
    }
  };
  })()
  ''', opts

# ==============================================================================
# Nested Structures — variable threading through block factories
# ==============================================================================

code "conditional inside loop threads loop vars", '''
  export A = component
    items := [{active: true}]
    render
      for item, i in items
        if item.active
          span "yes"
  ''', '''
  export const A = (() => {
  function create_block_1(ctx, item, i) {
    let _el2, _t0;
    return {
      c() {
        _el2 = document.createElement('span');
        _t0 = document.createTextNode("yes");
        _el2.appendChild(_t0);
      },
      m(target, anchor) {
        if (target) target.insertBefore(_el2, anchor);
      },
      p(ctx, item, i) {},
      d(detaching) {
        if (detaching && _el2) _el2.remove();
      }
    };
  }

  function create_block_0(ctx, item, i) {
    let _anchor1;
    let disposers = [];
    return {
      c() {
        _anchor1 = document.createComment('if');
      },
      m(target, anchor) {
        if (target) target.insertBefore(_anchor1, anchor);
      },
      p(ctx, item, i) {
        disposers.forEach(d => d());
        disposers = [];
        // Conditional: create_block_1
        {
          const anchor = _anchor1;
          let currentBlock = null;
          let showing = null;
          disposers.push(__effect(() => {
            const show = !!(item.active);
            const want = show ? 'then' : null;
            if (want === showing) return;
            if (currentBlock) {
              currentBlock.d(true);
              currentBlock = null;
            }
            showing = want;
            if (want === 'then') {
              currentBlock = create_block_1(ctx, item, i);
              currentBlock.c();
              if (anchor.parentNode) currentBlock.m(anchor.parentNode, anchor.nextSibling);
              currentBlock.p(ctx, item, i);
            }
          }));
        }
      },
      d(detaching) {
        disposers.forEach(d => d());
        if (detaching && _anchor1) _anchor1.remove();
      }
    };
  }

  return class extends __Component {
    _init(props) {
      this.items = __state([{active: true}]);
    }
    _create() {
      this._anchor0 = document.createComment('for');
      return this._anchor0;
    }
    _setup() {
      // Loop: create_block_0
      {
        const __anchor = this._anchor0;
        const __map = new Map();
        __effect(() => {
          const __items = this.items.value;
          const __parent = __anchor.parentNode;
          const __newMap = new Map();
          for (let i = 0; i < __items.length; i++) {
            const item = __items[i];
            const __key = item;
            let __block = __map.get(__key);
            if (!__block) {
              __block = create_block_0(this, item, i);
              __block.c();
            }
            __block.m(__parent, __anchor);
            __block.p(this, item, i);
            __newMap.set(__key, __block);
          }
          for (const [__k, __b] of __map) {
            if (!__newMap.has(__k)) __b.d(true);
          }
          __map.clear();
          for (const [__k, __v] of __newMap) __map.set(__k, __v);
        });
      }
    }
  };
  })()
  ''', opts

code "nested loops thread outer vars", '''
  export A = component
    rows := [[1, 2]]
    render
      for row, ri in rows
        for cell, ci in row
          span cell
  ''', '''
  export const A = (() => {
  function create_block_1(ctx, cell, ci, row, ri) {
    let _el2, _t0;
    return {
      c() {
        _el2 = document.createElement('span');
        _t0 = document.createTextNode(cell);
        _el2.appendChild(_t0);
      },
      m(target, anchor) {
        if (target) target.insertBefore(_el2, anchor);
      },
      p(ctx, cell, ci, row, ri) {},
      d(detaching) {
        if (detaching && _el2) _el2.remove();
      }
    };
  }

  function create_block_0(ctx, row, ri) {
    let _anchor1;
    let disposers = [];
    return {
      c() {
        _anchor1 = document.createComment('for');
      },
      m(target, anchor) {
        if (target) target.insertBefore(_anchor1, anchor);
      },
      p(ctx, row, ri) {
        disposers.forEach(d => d());
        disposers = [];
        // Loop: create_block_1
        {
          const __anchor = _anchor1;
          const __map = new Map();
          disposers.push(__effect(() => {
            const __items = row;
            const __parent = __anchor.parentNode;
            const __newMap = new Map();
            for (let ci = 0; ci < __items.length; ci++) {
              const cell = __items[ci];
              const __key = cell;
              let __block = __map.get(__key);
              if (!__block) {
                __block = create_block_1(ctx, cell, ci, row, ri);
                __block.c();
              }
              __block.m(__parent, __anchor);
              __block.p(ctx, cell, ci, row, ri);
              __newMap.set(__key, __block);
            }
            for (const [__k, __b] of __map) {
              if (!__newMap.has(__k)) __b.d(true);
            }
            __map.clear();
            for (const [__k, __v] of __newMap) __map.set(__k, __v);
          }));
        }
      },
      d(detaching) {
        disposers.forEach(d => d());
        if (detaching && _anchor1) _anchor1.remove();
      }
    };
  }

  return class extends __Component {
    _init(props) {
      this.rows = __state([[1, 2]]);
    }
    _create() {
      this._anchor0 = document.createComment('for');
      return this._anchor0;
    }
    _setup() {
      // Loop: create_block_0
      {
        const __anchor = this._anchor0;
        const __map = new Map();
        __effect(() => {
          const __items = this.rows.value;
          const __parent = __anchor.parentNode;
          const __newMap = new Map();
          for (let ri = 0; ri < __items.length; ri++) {
            const row = __items[ri];
            const __key = row;
            let __block = __map.get(__key);
            if (!__block) {
              __block = create_block_0(this, row, ri);
              __block.c();
            }
            __block.m(__parent, __anchor);
            __block.p(this, row, ri);
            __newMap.set(__key, __block);
          }
          for (const [__k, __b] of __map) {
            if (!__newMap.has(__k)) __b.d(true);
          }
          __map.clear();
          for (const [__k, __v] of __newMap) __map.set(__k, __v);
        });
      }
    }
  };
  })()
  ''', opts

