# ==============================================================================
# LIS Algorithm — __lis runtime correctness
# ==============================================================================

test "lis: empty array", '''
  X = component
    noop()
  __lis([])
  ''', []

test "lis: single element", '''
  X = component
    noop()
  __lis([0])
  ''', [0]

test "lis: already sorted", '''
  X = component
    noop()
  __lis([0, 1, 2, 3])
  ''', [0, 1, 2, 3]

test "lis: reversed", '''
  X = component
    noop()
  __lis([3, 2, 1, 0]).length
  ''', 1

test "lis: with new items (-1)", '''
  X = component
    noop()
  __lis([0, -1, 1, -1, 2])
  ''', [0, 2, 4]

test "lis: swap first and last", '''
  X = component
    noop()
  result = __lis([3, 1, 2, 0])
  result.length
  ''', 2

test "lis: interleaved", '''
  X = component
    noop()
  __lis([1, 0, 3, 2])
  ''', [1, 3]

# ==============================================================================
# Reconciliation — component state with loops (no DOM needed)
# ==============================================================================

test "loop component state access", '''
  A = component
    items := [1, 2, 3]
  a = A.new()
  a.items.value
  ''', [1, 2, 3]

test "loop component state mutation", '''
  A = component
    items := [1, 2, 3]
  a = A.new()
  a.items.value = [4, 5]
  a.items.value
  ''', [4, 5]

test "loop component computed from items", '''
  A = component
    items := [1, 2, 3]
    count ~= items.length
  a = A.new()
  a.count.value
  ''', 3

test "loop component computed reacts to items change", '''
  A = component
    items := [1, 2, 3]
    count ~= items.length
  a = A.new()
  a.items.value = [1, 2, 3, 4, 5]
  a.count.value
  ''', 5

# ==============================================================================
# Error Boundaries — onError lifecycle hook
# ==============================================================================

test "onError catches error from effect in _init", '''
  caught = null
  A = component
    onError = (err) -> caught = err.message
    ~> raise "boom"
  a = A.new()
  caught
  ''', "boom"

test "onError receives source component", '''
  source = null
  A = component
    onError = (err, comp) -> source = comp
    ~> raise "test"
  a = A.new()
  source is a
  ''', true

test "error without onError throws normally", '''
  threw = false
  A = component
    ~> raise "unhandled"
  try
    a = A.new()
  catch e
    threw = e.message
  threw
  ''', "unhandled"

test "onError on parent catches child error", '''
  caught = null
  Parent = component
    onError = (err, comp) -> caught = err.message
    ~> noop()
  Child = component
    ~> raise "child boom"
  p = Parent.new()
  __pushComponent(p)
  c = Child.new()
  __popComponent(null)
  caught
  ''', "child boom"

