# ============================================================================
# Component Tests - Fine-Grained Rendering
# ============================================================================

# ------------------------------------------------------------------------------
# Basic Component Structure
# ------------------------------------------------------------------------------

codeBody "minimal component", "component Hello\n  render\n    div", 'class Hello {\n  constructor(props = {}) {\n  }\n  _create() {\n    this._el0 = document.createElement(\'div\');\n    return this._el0;\n  }\n  mount(target) {\n    if (typeof target === \"string\") target = document.querySelector(target);\n    this._target = target;\n    this._root = this._create();\n    target.appendChild(this._root);\n    if (this._setup) this._setup();\n    if (this.mounted) this.mounted();\n    return this;\n  }\n  unmount() {\n    if (this.unmounted) this.unmounted();\n    if (this._root && this._root.parentNode) {\n      this._root.parentNode.removeChild(this._root);\n    }\n  }\n}'

codeBody "component with text", 'component Hello\n  render\n    div "Hello"', 'class Hello {\n  constructor(props = {}) {\n  }\n  _create() {\n    this._el0 = document.createElement(\'div\');\n    this._t0 = document.createTextNode("Hello");\n    this._el0.appendChild(this._t0);\n    return this._el0;\n  }\n  mount(target) {\n    if (typeof target === \"string\") target = document.querySelector(target);\n    this._target = target;\n    this._root = this._create();\n    target.appendChild(this._root);\n    if (this._setup) this._setup();\n    if (this.mounted) this.mounted();\n    return this;\n  }\n  unmount() {\n    if (this.unmounted) this.unmounted();\n    if (this._root && this._root.parentNode) {\n      this._root.parentNode.removeChild(this._root);\n    }\n  }\n}'

# ------------------------------------------------------------------------------
# Component State - Fine-Grained Updates
# ------------------------------------------------------------------------------

codeBody "component with state", "component Counter\n  count = 0\n  render\n    span count", 'class Counter {\n  constructor(props = {}) {\n    this.count = __state(0);\n  }\n  _create() {\n    this._el0 = document.createElement(\'span\');\n    this._t0 = document.createTextNode(\'\');\n    this._el0.appendChild(this._t0);\n    return this._el0;\n  }\n  _setup() {\n    __effect(() => { this._t0.data = this.count.value; });\n  }\n  mount(target) {\n    if (typeof target === \"string\") target = document.querySelector(target);\n    this._target = target;\n    this._root = this._create();\n    target.appendChild(this._root);\n    if (this._setup) this._setup();\n    if (this.mounted) this.mounted();\n    return this;\n  }\n  unmount() {\n    if (this.unmounted) this.unmounted();\n    if (this._root && this._root.parentNode) {\n      this._root.parentNode.removeChild(this._root);\n    }\n  }\n}'

codeBody "component with computed", "component Doubler\n  count = 1\n  doubled ~= count * 2\n  render\n    span doubled", 'class Doubler {\n  constructor(props = {}) {\n    this.count = __state(1);\n    this.doubled = __computed(() => (this.count.value * 2));\n  }\n  _create() {\n    this._el0 = document.createElement(\'span\');\n    this._t0 = document.createTextNode(\'\');\n    this._el0.appendChild(this._t0);\n    return this._el0;\n  }\n  _setup() {\n    __effect(() => { this._t0.data = this.doubled.value; });\n  }\n  mount(target) {\n    if (typeof target === \"string\") target = document.querySelector(target);\n    this._target = target;\n    this._root = this._create();\n    target.appendChild(this._root);\n    if (this._setup) this._setup();\n    if (this.mounted) this.mounted();\n    return this;\n  }\n  unmount() {\n    if (this.unmounted) this.unmounted();\n    if (this._root && this._root.parentNode) {\n      this._root.parentNode.removeChild(this._root);\n    }\n  }\n}'

