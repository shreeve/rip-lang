codeBody "component in render", 'component App\n  render\n    div\n      Button label: "Click"', 'class App {\n  constructor(props = {}) {\n  }\n  _create() {\n    this._el0 = document.createElement(\'div\');\n    this._inst1 = new Button({ label: "Click" });\n    this._el2 = this._inst1._create();\n    this._el0.appendChild(this._el2);\n    return this._el0;\n  }\n  _setup() {\n    if (this._inst1._setup) this._inst1._setup();\n  }\n  mount(target) {\n    if (typeof target === \"string\") target = document.querySelector(target);\n    this._target = target;\n    this._root = this._create();\n    target.appendChild(this._root);\n    if (this._setup) this._setup();\n    if (this.mounted) this.mounted();\n    return this;\n  }\n  unmount() {\n    if (this.unmounted) this.unmounted();\n    if (this._root && this._root.parentNode) {\n      this._root.parentNode.removeChild(this._root);\n    }\n  }\n}'

