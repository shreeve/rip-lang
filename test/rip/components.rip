# ==============================================================================
# String Content in Factories — the "this works" regression test
# ==============================================================================

code "string containing 'this' in conditional factory", '''
  export A = component
    show := true
    render
      if show
        span "this works"
  ''', '''
  export const A = (() => {
  function create_block_0(ctx) {
    let _el1, _t0;
    let _factoryChildren = [];
    return {
   c() {
     _el1 = document.createElement('span');
     _t0 = document.createTextNode("this works");
     _el1.appendChild(_t0);
     this._first = _el1;
   },
   m(target, anchor) {
     if (target) target.insertBefore(_el1, anchor);
   },
   p(ctx) {
   },
   d(detaching) {
     for (const __c of _factoryChildren) { try { __c.unmount?.({removeDOM: detaching}); } catch (__e) { console.error('[Rip] factory child unmount error:', __e); } }
     _factoryChildren = [];
     if (detaching) __detach(_el1);
   }
    };
  }

  return class extends __Component {
    _init(props) {
   this.show = __state(true);
    }
    _create() {
   this._anchor0 = document.createComment('if');
   return this._anchor0;
    }
    _setup() {
   // Conditional: create_block_0
   {
     const anchor = this._anchor0;
     let currentBlock = null;
     let showing = null;
     __effect(() => {
       const show = !!(this.show.value);
       const want = show ? 'then' : null;
       if (want === showing) return;

       if (currentBlock) {
         const leaving = currentBlock;
         if (leaving._t) { __transition(leaving._first, leaving._t, 'leave', () => leaving.d(true)); }
         else { leaving.d(true); }
         currentBlock = null;
       }
       showing = want;

       if (want === 'then') {
         currentBlock = create_block_0(this);
         currentBlock.c();
         if (anchor.parentNode) currentBlock.m(anchor.parentNode, anchor.nextSibling);
         currentBlock.p(this);
         if (currentBlock._t) __transition(currentBlock._first, currentBlock._t, 'enter');
       }
     });
     { const __cur = globalThis.__ripComponent?.__getCurrentComponent?.(); if (__cur) (__cur._disposers ??= []).push(() => { if (currentBlock) { currentBlock.d(true); currentBlock = null; } }); }
   }
    }
  };
  })();
  ''', opts

code "string containing 'this' in loop factory", '''
  export A = component
    items := [1]
    render
      for item in items
        span "this also works"
  ''', '''
  export const A = (() => {
  function create_block_0(ctx, item, i) {
    let _el1, _t0;
    let _factoryChildren = [];
    return {
   _s: true,
   c() {
     _el1 = document.createElement('span');
     _t0 = document.createTextNode("this also works");
     _el1.appendChild(_t0);
     this._first = _el1;
   },
   m(target, anchor) {
     if (target) target.insertBefore(_el1, anchor);
   },
   p(ctx, item, i) {
   },
   d(detaching) {
     for (const __c of _factoryChildren) { try { __c.unmount?.({removeDOM: detaching}); } catch (__e) { console.error('[Rip] factory child unmount error:', __e); } }
     _factoryChildren = [];
     if (detaching) __detach(_el1);
   }
    };
  }

  return class extends __Component {
    _init(props) {
   this.items = __state([1]);
    }
    _create() {
   this._anchor0 = document.createComment('for');
   return this._anchor0;
    }
    _setup() {
   // Loop: create_block_0
   {
     const __s = { blocks: [], keys: [] };
     __effect(() => {
       __reconcile(this._anchor0, __s, this.items.value, this, create_block_0, null);
     });
     { const __cur = globalThis.__ripComponent?.__getCurrentComponent?.(); if (__cur) (__cur._disposers ??= []).push(() => { for (const __b of __s.blocks) { try { __b.d(true); } catch {} } __s.blocks = []; __s.keys = []; __s.items = []; }); }
   }
    }
  };
  })();
  ''', opts

# ==============================================================================
# Event Handlers
# ==============================================================================

code "event handler with method reference", '''
  export A = component
    handleClick = -> p "clicked"
    render
      button @click: handleClick
  ''', '''
  export const A = class extends __Component {
    _init(props) {}
    handleClick() { return p("clicked"); }
    _create() {
      this._el0 = document.createElement('button');
      this._el0.addEventListener('click', (e) => __batch(() => this.handleClick(e)));
      return this._el0;
    }
  }
  ''', opts

# ==============================================================================
# Auto-wired Event Handlers (on* convention)
# ==============================================================================

code "auto-wire onClick to root element", '''
  export A = component
    onClick: -> p "clicked"
    render
      button "Click me"
  ''', '''
  export const A = class extends __Component {
    _init(props) {}
    onClick() { return p("clicked"); }
    _create() {
      this._el0 = document.createElement('button');
      this._t0 = document.createTextNode("Click me");
      this._el0.appendChild(this._t0);
      this._el0.addEventListener('click', (e) => __batch(() => this.onClick(e)));
      return this._el0;
    }
  }
  ''', opts

code "auto-wire multiple on* methods", '''
  export A = component
    onClick: -> p "click"
    onKeydown: (e) -> p e.key
    render
      button "Press"
  ''', '''
  export const A = class extends __Component {
    _init(props) {}
    onClick() { return p("click"); }
    onKeydown(e) { return p(e.key); }
    _create() {
      this._el0 = document.createElement('button');
      this._t0 = document.createTextNode("Press");
      this._el0.appendChild(this._t0);
      this._el0.addEventListener('click', (e) => __batch(() => this.onClick(e)));
      this._el0.addEventListener('keydown', (e) => __batch(() => this.onKeydown(e)));
      return this._el0;
    }
  }
  ''', opts

code "explicit event on root overrides auto-wire", '''
  export A = component
    onClick: -> p "auto"
    toggle: -> p "explicit"
    render
      button @click: toggle
  ''', '''
  export const A = class extends __Component {
    _init(props) {}
    onClick() { return p("auto"); }
    toggle() { return p("explicit"); }
    _create() {
      this._el0 = document.createElement('button');
      this._el0.addEventListener('click', (e) => __batch(() => this.toggle(e)));
      return this._el0;
    }
  }
  ''', opts

code "partial override — one overridden, one auto-wired", '''
  export A = component
    onClick: -> p "auto-click"
    onKeydown: -> p "auto-key"
    ring: -> p "ring"
    render
      button @keydown: ring
  ''', '''
  export const A = class extends __Component {
    _init(props) {}
    onClick() { return p("auto-click"); }
    onKeydown() { return p("auto-key"); }
    ring() { return p("ring"); }
    _create() {
      this._el0 = document.createElement('button');
      this._el0.addEventListener('keydown', (e) => __batch(() => this.ring(e)));
      this._el0.addEventListener('click', (e) => __batch(() => this.onClick(e)));
      return this._el0;
    }
  }
  ''', opts

code "onError is not auto-wired (lifecycle hook)", '''
  export A = component
    onError: (e) -> p e.message
    render
      div "safe"
  ''', '''
  export const A = class extends __Component {
    _init(props) {}
    onError(e) { return p(e.message); }
    _create() {
      this._el0 = document.createElement('div');
      this._t0 = document.createTextNode("safe");
      this._el0.appendChild(this._t0);
      return this._el0;
    }
  }
  ''', opts

code "no auto-wire for non-on* methods", '''
  export A = component
    handleClick: -> p "hi"
    render
      button "Go"
  ''', '''
  export const A = class extends __Component {
    _init(props) {}
    handleClick() { return p("hi"); }
    _create() {
      this._el0 = document.createElement('button');
      this._t0 = document.createTextNode("Go");
      this._el0.appendChild(this._t0);
      return this._el0;
    }
  }
  ''', opts

code "auto-wire with nested children", '''
  export A = component
    onClick: -> p "clicked"
    render
      div
        span "inner"
  ''', '''
  export const A = class extends __Component {
    _init(props) {}
    onClick() { return p("clicked"); }
    _create() {
      this._el0 = document.createElement('div');
      this._el1 = document.createElement('span');
      this._t0 = document.createTextNode("inner");
      this._el1.appendChild(this._t0);
      this._el0.appendChild(this._el1);
      this._el0.addEventListener('click', (e) => __batch(() => this.onClick(e)));
      return this._el0;
    }
  }
  ''', opts

