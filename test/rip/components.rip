# ==============================================================================
# Component Runtime Behavior — test execution (no DOM needed)
# ==============================================================================

test "component state access", '''
  A = component
    x := 5
  a = A.new()
  a.x.value
  ''', 5

test "component state mutation", '''
  A = component
    x := 10
  a = A.new()
  a.x.value = 20
  a.x.value
  ''', 20

test "component computed", '''
  A = component
    x := 3
    doubled ~= x * 2
  a = A.new()
  a.doubled.value
  ''', 6

test "component computed reacts to state change", '''
  A = component
    x := 3
    doubled ~= x * 2
  a = A.new()
  a.x.value = 10
  a.doubled.value
  ''', 20

test "component method", '''
  A = component
    x := 0
    inc = -> @x += 1
  a = A.new()
  a.inc()
  a.x.value
  ''', 1

test "component readonly prop with default", '''
  A = component
    @label =! "default"
  a = A.new()
  a.label
  ''', "default"

test "component readonly prop from constructor", '''
  A = component
    @label =! "default"
  a = A.new({ label: "custom" })
  a.label
  ''', "custom"

test "component public state from constructor", '''
  A = component
    @count := 0
  a = A.new({ count: 42 })
  a.count.value
  ''', 42

test "extends collects unknown props into _rest", '''
  A = component extends input
    @label := ""
    render
      input
  a = A.new({ label: "x", autofocus: true, maxlength: 10 })
  [a._rest.autofocus, a._rest.maxlength, a._rest.label?]
  ''', [true, 10, false]

test "extends rest props can be updated", '''
  A = component extends input
    render
      input
  a = A.new({ autofocus: true })
  a._setRestProp("maxlength", 25)
  a._rest.maxlength
  ''', 25

# `@rest` is exposed as a reactive Signal whose value is the live `_rest`
# bag. Reads in computeds/effects track it; `_setRestProp` calls
# `this.rest.touch()` so reactive consumers re-fire on parent prop changes.
test "extends exposes @rest as reactive signal", '''
  A = component extends button
    render
      button
  a = A.new({ disabled: true, "data-id": "x1" })
  [typeof a.rest, a.rest.value.disabled, a.rest.value["data-id"]]
  ''', ["object", true, "x1"]

# The class-merge pattern: a computed reads `@rest.class` and concatenates
# it with component-controlled parts. The computed re-evaluates when the
# parent updates the `class` prop via `_setRestProp`. Returning an array
# (rather than a joined string) lets the `class:` runtime flatten via
# __clsx, so parents can pass strings, arrays, or {name: bool} objects.
test "extends class-merge pattern via @rest in computed", '''
  A = component extends button
    @variant?:: 'primary' | 'secondary' := 'primary'
    classes ~=
      parts = []
      parts.push 'secondary' if @variant is 'secondary'
      parts.push @rest.class
      parts
    render
      button
        class: classes
  a = A.new({ variant: 'secondary', class: 'mt-4' })
  before = a.classes.value.slice()
  a._setRestProp('class', ['mb-2', 'mt-4'])
  [before, a.classes.value]
  ''', [['secondary', 'mt-4'], ['secondary', ['mb-2', 'mt-4']]]

# `?` on a prop name is the sole optionality marker.
# `:=` only assigns a default; it no longer implies optionality.
test "optional typed prop without default omitted by caller is undefined at runtime", '''
  A = component
    @label?:: string
    render
      span
  a = A.new()
  a._init({})
  a.label.value
''', undefined

test "optional typed prop without default accepts a value", '''
  A = component
    @label?:: string
    render
      span
  a = A.new(label: "hi")
  a._init(label: "hi")
  a.label.value
''', "hi"

test "optional typed prop with default falls back when omitted", '''
  A = component
    @label?:: string := "fallback"
    render
      span
  a = A.new()
  a._init({})
  a.label.value
''', "fallback"

test "typed prop with default but no ? still applies the default at runtime", '''
  A = component
    @label:: string := "fallback"
    render
      span
  a = A.new()
  a._init({})
  a.label.value
''', "fallback"

test "component effect runs on state change", '''
  A = component
    x := 0
    log =! []
    ~> @log.push(x + 0)
  a = A.new()
  a.x.value = 1
  a.x.value = 2
  a.log
  ''', [0, 1, 2]

# Effects in components register their disposers via __getCurrentComponent
# so that unmount() can stop them from firing on later state changes. This
# is the contract the ARIA helpers rely on for popup listener cleanup.
test "component effect stops on unmount", '''
  A = component
    x := 0
    log =! []
    ~> @log.push(x + 0)
  a = A.new()
  a.x.value = 1
  a.unmount?(removeDOM: false)
  a.x.value = 2
  a.x.value = 3
  a.log
  ''', [0, 1]

# Cleanup-via-implicit-return: when a `~>` body returns a function, the
# reactive runtime stores it as the effect's cleanup and fires it before
# every re-run AND on dispose. This is THE pattern ARIA.bindPopover and
# friends rely on.
test "component effect cleanup runs before re-run and on unmount", '''
  A = component
    x := 0
    log =! []
    ~>
      val = x + 0
      @log.push("setup-#{val}")
      -> @log.push("cleanup-#{val}")
  a = A.new()
  a.x.value = 1
  a.x.value = 2
  a.unmount?(removeDOM: false)
  a.log
  ''', ['setup-0', 'cleanup-0', 'setup-1', 'cleanup-1', 'setup-2', 'cleanup-2']

# Wave 8a: a component's own effects register on that component's
# _disposers (the auto-registration via __getCurrentComponent during
# _init runs while the component is the current pushed component).
test "component owns its own effect disposers", '''
  A = component
    x := 0
    log =! []
    ~> @log.push(x + 0)
  a = A.new()
  a._disposers?.length > 0
  ''', true

# Wave 8a: Component.unmount() is idempotent — calling it twice does
# NOT re-fire beforeUnmount/unmounted hooks or cascade to children
# again.
test "Component.unmount is idempotent", '''
  count = 0
  A = component
    unmounted = -> count += 1
  a = A.new()
  a.unmount?(removeDOM: false)
  a.unmount?(removeDOM: false)
  a.unmount?(removeDOM: false)
  count
  ''', 1

# Wave 9a: `getEffectSignal()` returns the AbortSignal for the
# currently-running effect. On unmount, the signal aborts so async
# bodies (e.g. `fetch! url, {signal}`) can bail cleanly instead of
# resolving and mutating state on a destroyed component.
test "effect signal aborts on unmount", '''
  events = []
  A = component
    ~>
      signal = getEffectSignal()
      signal?.addEventListener 'abort', -> events.push 'aborted'
  a = A.new()
  a.unmount?(removeDOM: false)
  events
  ''', ['aborted']

# Wave 9a: the signal also aborts when the effect re-runs (its
# dependencies changed). Each re-run gets a fresh signal; the prior
# one fires 'abort' so any in-flight async work on the previous run
# unwinds.
test "effect signal aborts on re-run", '''
  aborts = 0
  A = component
    x := 0
    ~>
      v = x + 0
      signal = getEffectSignal()
      signal?.addEventListener 'abort', -> aborts += 1
  a = A.new()
  a.x.value = 1
  a.x.value = 2
  aborts
  ''', 2

# Wave 9b: when a component's _init throws AND a parent onError
# handles it, the constructor returns the instance with _initFailed
# set so the parent's _create can substitute a placeholder instead
# of running _create / _setup on a broken instance.
test "init failure with handled onError sets _initFailed flag", '''
  caught = null
  Bad = component
    onError = (err) -> caught = err.message
    _init = -> raise "boom"
  bad = Bad.new()
  # onError caught the error (existing semantics) AND _initFailed marks
  # the instance for parent emit-sites to substitute a placeholder.
  caught is "boom" and bad._initFailed is true
  ''', true

# Wave 9b: when _init throws AND no onError boundary handles it, the
# constructor re-throws. The parent's emitChildComponent block has its
# own try/catch that catches the throw and substitutes a placeholder.
# This test exercises just the throw-from-constructor side; full
# render-template integration requires DOM.
test "init failure without onError throws from constructor", '''
  Bad = component
    _init = -> raise "boom"
  caught = null
  try
    bad = Bad.new()
  catch e
    caught = e.message
  caught
  ''', "boom"

# Wave 10: each effect run has a unique runId; async resolutions from
# a SUPERSEDED run (effect re-ran while the prior body was awaiting)
# must NOT install their cleanup on the now-current run, AbortError
# from the superseded run must NOT be logged. This test simulates by
# triggering re-runs faster than a delayed promise resolves.
test "async effect: stale resolution does not overwrite current cleanup", '''
  cleanups = []
  A = component
    x := 0
    ~>
      v = x + 0
      -> cleanups.push("cleanup-#{v}")
  a = A.new()
  a.x.value = 1
  a.x.value = 2
  # Each run should install its cleanup, prior run's cleanup runs on
  # supersession. Order: setup-0; x=1 fires cleanup-0 then setup-1;
  # x=2 fires cleanup-1 then setup-2. Cleanups so far: ['cleanup-0',
  # 'cleanup-1']. unmount fires cleanup-2.
  a.unmount?(removeDOM: false)
  cleanups
  ''', ['cleanup-0', 'cleanup-1', 'cleanup-2']

# Wave 12: __pushComponent must NEVER set component._parent = component
# (self-cycle). The previous code unconditionally assigned _parent on
# every push; emitChildComponent's outer push of the parent (while the
# parent was already current via mount()) created a self-cycle that
# would hang getContext('missing') and __handleComponentError on a
# missing key/boundary.
test "__pushComponent does not create _parent self-cycle", '''
  A = component
    val =! "x"
  a = A.new()
  __pushComponent(a)         # a is now current
  __pushComponent(a)         # re-push while already current
  __popComponent(null)
  __popComponent(null)
  a._parent isnt a           # critical invariant
  ''', true

# Wave 12: getContext() on a missing key terminates even if the
# parent chain has a cycle (defensive cycle-detection guard).
test "getContext terminates on cycled parent chain", '''
  A = component
    val =! "x"
  a = A.new()
  a._parent = a              # poison the chain
  __pushComponent(a)
  result = getContext("missing")
  __popComponent(null)
  result is undefined        # returned, did not hang
  ''', true

# Wave 13: __pushComponent assigns _parent ONCE (on the first push
# under a different parent). Subsequent pushes (e.g. when the same
# component is re-pushed for its own mount or lifecycle hook)
# preserve the construction-time parent. Without this, the
# renderer's outer-layout -> page parent chain would survive
# construction but be clobbered by any later self-push.
test "__pushComponent preserves _parent across re-pushes", '''
  A = component
    val =! "outer"
  B = component
    val =! "inner"
  outer = A.new()
  inner = B.new()
  __pushComponent(outer)     # outer becomes current
  __pushComponent(inner)     # inner._parent = outer
  __popComponent(outer)
  __popComponent(null)
  __pushComponent(inner)     # re-push inner with no current — must NOT clobber to null
  __popComponent(null)
  inner._parent is outer
  ''', true

# Wave 13: layout/page context propagation survives mount lifecycle.
# A component constructed under a parent's scope must keep its parent
# even after its own mount() re-pushes it.
test "context propagates from outer to inner across re-push", '''
  Outer = component
    init = -> setContext("greeting", "hi")
  Inner = component
    val =! null
    _init = -> @val = getContext("greeting")
  outer = Outer.new()
  __pushComponent(outer)
  outer.init()
  inner = Inner.new()        # constructor runs _init under outer scope
  __popComponent(null)
  __pushComponent(inner)     # later self-push must preserve _parent
  again = getContext("greeting")
  __popComponent(null)
  inner.val is "hi" and again is "hi"
  ''', true

test "component computed with postfix ternary", '''
  A = component
    flag := false
    result ~= "yes" if flag else "no"
  a = A.new()
  before = a.result.value
  a.flag.value = true
  after = a.result.value
  before + "," + after
  ''', "no,yes"

# ==============================================================================
# Two-Way Binding — <=> generates effect + event listener
# ==============================================================================

code "two-way binding value (text input)", '''
  export A = component
    name := ""
    render
      input value <=> name
  ''', '''
  export const A = class extends __Component {
    _init(props) {
      this.name = __state("");
    }
    _create() {
      this._el0 = document.createElement('input');
      this._el0.addEventListener('input', (e) => { this.name.value = e.target.value; });
      return this._el0;
    }
    _setup() {
      __effect(() => { this._el0.value = this.name.value; });
    }
  }
  ''', opts

code "two-way binding checked (checkbox)", '''
  export A = component
    active := false
    render
      input type: "checkbox", checked <=> active
  ''', '''
  export const A = class extends __Component {
    _init(props) {
      this.active = __state(false);
    }
    _create() {
      this._el0 = document.createElement('input');
      this._el0.setAttribute('type', "checkbox");
      this._el0.addEventListener('change', (e) => { this.active.value = e.target.checked; });
      return this._el0;
    }
    _setup() {
      __effect(() => { this._el0.checked = this.active.value; });
    }
  }
  ''', opts

code "two-way binding valueAsNumber (number input)", '''
  export A = component
    age := 25
    render
      input type: "number", value <=> age
  ''', '''
  export const A = class extends __Component {
    _init(props) {
      this.age = __state(25);
    }
    _create() {
      this._el0 = document.createElement('input');
      this._el0.setAttribute('type', "number");
      this._el0.addEventListener('input', (e) => { this.age.value = e.target.valueAsNumber; });
      return this._el0;
    }
    _setup() {
      __effect(() => { this._el0.value = this.age.value; });
    }
  }
  ''', opts

code "value: reactive is one-way push (use <=> for two-way)", '''
  export A = component
    name := ""
    render
      input type: "text", value: name
  ''', '''
  export const A = class extends __Component {
    _init(props) {
      this.name = __state("");
    }
    _create() {
      this._el0 = document.createElement('input');
      this._el0.setAttribute('type', "text");
      return this._el0;
    }
    _setup() {
      __effect(() => { this._el0.value = this.name.value; });
    }
  }
  ''', opts

# ==============================================================================
# Dynamic Classes — .() / __clsx
# ==============================================================================

code "dynamic classes with .()", '''
  export A = component
    isActive := true
    render
      div.("card", isActive && "active")
  ''', '''
  export const A = class extends __Component {
    _init(props) {
      this.isActive = __state(true);
    }
    _create() {
      this._el0 = document.createElement('div');
      return this._el0;
    }
    _setup() {
      __effect(() => { this._el0.className = __clsx("card", (this.isActive.value && "active")); });
    }
  }
