codeBody "children prop", 'component Wrapper\n  @children?\n  render\n    div.wrapper @children', 'class Wrapper {\n  constructor(props = {}) {\n    this.children = props.children;\n  }\n  render() { return h(\'div.wrapper\', 0, this.children); }\n  mount(target) {\n    this._target = target;\n    this._dispose = __effect(() => {\n      const el = this.render();\n      if (this._el) this._el.replaceWith(el);\n      else target.appendChild(el);\n      this._el = el;\n    });\n    if (this.mounted) this.mounted();\n    return this;\n  }\n  unmount() {\n    if (this.unmounted) this.unmounted();\n    if (this._dispose) this._dispose();\n    if (this._el && this._el.parentNode) {\n      this._el.parentNode.removeChild(this._el);\n    }\n  }\n}'

