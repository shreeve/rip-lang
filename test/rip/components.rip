test "text output in switch loop with postfix if else compiles", '''
  A = component
    items := [{status: "ready"}]
    tab := "reports"
    render
      switch tab
        when "reports"
          div
            for report in items
              span
                = "Ready" if report.status is "ready" else "Processing"
        else
          div "Other"
  typeof A
''', "function"

test "text output in switch loop with attrs and postfix if else compiles", '''
  A = component
    items := [{status: "ready"}]
    tab := "reports"
    render
      switch tab
        when "reports"
          div
            for report in items
              span
                class: if report.status is "ready" then "a" else "b"
                = "Ready" if report.status is "ready" else "Processing"
        else
          div "Other"
  typeof A
''', "function"

test "uppercase loop iterable in render compiles as data, not component", '''
  A = component
    render
      div
        for report in RESULTS_REPORTS
          span
            = "Ready" if report.status is "ready" else "Processing"
  typeof A
''', "function"

# ==============================================================================
# Nested Structures — variable threading through block factories
# ==============================================================================

code "conditional inside loop threads loop vars", '''
  export A = component
    items := [{active: true}]
    render
      for item, i in items
        if item.active
          span "yes"
  ''', '''
  export const A = (() => {
  function create_block_1(ctx, item, i) {
    let _el2, _t0;
    return {
      c() {
        _el2 = document.createElement('span');
        _t0 = document.createTextNode("yes");
        _el2.appendChild(_t0);
        this._first = _el2;
      },
      m(target, anchor) {
        if (target) target.insertBefore(_el2, anchor);
      },
      p(ctx, item, i) {},
      d(detaching) {
        if (detaching && _el2) _el2.remove();
      }
    };
  }

  function create_block_0(ctx, item, i) {
    let _anchor1;
    let disposers = [];
    return {
      c() {
        _anchor1 = document.createComment('if');
        this._first = _anchor1;
      },
      m(target, anchor) {
        if (target) target.insertBefore(_anchor1, anchor);
      },
      p(ctx, item, i) {
        disposers.forEach(d => d());
        disposers = [];
        // Conditional: create_block_1
        {
          const anchor = _anchor1;
          let currentBlock = null;
          let showing = null;
          disposers.push(__effect(() => {
            const show = !!(item.active);
            const want = show ? 'then' : null;
            if (want === showing) return;
            if (currentBlock) {
              const leaving = currentBlock;
              if (leaving._t) { __transition(leaving._first, leaving._t, 'leave', () => leaving.d(true)); }
              else { leaving.d(true); }
              currentBlock = null;
            }
            showing = want;
            if (want === 'then') {
              currentBlock = create_block_1(ctx, item, i);
              currentBlock.c();
              if (anchor.parentNode) currentBlock.m(anchor.parentNode, anchor.nextSibling);
              currentBlock.p(ctx, item, i);
              if (currentBlock._t) __transition(currentBlock._first, currentBlock._t, 'enter');
            }
          }));
          disposers.push(() => { if (currentBlock) { currentBlock.d(true); currentBlock = null; } });
        }
      },
      d(detaching) {
        disposers.forEach(d => d());
        if (detaching && _anchor1) _anchor1.remove();
      }
    };
  }

  return class extends __Component {
    _init(props) {
      this.items = __state([{active: true}]);
    }
    _create() {
      this._anchor0 = document.createComment('for');
      return this._anchor0;
    }
    _setup() {
      // Loop: create_block_0
      {
        const __s = { blocks: [], keys: [] };
        __effect(() => {
          __reconcile(this._anchor0, __s, this.items.value, this, create_block_0, null);
        });
      }
    }
  };
  })()
  ''', opts

code "nested loops thread outer vars", '''
  export A = component
    rows := [[1, 2]]
    render
      for row, ri in rows
        for cell, ci in row
          span cell
  ''', '''
  export const A = (() => {
  function create_block_1(ctx, cell, ci, row, ri) {
    let _el2, _t0;
    return {
      _s: true,
      c() {
        _el2 = document.createElement('span');
        _t0 = document.createTextNode(cell);
        _el2.appendChild(_t0);
        this._first = _el2;
      },
      m(target, anchor) {
        if (target) target.insertBefore(_el2, anchor);
      },
      p(ctx, cell, ci, row, ri) {},
      d(detaching) {
        if (detaching && _el2) _el2.remove();
      }
    };
  }

  function create_block_0(ctx, row, ri) {
    let _anchor1;
    let disposers = [];
    return {
      c() {
        _anchor1 = document.createComment('for');
        this._first = _anchor1;
      },
      m(target, anchor) {
        if (target) target.insertBefore(_anchor1, anchor);
      },
      p(ctx, row, ri) {
        disposers.forEach(d => d());
        disposers = [];
        // Loop: create_block_1
        {
          const __s = { blocks: [], keys: [] };
          disposers.push(__effect(() => {
            __reconcile(_anchor1, __s, row, ctx, create_block_1, null, row, ri);
          }));
        }
      },
      d(detaching) {
        disposers.forEach(d => d());
        if (detaching && _anchor1) _anchor1.remove();
      }
    };
  }

  return class extends __Component {
    _init(props) {
      this.rows = __state([[1, 2]]);
    }
    _create() {
      this._anchor0 = document.createComment('for');
      return this._anchor0;
    }
    _setup() {
      // Loop: create_block_0
      {
        const __s = { blocks: [], keys: [] };
        __effect(() => {
          __reconcile(this._anchor0, __s, this.rows.value, this, create_block_0, null);
        });
      }
    }
  };
  })()
  ''', opts

