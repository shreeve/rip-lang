codeBody "component with classes", "component Card\n  render\n    div.card.shadow", "class Card {\n  constructor(props = {}) {\n  }\n  render() { return h('div.card.shadow', 0); }\n  mount(target) {\n    this._target = target;\n    this._dispose = __effect(() => {\n      const el = this.render();\n      if (this._el) this._el.replaceWith(el);\n      else target.appendChild(el);\n      this._el = el;\n    });\n    if (this.mounted) this.mounted();\n    return this;\n  }\n  unmount() {\n    if (this.unmounted) this.unmounted();\n    if (this._dispose) this._dispose();\n    if (this._el && this._el.parentNode) {\n      this._el.parentNode.removeChild(this._el);\n    }\n  }\n}"

codeBody "component with multiple roots", 'component Multi\n  render\n    div "One"\n    div "Two"', 'class Multi {\n  constructor(props = {}) {\n  }\n  render() { return frag(h(\'div\', 0, "One"), h(\'div\', 0, "Two")); }\n  mount(target) {\n    this._target = target;\n    this._dispose = __effect(() => {\n      const el = this.render();\n      if (this._el) this._el.replaceWith(el);\n      else target.appendChild(el);\n      this._el = el;\n    });\n    if (this.mounted) this.mounted();\n    return this;\n  }\n  unmount() {\n    if (this.unmounted) this.unmounted();\n    if (this._dispose) this._dispose();\n    if (this._el && this._el.parentNode) {\n      this._el.parentNode.removeChild(this._el);\n    }\n  }\n}'

# ------------------------------------------------------------------------------
# Component Props
# ------------------------------------------------------------------------------

codeBody "required prop", "component Button\n  @label\n  render\n    button @label", 'class Button {\n  constructor(props = {}) {\n    if (props.label === undefined) throw new Error(\'Required prop: label\');\n    this.label = props.label;\n  }\n  render() { return h(\'button\', 0, txt(this.label)); }\n  mount(target) {\n    this._target = target;\n    this._dispose = __effect(() => {\n      const el = this.render();\n      if (this._el) this._el.replaceWith(el);\n      else target.appendChild(el);\n      this._el = el;\n    });\n    if (this.mounted) this.mounted();\n    return this;\n  }\n  unmount() {\n    if (this.unmounted) this.unmounted();\n    if (this._dispose) this._dispose();\n    if (this._el && this._el.parentNode) {\n      this._el.parentNode.removeChild(this._el);\n    }\n  }\n}'

codeBody "optional prop", "component Card\n  @subtitle?\n  render\n    div", 'class Card {\n  constructor(props = {}) {\n    this.subtitle = props.subtitle;\n  }\n  render() { return h(\'div\', 0); }\n  mount(target) {\n    this._target = target;\n    this._dispose = __effect(() => {\n      const el = this.render();\n      if (this._el) this._el.replaceWith(el);\n      else target.appendChild(el);\n      this._el = el;\n    });\n    if (this.mounted) this.mounted();\n    return this;\n  }\n  unmount() {\n    if (this.unmounted) this.unmounted();\n    if (this._dispose) this._dispose();\n    if (this._el && this._el.parentNode) {\n      this._el.parentNode.removeChild(this._el);\n    }\n  }\n}'

codeBody "prop with default", 'component Button\n  @size = "md"\n  render\n    button', 'class Button {\n  constructor(props = {}) {\n    this.size = props.size ?? "md";\n  }\n  render() { return h(\'button\', 0); }\n  mount(target) {\n    this._target = target;\n    this._dispose = __effect(() => {\n      const el = this.render();\n      if (this._el) this._el.replaceWith(el);\n      else target.appendChild(el);\n      this._el = el;\n    });\n    if (this.mounted) this.mounted();\n    return this;\n  }\n  unmount() {\n    if (this.unmounted) this.unmounted();\n    if (this._dispose) this._dispose();\n    if (this._el && this._el.parentNode) {\n      this._el.parentNode.removeChild(this._el);\n    }\n  }\n}'

codeBody "rest props", "component Input\n  @label\n  @...rest\n  render\n    div", 'class Input {\n  constructor(props = {}) {\n    if (props.label === undefined) throw new Error(\'Required prop: label\');\n    this.label = props.label;\n    const { label, ...rest } = props;\n    this.rest = rest;\n  }\n  render() { return h(\'div\', 0); }\n  mount(target) {\n    this._target = target;\n    this._dispose = __effect(() => {\n      const el = this.render();\n      if (this._el) this._el.replaceWith(el);\n      else target.appendChild(el);\n      this._el = el;\n    });\n    if (this.mounted) this.mounted();\n    return this;\n  }\n  unmount() {\n    if (this.unmounted) this.unmounted();\n    if (this._dispose) this._dispose();\n    if (this._el && this._el.parentNode) {\n      this._el.parentNode.removeChild(this._el);\n    }\n  }\n}'

