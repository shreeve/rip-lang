# Test: Standard Library Helpers
#
# Locks in the runtime behavior of the global stdlib helpers injected into
# every compiled file. These globals come from `getStdlibCode()` in
# `src/stdlib.js`.
#
# The four print helpers (p / pp / pr / pj) are all chainable: they print
# something, then return their argument. That property lets you drop one
# into the middle of a pipeline (`x = pr something()`) without disrupting
# control flow. Each test below exercises that contract on a different
# value type so a future refactor can't silently break it.
#
# `pr` is the one with non-trivial fallback semantics — it produces Rip
# syntax for plain values (literals, arrays, plain objects, interned
# symbols) and falls back to `console.dir`-style inspect for anything
# that has no faithful Rip-literal form (class instances, Date, BigInt,
# Map/Set, non-interned Symbols, functions). Tests below verify the
# fallback path doesn't throw.

# ==============================================================================
# All four print helpers exist as global functions
# ==============================================================================

test "p is a function",  "typeof p",  "function"
test "pp is a function", "typeof pp", "function"
test "pr is a function", "typeof pr", "function"
test "pj is a function", "typeof pj", "function"

# ==============================================================================
# Chainable: each helper returns its argument unchanged
# ==============================================================================

test "p returns void (no-op chainable test below)", "p 42; 42", 42
test "pp returns argument (number)", "pp 42", 42
test "pr returns argument (number)", "pr 42", 42
test "pj returns argument (number)", "pj 42", 42
test "pp returns argument (string)", "pp 'hello'", "hello"
test "pr returns argument (string)", "pr 'hello'", "hello"
test "pj returns argument (string)", "pj 'hello'", "hello"

# Reference-identity for collections: the value handed in is the value
# returned out (not a copy).
test "pp returns same object", "x = {a: 1}; pp(x) is x", true
test "pr returns same object", "x = {a: 1}; pr(x) is x", true
test "pj returns same array",  "y = [1,2,3]; pj(y) is y", true

# ==============================================================================
# pr: tolerant fallback for values without a Rip-literal form
# ==============================================================================
#
# These test only that pr DOESN'T THROW on the input. The actual rendered
# output goes through console.dir for the fallback path, which is the
# debug behavior we want — never crash a debug session.

test "pr handles class instance", '''
  class Foo
    constructor: -> @x = 1
  result = try
    pr new Foo
    'ok'
  catch
    'threw'
  result
''', 'ok'

test "pr handles Date", "(try pr new Date(); 'ok' catch then 'threw')", 'ok'
test "pr handles Map",  "(try pr new Map(); 'ok' catch then 'threw')", 'ok'
test "pr handles Set",  "(try pr new Set(); 'ok' catch then 'threw')", 'ok'
test "pr handles BigInt", "(try pr 1n; 'ok' catch then 'threw')", 'ok'
test "pr handles non-interned symbol", "(try pr Symbol('local'); 'ok' catch then 'threw')", 'ok'
test "pr handles function", "(try pr (-> 42); 'ok' catch then 'threw')", 'ok'
test "pr handles null", "(try pr null; 'ok' catch then 'threw')", 'ok'
test "pr handles undefined", "(try pr undefined; 'ok' catch then 'threw')", 'ok'

# ==============================================================================
# pj produces machine-parseable JSON for trivial values
# ==============================================================================
#
# We can't easily snapshot pj's stdout output from inside a test, but we
# can confirm it runs without error and returns the value. Combined with
# the type-check on `pj` above, this gives the round-trip-by-construction
# guarantee for primitive types.

test "pj passes object through", "x = { a: 1, b: [2,3] }; pj(x) is x", true
test "pj passes nested array through", "y = [[1,2],[3,4]]; pj(y) is y", true