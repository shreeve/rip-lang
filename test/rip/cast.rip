# @nocheck
# Test: `expr as Type` cast operator
#
# A TypeScript-style postfix type assertion. The cast is ERASED at runtime
# (the value is emitted unchanged) and only re-materializes as a real TS
# `(expr as Type)` in the shadow-TS check path (`inlineTypes`). The type RHS
# is stripped to a string by the type rewriter, so the grammar never parses a
# type — `as` reuses the same machinery as `::` annotations.

# ==============================================================================
# Runtime erasure — the cast leaves no trace in the emitted JS
# ==============================================================================

code "cast on identifier erased", "y = x as Foo", "y = x"
code "parenthesized cast erased", "y = (x as Foo)", "y = x"
code "cast inside call erased", "foo(x as Bar)", "foo(x)"
code "cast inside array erased", "z = [a as T]", "z = [a]"
code "cast on member access erased", "r = obj.prop as T", "r = obj.prop"
code "cast on call result erased", "c = foo(1) as T", "c = foo(1)"
code "cast on index erased", "i = arr[0] as T", "i = arr[0]"

# ==============================================================================
# Precedence — cast binds tighter than binary operators (postfix)
# ==============================================================================

# `x as Bar + n` is `(x as Bar) + n` — the type collection stops at `+`.
code "cast stops before plus", "y = x as Bar + n", "y = x + n"

# ==============================================================================
# Type operators inside the cast type are consumed, not stops
# ==============================================================================

code "cast with generic type", "m = x as Map<string, number>", "m = x"
code "cast with union type", "u = x as A | B", "u = x"
code "cast with intersection type", "k = x as A & B", "k = x"
code "cast with object type", "o = x as { a: number }", "o = x"
code "cast with array type", "a = x as number[]", "a = x"

# ==============================================================================
# Chaining — `x as A as B`
# ==============================================================================

code "chained casts erased", "y = x as A as B", "y = x"

# ==============================================================================
# Shadow-TS check path — the cast becomes a real TS assertion (it narrows)
# ==============================================================================
#
# Route A: the cast is a grammar node that reduces AFTER the full postfix
# expression is built, so EVERY carrier narrows — identifier, member access,
# AND call / index / parenthesized results.

code "inlineTypes keeps TS cast", "y = x as Foo", "y = x as Foo", { inlineTypes: true }
code "inlineTypes keeps generic cast", "m = x as Map<string, number>", "m = (x as Map<string, number>)", { inlineTypes: true }
code "inlineTypes cast precedence", "y = x as Bar + n", "y = (x as Bar) + n", { inlineTypes: true }
code "inlineTypes chained cast", "y = x as A as B", "y = (x as A) as B", { inlineTypes: true }
code "inlineTypes parenthesized identifier", "y = (x as Foo)", "y = x as Foo", { inlineTypes: true }
code "inlineTypes member access narrows", "r = obj.prop as Foo", "r = obj.prop as Foo", { inlineTypes: true }

# ==============================================================================
# Full narrowing — call / index / paren-prefixed results now narrow too
# (the route-A grammar node closes the old RFC-12 carrier gap).
# ==============================================================================

code "inlineTypes call result narrows", "c = foo(1) as Foo", "c = foo(1) as Foo", { inlineTypes: true }
code "inlineTypes index result narrows", "i = arr[0] as Foo", "i = arr[0] as Foo", { inlineTypes: true }
code "inlineTypes paren-prefixed narrows", "y = (x) as Foo", "y = x as Foo", { inlineTypes: true }

# ==============================================================================
# `as` is NOT a cast in for / import / export / property contexts
# ==============================================================================

code "for-as iteration unaffected", '''
  for x as items
    p x
  ''', '''
  for (let x of items) {
    p(x);
  }
  '''

code "for-as! async iteration unaffected", '''
  for x as! items
    p x
  ''', '''
  for await (let x of items) {
    p(x);
  }
  '''

code "import-as alias unaffected", "import { foo as bar } from 'mod'", "import { foo as bar } from 'mod'"
code "import-namespace-as unaffected", "import * as NS from 'mod'", "import * as NS from 'mod'"
code "export-as re-export unaffected", "export { x as y } from 'mod'", "export { x as y } from 'mod'"
code "dot-as is a property, not a cast", "y = obj.as", "y = obj.as"
