export Button = component extends button
  @variant:: 'primary' | 'secondary' := 'primary'
  @outline:: boolean := false
  @link:: boolean := false
  @loading:: boolean := false

  render
    button
      aria-busy: @loading
      disabled: @loading or @rest.disabled
      class: [
        @variant
        @outline and 'outline'
        @link and 'link'
        @rest.class
      ]
      slot
