import { get, use, start, notFound } from '@rip-lang/server'
import { serve } from '@rip-lang/server/middleware'

dir = import.meta.dir

import './api/routes/index.rip'

use serve dir: "#{dir}/app", components: ['app/components'], watch: true

notFound -> @send "#{dir}/app/index.html", 'text/html; charset=UTF-8'

start!
